#Область ПрограммныйИнтерфейс

// Собирает HTML списка категорий с группами (навигация по родителю).
//
Функция HTMLСпискаКатегорий(ЭтоРасход, СтрокаПоиска = "", ТекущийРодитель = Неопределено) Экспорт
	
	Акцент = АкцентКатегорий(ЭтоРасход);
	ЗаголовокСписка = ЗаголовокСпискаКатегорий(ЭтоРасход, ТекущийРодитель);
	Подсказка = ?(ЭтоРасход,
		"Категории используются в документах расхода и отчетах",
		"Категории используются в документах дохода и отчетах");
	ПлейсхолдерПоиска = "Поиск категории";
	ЕстьПоиск = Не ПустаяСтрока(СокрЛП(СтрокаПоиска));
	
	Таблица = ТаблицаКатегорийДляСписка(ЭтоРасход, СтрокаПоиска, ТекущийРодитель);
	Статистика = СтатистикаОперацийКатегорий(ЭтоРасход, Ложь);
	
	Строки = Новый Массив;
	ДобавитьШапкуHTML(Строки, СтилиСпискаИВыбора(Акцент));
	Строки.Добавить("<div class=""top"">");
	Строки.Добавить("<a class=""icon-btn"" href=""app:back"">" + SVGСтрелкаНазад() + "</a>");
	Строки.Добавить("<div class=""title"">" + ЭкранироватьHTML(ЗаголовокСписка) + "</div>");
	Строки.Добавить("<a class=""icon-btn"" href=""app:add"">" + SVGПлюс(Акцент) + "</a></div>");
	Строки.Добавить("<a class=""search"" href=""app:search""><span class=""search-ico"">" + SVGПоиск()
		+ "</span><span class=""search-text"">"
		+ ЭкранироватьHTML(?(ЕстьПоиск, СтрокаПоиска, ПлейсхолдерПоиска))
		+ "</span></a>");
	Строки.Добавить("<div class=""info"">" + ЭкранироватьHTML(Подсказка) + "</div>");
	Строки.Добавить("<div class=""list"">");
	
	Если Таблица.Количество() = 0 Тогда
		
		Строки.Добавить("<div class=""empty"">Категории не найдены</div>");
		
	Иначе
		
		Для Каждого СтрокаКатегории Из Таблица Цикл
			
			Если СтрокаКатегории.ЭтоГруппа Тогда
				
				Ссылка = "app:folder:" + Строка(СтрокаКатегории.Ссылка.УникальныйИдентификатор());
				Строки.Добавить("<a class=""item group"" href=""" + Ссылка + """>");
				Строки.Добавить("<span class=""ico"" style=""background:#EEF2FF;color:#4F46E5"">"
					+ SVGПапка() + "</span>");
				Строки.Добавить("<span class=""mid""><span class=""name"">" + ЭкранироватьHTML(СтрокаКатегории.Наименование)
					+ "</span><span class=""sub"">Группа</span></span>");
				Строки.Добавить("<span class=""right""><span class=""chev"">›</span></span></a>");
				
			Иначе
				
				Количество = 0;
				СтрокаСтатистики = Статистика.Найти(СтрокаКатегории.Ссылка, "Категория");
				
				Если СтрокаСтатистики <> Неопределено Тогда
					
					Количество = СтрокаСтатистики.Количество;
					
				КонецЕсли;
				
				ПодписьКоличества = ПредставлениеКоличестваОпераций(Количество);
				КодИконки = КодИконкиКатегории(СтрокаКатегории.КодИконки, СтрокаКатегории.Наименование, ЭтоРасход);
				Описание = ?(ЗначениеЗаполнено(СтрокаКатегории.Описание), СтрокаКатегории.Описание, "Без описания");
				Ссылка = "app:open:" + Строка(СтрокаКатегории.Ссылка.УникальныйИдентификатор());
				
				Строки.Добавить("<a class=""item"" href=""" + Ссылка + """>");
				Строки.Добавить("<span class=""ico"" style=""background:" + Акцент.ФонИконки + ";color:" + Акцент.Цвет
					+ """>" + SVGИконкаКатегории(КодИконки) + "</span>");
				Строки.Добавить("<span class=""mid""><span class=""name"">" + ЭкранироватьHTML(СтрокаКатегории.Наименование)
					+ "</span><span class=""sub"">" + ЭкранироватьHTML(Описание) + "</span></span>");
				Строки.Добавить("<span class=""right""><span class=""meta"">" + ЭкранироватьHTML(ПодписьКоличества)
					+ "</span><span class=""chev"">›</span></span></a>");
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
	Строки.Добавить("</div></body></html>");
	
	Возврат СтрСоединить(Строки, Символы.ПС);
	
КонецФункции

// Собирает HTML формы выбора категории.
//
Функция HTMLВыбораКатегорий(ЭтоРасход, ТекущаяКатегория = Неопределено, СтрокаПоиска = "") Экспорт
	
	Акцент = АкцентКатегорий(ЭтоРасход);
	ЗаголовокВыбора = ?(ЭтоРасход, "Выбор расхода", "Выбор дохода");
	Подсказка = ?(ЭтоРасход, "Выберите категорию для операции расхода", "Выберите категорию для операции дохода");
	ПлейсхолдерПоиска = "Найти категорию";
	
	Таблица = ТаблицаКатегорий(ЭтоРасход, СтрокаПоиска, Истина);
	
	Строки = Новый Массив;
	ДобавитьШапкуHTML(Строки, СтилиСпискаИВыбора(Акцент) + СтилиКнопкиВыбора(Акцент));
	Строки.Добавить("<div class=""top"">");
	Строки.Добавить("<a class=""icon-btn"" href=""app:back"">" + SVGСтрелкаНазад() + "</a>");
	Строки.Добавить("<div class=""title"">" + ЭкранироватьHTML(ЗаголовокВыбора) + "</div>");
	Строки.Добавить("<a class=""icon-btn"" href=""app:add"">" + SVGПлюс(Акцент) + "</a></div>");
	Строки.Добавить("<a class=""search"" href=""app:search""><span class=""search-ico"">" + SVGПоиск()
		+ "</span><span class=""search-text"">"
		+ ЭкранироватьHTML(?(ПустаяСтрока(СтрокаПоиска), ПлейсхолдерПоиска, СтрокаПоиска))
		+ "</span></a>");
	Строки.Добавить("<div class=""hint"">" + ЭкранироватьHTML(Подсказка) + "</div>");
	Строки.Добавить("<div class=""list choice"">");
	
	Если Таблица.Количество() = 0 Тогда
		
		Строки.Добавить("<div class=""empty"">Категории не найдены</div>");
		
	Иначе
		
		Для Каждого СтрокаКатегории Из Таблица Цикл
			
			Выбран = ЗначениеЗаполнено(ТекущаяКатегория) И СтрокаКатегории.Ссылка = ТекущаяКатегория;
			Класс = ?(Выбран, "item selected", "item");
			КодИконки = КодИконкиКатегории(СтрокаКатегории.КодИконки, СтрокаКатегории.Наименование, ЭтоРасход);
			Описание = ?(ЗначениеЗаполнено(СтрокаКатегории.Описание), СтрокаКатегории.Описание, "Без описания");
			Ссылка = "app:pick:" + Строка(СтрокаКатегории.Ссылка.УникальныйИдентификатор());
			
			Строки.Добавить("<a class=""" + Класс + """ href=""" + Ссылка + """>");
			Строки.Добавить("<span class=""ico"" style=""background:" + Акцент.ФонИконки + ";color:" + Акцент.Цвет
				+ """>" + SVGИконкаКатегории(КодИконки) + "</span>");
			Строки.Добавить("<span class=""mid""><span class=""name"">" + ЭкранироватьHTML(СтрокаКатегории.Наименование)
				+ "</span><span class=""sub"">" + ЭкранироватьHTML(Описание) + "</span></span>");
			
			Если Выбран Тогда
				
				Строки.Добавить("<span class=""check"">✓</span>");
				
			Иначе
				
				Строки.Добавить("<span class=""chev"">›</span>");
				
			КонецЕсли;
			
			Строки.Добавить("</a>");
			
		КонецЦикла;
		
	КонецЕсли;
	
	Строки.Добавить("</div>");
	
	Если ЗначениеЗаполнено(ТекущаяКатегория) Тогда
		
		ПодписьКнопки = "Выбрать: " + Строка(ТекущаяКатегория);
		Строки.Добавить("<div class=""footer""><a class=""btn"" href=""app:confirm"">"
			+ ЭкранироватьHTML(ПодписьКнопки) + "</a></div>");
		
	КонецЕсли;
	
	Строки.Добавить("</body></html>");
	
	Возврат СтрСоединить(Строки, Символы.ПС);
	
КонецФункции

// Собирает HTML карточки категории (элемент / набор иконок / выбор родителя).
//
Функция HTMLЭлементаКатегории(ЭтоРасход, ДанныеКатегории, РежимВыбораИконки = Ложь, РежимВыбораРодителя = Ложь) Экспорт
	
	Акцент = АкцентКатегорий(ЭтоРасход);
	ЗаголовокФормы = ?(ЭтоРасход, "Категория расхода", "Категория дохода");
	Инфо = ?(ЭтоРасход,
		"Категория будет доступна в документе «Новый расход» и отчетах по расходам",
		"Категория будет доступна в документе «Новый доход» и отчетах по доходам");
	
	Если РежимВыбораИконки Тогда
		
		Возврат HTMLНабораИконок(ЭтоРасход, ДанныеКатегории, Акцент, ЗаголовокФормы);
		
	КонецЕсли;
	
	Если РежимВыбораРодителя Тогда
		
		Возврат HTMLВыбораРодителя(ЭтоРасход, ДанныеКатегории, Акцент, ЗаголовокФормы);
		
	КонецЕсли;
	
	КодИконки = КодИконкиКатегории(ДанныеКатегории.КодИконки, ДанныеКатегории.Наименование, ЭтоРасход);
	Наименование = ?(ЗначениеЗаполнено(ДанныеКатегории.Наименование), ДанныеКатегории.Наименование, "Без названия");
	Описание = ?(ЗначениеЗаполнено(ДанныеКатегории.Описание), ДанныеКатегории.Описание, "Добавить описание");
	РодительТекст = ?(ЗначениеЗаполнено(ДанныеКатегории.РодительНаименование), ДанныеКатегории.РодительНаименование, "Без группы");
	Показывать = ?(ДанныеКатегории.ПоказыватьВВыборе, "on", "off");
	МожноЗаписать = ЗначениеЗаполнено(ДанныеКатегории.Наименование);
	ПодписьКнопки = ?(МожноЗаписать, "Записать категорию", "Укажите наименование");
	КлассКнопки = ?(МожноЗаписать, "btn", "btn disabled");
	СсылкаКнопки = ?(МожноЗаписать, "app:save", "app:noop");
	
	Строки = Новый Массив;
	ДобавитьШапкуHTML(Строки, СтилиЭлемента(Акцент));
	Строки.Добавить("<div class=""top"">");
	Строки.Добавить("<a class=""icon-btn"" href=""app:back"">" + SVGСтрелкаНазад() + "</a>");
	Строки.Добавить("<div class=""title"">" + ЭкранироватьHTML(ЗаголовокФормы) + "</div>");
	
	Если ДанныеКатегории.Предопределенный Тогда
		
		Строки.Добавить("<span class=""icon-btn ghost""></span>");
		
	Иначе
		
		Строки.Добавить("<a class=""icon-btn"" href=""app:delete"">" + SVGКорзина() + "</a>");
		
	КонецЕсли;
	
	Строки.Добавить("</div>");
	Строки.Добавить("<a class=""hero"" href=""app:icons"">");
	Строки.Добавить("<span class=""ico big"" style=""background:" + Акцент.ФонИконки + ";color:" + Акцент.Цвет
		+ """>" + SVGИконкаКатегории(КодИконки) + "</span>");
	Строки.Добавить("<span class=""hero-text"">Иконка и цвет</span><span class=""chev"">›</span></a>");
	Строки.Добавить("<a class=""card"" href=""app:name""><span class=""label"">Наименование</span>"
		+ "<span class=""value"">" + ЭкранироватьHTML(Наименование) + "</span></a>");
	Строки.Добавить("<a class=""card"" href=""app:desc""><span class=""label"">Описание</span>"
		+ "<span class=""value muted"">" + ЭкранироватьHTML(Описание) + "</span></a>");
	Строки.Добавить("<a class=""card"" href=""app:parent""><span class=""label"">Группа</span>"
		+ "<span class=""value"">" + ЭкранироватьHTML(РодительТекст) + "</span></a>");
	Строки.Добавить("<a class=""card row"" href=""app:toggle-show""><span class=""label"">Показывать в выборе</span>"
		+ "<span class=""switch " + Показывать + """></span></a>");
	Строки.Добавить("<div class=""info"">" + ЭкранироватьHTML(Инфо) + "</div>");
	Строки.Добавить("<div class=""footer""><a class=""" + КлассКнопки + """ href=""" + СсылкаКнопки + """>"
		+ ЭкранироватьHTML(ПодписьКнопки) + "</a></div>");
	Строки.Добавить("</body></html>");
	
	Возврат СтрСоединить(Строки, Символы.ПС);
	
КонецФункции

// Возвращает ссылку категории по UUID-строке.
//
Функция КатегорияПоИдентификатору(ЭтоРасход, ИдентификаторСтрокой) Экспорт
	
	Если Не ЗначениеЗаполнено(ИдентификаторСтрокой) Тогда
		
		Возврат ?(ЭтоРасход, Справочники.КатегорииРасходов.ПустаяСсылка(), Справочники.КатегорииДоходов.ПустаяСсылка());
		
	КонецЕсли;
	
	Идентификатор = Новый УникальныйИдентификатор(ИдентификаторСтрокой);
	
	Если ЭтоРасход Тогда
		
		Возврат Справочники.КатегорииРасходов.ПолучитьСсылку(Идентификатор);
		
	КонецЕсли;
	
	Возврат Справочники.КатегорииДоходов.ПолучитьСсылку(Идентификатор);
	
КонецФункции

// Возвращает данные категории для карточки операции: имя, описание, SVG, цвета.
//
Функция ДанныеОтображенияКатегории(ЭтоРасход, Категория) Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("Заполнена", Ложь);
	Результат.Вставить("Наименование", "Выберите категорию");
	Результат.Вставить("Описание", "Категория операции");
	Результат.Вставить("SVG", SVGИконкаКатегории(?(ЭтоРасход, "other", "wallet")));
	Результат.Вставить("ЦветИконки", ?(ЭтоРасход, "#DC2626", "#16A34A"));
	Результат.Вставить("ФонИконки", ?(ЭтоРасход, "#FEE2E2", "#DCFCE7"));
	
	Если Не ЗначениеЗаполнено(Категория) Тогда
		
		Возврат Результат;
		
	КонецЕсли;
	
	Наименование = Строка(Категория);
	Описание = "";
	КодИконки = "";
	
	Если ЭтоРасход Тогда
		
		Значения = ОбщегоНазначенияЗначенияРеквизитовКатегорииРасхода(Категория);
		
	Иначе
		
		Значения = ОбщегоНазначенияЗначенияРеквизитовКатегорииДохода(Категория);
		
	КонецЕсли;
	
	Если Значения <> Неопределено Тогда
		
		Наименование = Значения.Наименование;
		Описание = Значения.Описание;
		КодИконки = Значения.КодИконки;
		
	КонецЕсли;
	
	Код = КодИконкиКатегории(КодИконки, Наименование, ЭтоРасход);
	Результат.Заполнена = Истина;
	Результат.Наименование = Наименование;
	Результат.Описание = ?(ЗначениеЗаполнено(Описание), Описание, "Без описания");
	Результат.SVG = SVGИконкаКатегории(Код);
	
	Возврат Результат;
	
КонецФункции

// Экранирует текст для HTML.
//
Функция ЭкранироватьHTML(Знач Текст) Экспорт
	
	Результат = Строка(Текст);
	Результат = СтрЗаменить(Результат, "&", "&amp;");
	Результат = СтрЗаменить(Результат, "<", "&lt;");
	Результат = СтрЗаменить(Результат, ">", "&gt;");
	Результат = СтрЗаменить(Результат, """", "&quot;");
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ОбщегоНазначенияЗначенияРеквизитовКатегорииРасхода(Категория)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Категории.Наименование КАК Наименование,
	|	Категории.Описание КАК Описание,
	|	Категории.КодИконки КАК КодИконки
	|ИЗ
	|	Справочник.КатегорииРасходов КАК Категории
	|ГДЕ
	|	Категории.Ссылка = &Ссылка";
	Запрос.УстановитьПараметр("Ссылка", Категория);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		
		Возврат Новый Структура("Наименование, Описание, КодИконки",
			Выборка.Наименование, Выборка.Описание, Выборка.КодИконки);
		
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

Функция ОбщегоНазначенияЗначенияРеквизитовКатегорииДохода(Категория)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Категории.Наименование КАК Наименование,
	|	Категории.Описание КАК Описание,
	|	Категории.КодИконки КАК КодИконки
	|ИЗ
	|	Справочник.КатегорииДоходов КАК Категории
	|ГДЕ
	|	Категории.Ссылка = &Ссылка";
	Запрос.УстановитьПараметр("Ссылка", Категория);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		
		Возврат Новый Структура("Наименование, Описание, КодИконки",
			Выборка.Наименование, Выборка.Описание, Выборка.КодИконки);
		
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

Функция HTMLНабораИконок(ЭтоРасход, ДанныеКатегории, Акцент, ЗаголовокФормы)
	
	ТекущийКод = КодИконкиКатегории(ДанныеКатегории.КодИконки, ДанныеКатегории.Наименование, ЭтоРасход);
	Коды = НаборКодовИконок(ЭтоРасход);
	
	Строки = Новый Массив;
	ДобавитьШапкуHTML(Строки, СтилиЭлемента(Акцент) + СтилиСеткиИконок(Акцент));
	Строки.Добавить("<div class=""top"">");
	Строки.Добавить("<a class=""icon-btn"" href=""app:icons-back"">" + SVGСтрелкаНазад() + "</a>");
	Строки.Добавить("<div class=""title"">" + ЭкранироватьHTML(ЗаголовокФормы) + "</div>");
	Строки.Добавить("<span class=""icon-btn ghost""></span></div>");
	Строки.Добавить("<div class=""section-title"">Выберите иконку</div>");
	Строки.Добавить("<div class=""icons"">");
	
	Для Каждого Код Из Коды Цикл
		
		Выбран = Код = ТекущийКод;
		Класс = ?(Выбран, "icon-cell selected", "icon-cell");
		Строки.Добавить("<a class=""" + Класс + """ href=""app:icon:" + Код + """>"
			+ "<span class=""ico"" style=""background:" + Акцент.ФонИконки + ";color:" + Акцент.Цвет + """>"
			+ SVGИконкаКатегории(Код) + "</span></a>");
		
	КонецЦикла;
	
	Строки.Добавить("</div></body></html>");
	
	Возврат СтрСоединить(Строки, Символы.ПС);
	
КонецФункции

Функция HTMLВыбораРодителя(ЭтоРасход, ДанныеКатегории, Акцент, ЗаголовокФормы)
	
	ТаблицаГрупп = ТаблицаГруппКатегорий(ЭтоРасход, ДанныеКатегории.Ссылка);
	ТекущийРодитель = ДанныеКатегории.Родитель;
	
	Строки = Новый Массив;
	ДобавитьШапкуHTML(Строки, СтилиСпискаИВыбора(Акцент));
	Строки.Добавить("<div class=""top"">");
	Строки.Добавить("<a class=""icon-btn"" href=""app:parent-back"">" + SVGСтрелкаНазад() + "</a>");
	Строки.Добавить("<div class=""title"">" + ЭкранироватьHTML(ЗаголовокФормы) + "</div>");
	Строки.Добавить("<span class=""icon-btn ghost""></span></div>");
	Строки.Добавить("<div class=""section-title"">Выберите группу</div>");
	Строки.Добавить("<div class=""list"">");
	
	КлассПустой = ?(Не ЗначениеЗаполнено(ТекущийРодитель), "item selected", "item");
	Строки.Добавить("<a class=""" + КлассПустой + """ href=""app:set-parent-empty"">");
	Строки.Добавить("<span class=""ico"" style=""background:#F3F4F6;color:#6B7280"">" + SVGПапка() + "</span>");
	Строки.Добавить("<span class=""mid""><span class=""name"">Без группы</span>"
		+ "<span class=""sub"">Корень справочника</span></span>");
	
	Если Не ЗначениеЗаполнено(ТекущийРодитель) Тогда
		
		Строки.Добавить("<span class=""check"">✓</span>");
		
	КонецЕсли;
	
	Строки.Добавить("</a>");
	
	Для Каждого СтрокаГруппы Из ТаблицаГрупп Цикл
		
		Выбран = ЗначениеЗаполнено(ТекущийРодитель) И СтрокаГруппы.Ссылка = ТекущийРодитель;
		Класс = ?(Выбран, "item selected", "item");
		Ссылка = "app:set-parent:" + Строка(СтрокаГруппы.Ссылка.УникальныйИдентификатор());
		Строки.Добавить("<a class=""" + Класс + """ href=""" + Ссылка + """>");
		Строки.Добавить("<span class=""ico"" style=""background:#EEF2FF;color:#4F46E5"">" + SVGПапка() + "</span>");
		Строки.Добавить("<span class=""mid""><span class=""name"">" + ЭкранироватьHTML(СтрокаГруппы.Наименование)
			+ "</span><span class=""sub"">Группа</span></span>");
		
		Если Выбран Тогда
			
			Строки.Добавить("<span class=""check"">✓</span>");
			
		КонецЕсли;
		
		Строки.Добавить("</a>");
		
	КонецЦикла;
	
	Строки.Добавить("</div></body></html>");
	
	Возврат СтрСоединить(Строки, Символы.ПС);
	
КонецФункции

Функция ЗаголовокСпискаКатегорий(ЭтоРасход, ТекущийРодитель)
	
	Если ЗначениеЗаполнено(ТекущийРодитель) Тогда
		
		Возврат Строка(ТекущийРодитель);
		
	КонецЕсли;
	
	Возврат ?(ЭтоРасход, "Расходы", "Доходы");
	
КонецФункции

Функция ТаблицаКатегорийДляСписка(ЭтоРасход, СтрокаПоиска, ТекущийРодитель)
	
	ИмяСправочника = ?(ЭтоРасход, "КатегорииРасходов", "КатегорииДоходов");
	ЕстьПоиск = Не ПустаяСтрока(СокрЛП(СтрокаПоиска));
	Запрос = Новый Запрос;
	
	Если ЕстьПоиск Тогда
		
		Запрос.Текст =
		"ВЫБРАТЬ
		|	Категории.Ссылка КАК Ссылка,
		|	Категории.Наименование КАК Наименование,
		|	Категории.Описание КАК Описание,
		|	Категории.КодИконки КАК КодИконки,
		|	Категории.ЭтоГруппа КАК ЭтоГруппа
		|ИЗ
		|	Справочник." + ИмяСправочника + " КАК Категории
		|ГДЕ
		|	НЕ Категории.ПометкаУдаления
		|	И (Категории.Наименование ПОДОБНО &ШаблонПоиска
		|		ИЛИ Категории.Описание ПОДОБНО &ШаблонПоиска)
		|
		|УПОРЯДОЧИТЬ ПО
		|	ЭтоГруппа УБЫВ,
		|	Наименование";
		
	Иначе
		
		Запрос.Текст =
		"ВЫБРАТЬ
		|	Категории.Ссылка КАК Ссылка,
		|	Категории.Наименование КАК Наименование,
		|	Категории.Описание КАК Описание,
		|	Категории.КодИконки КАК КодИконки,
		|	Категории.ЭтоГруппа КАК ЭтоГруппа
		|ИЗ
		|	Справочник." + ИмяСправочника + " КАК Категории
		|ГДЕ
		|	НЕ Категории.ПометкаУдаления
		|	И Категории.Родитель = &Родитель
		|
		|УПОРЯДОЧИТЬ ПО
		|	ЭтоГруппа УБЫВ,
		|	Наименование";
		Запрос.УстановитьПараметр("Родитель",
			?(ЗначениеЗаполнено(ТекущийРодитель), ТекущийРодитель,
				?(ЭтоРасход, Справочники.КатегорииРасходов.ПустаяСсылка(), Справочники.КатегорииДоходов.ПустаяСсылка())));
		
	КонецЕсли;
	
	Запрос.УстановитьПараметр("ШаблонПоиска", "%" + СокрЛП(СтрокаПоиска) + "%");
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

Функция ТаблицаГруппКатегорий(ЭтоРасход, ИсключитьСсылку = Неопределено)
	
	ИмяСправочника = ?(ЭтоРасход, "КатегорииРасходов", "КатегорииДоходов");
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Категории.Ссылка КАК Ссылка,
	|	Категории.Наименование КАК Наименование
	|ИЗ
	|	Справочник." + ИмяСправочника + " КАК Категории
	|ГДЕ
	|	НЕ Категории.ПометкаУдаления
	|	И Категории.ЭтоГруппа
	|	И Категории.Ссылка <> &ИсключитьСсылку
	|
	|УПОРЯДОЧИТЬ ПО
	|	Наименование";
	Запрос.УстановитьПараметр("ИсключитьСсылку",
		?(ЗначениеЗаполнено(ИсключитьСсылку), ИсключитьСсылку,
			?(ЭтоРасход, Справочники.КатегорииРасходов.ПустаяСсылка(), Справочники.КатегорииДоходов.ПустаяСсылка())));
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

Функция ТаблицаКатегорий(ЭтоРасход, СтрокаПоиска, ТолькоДляВыбора)
	
	ИмяСправочника = ?(ЭтоРасход, "КатегорииРасходов", "КатегорииДоходов");
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Категории.Ссылка КАК Ссылка,
	|	Категории.Наименование КАК Наименование,
	|	Категории.Описание КАК Описание,
	|	Категории.КодИконки КАК КодИконки
	|ИЗ
	|	Справочник." + ИмяСправочника + " КАК Категории
	|ГДЕ
	|	НЕ Категории.ПометкаУдаления
	|	И НЕ Категории.ЭтоГруппа
	|	И (&СтрокаПоиска = """"
	|		ИЛИ Категории.Наименование ПОДОБНО &ШаблонПоиска
	|		ИЛИ Категории.Описание ПОДОБНО &ШаблонПоиска)
	|	И (НЕ &ТолькоДляВыбора
	|		ИЛИ Категории.ПоказыватьВВыборе
	|		ИЛИ (Категории.КодИконки = """" И Категории.Описание = """"))
	|
	|УПОРЯДОЧИТЬ ПО
	|	Наименование";
	Запрос.УстановитьПараметр("СтрокаПоиска", СокрЛП(СтрокаПоиска));
	Запрос.УстановитьПараметр("ШаблонПоиска", "%" + СокрЛП(СтрокаПоиска) + "%");
	Запрос.УстановитьПараметр("ТолькоДляВыбора", ТолькоДляВыбора);
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

Функция СтатистикаОперацийКатегорий(ЭтоРасход, ТолькоТекущийМесяц)
	
	Запрос = Новый Запрос;
	
	Если ЭтоРасход Тогда
		
		Запрос.Текст =
		"ВЫБРАТЬ
		|	Обороты.КатегорияРасходов КАК Категория,
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ Обороты.Регистратор) КАК Количество,
		|	СУММА(Обороты.СуммаОборот) КАК Сумма
		|ИЗ
		|	РегистрНакопления.Расходы.Обороты(&НачалоПериода, &КонецПериода, Регистратор, ) КАК Обороты
		|
		|СГРУППИРОВАТЬ ПО
		|	Обороты.КатегорияРасходов";
		
	Иначе
		
		Запрос.Текст =
		"ВЫБРАТЬ
		|	Обороты.КатегорииДоходов КАК Категория,
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ Обороты.Регистратор) КАК Количество,
		|	СУММА(Обороты.СуммаОборот) КАК Сумма
		|ИЗ
		|	РегистрНакопления.Доходы.Обороты(&НачалоПериода, &КонецПериода, Регистратор, ) КАК Обороты
		|
		|СГРУППИРОВАТЬ ПО
		|	Обороты.КатегорииДоходов";
		
	КонецЕсли;
	
	Если ТолькоТекущийМесяц Тогда
		
		Запрос.УстановитьПараметр("НачалоПериода", НачалоМесяца(ТекущаяДата()));
		Запрос.УстановитьПараметр("КонецПериода", КонецМесяца(ТекущаяДата()));
		
	Иначе
		
		Запрос.УстановитьПараметр("НачалоПериода", Дата(1, 1, 1));
		Запрос.УстановитьПараметр("КонецПериода", Дата(3999, 12, 31));
		
	КонецЕсли;
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

Функция СтатистикаКатегории(ЭтоРасход, Категория)
	
	Результат = Новый Структура("Количество, Сумма, ПериодПодпись", 0, 0, Формат(ТекущаяДата(), "ДФ='MMMM yyyy'"));
	
	Если Не ЗначениеЗаполнено(Категория) Тогда
		
		Возврат Результат;
		
	КонецЕсли;
	
	Запрос = Новый Запрос;
	
	Если ЭтоРасход Тогда
		
		Запрос.Текст =
		"ВЫБРАТЬ
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ Обороты.Регистратор) КАК Количество,
		|	СУММА(Обороты.СуммаОборот) КАК Сумма
		|ИЗ
		|	РегистрНакопления.Расходы.Обороты(&НачалоПериода, &КонецПериода, Регистратор, КатегорияРасходов = &Категория) КАК Обороты";
		
	Иначе
		
		Запрос.Текст =
		"ВЫБРАТЬ
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ Обороты.Регистратор) КАК Количество,
		|	СУММА(Обороты.СуммаОборот) КАК Сумма
		|ИЗ
		|	РегистрНакопления.Доходы.Обороты(&НачалоПериода, &КонецПериода, Регистратор, КатегорииДоходов = &Категория) КАК Обороты";
		
	КонецЕсли;
	
	Запрос.УстановитьПараметр("НачалоПериода", НачалоМесяца(ТекущаяДата()));
	Запрос.УстановитьПараметр("КонецПериода", КонецМесяца(ТекущаяДата()));
	Запрос.УстановитьПараметр("Категория", Категория);
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		
		Результат.Количество = ?(Выборка.Количество = Null, 0, Выборка.Количество);
		Результат.Сумма = ?(Выборка.Сумма = Null, 0, Выборка.Сумма);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Данные для HTML карточки элемента.
//
Функция ДанныеКатегорииДляHTML(ЭтоРасход, СсылкаКатегории, Наименование, Описание, КодИконки, ПоказыватьВВыборе,
	Предопределенный, Родитель = Неопределено) Экспорт
	
	Статистика = СтатистикаКатегории(ЭтоРасход, СсылкаКатегории);
	РодительСсылка = Родитель;
	
	Если РодительСсылка = Неопределено Тогда
		
		РодительСсылка = ?(ЭтоРасход, Справочники.КатегорииРасходов.ПустаяСсылка(),
			Справочники.КатегорииДоходов.ПустаяСсылка());
		
	КонецЕсли;
	
	Возврат Новый Структура(
		"Ссылка, Наименование, Описание, КодИконки, ПоказыватьВВыборе, Предопределенный, Родитель, РодительНаименование, КоличествоОпераций, СуммаОпераций, ПериодПодпись",
		СсылкаКатегории, Наименование, Описание, КодИконки, ПоказыватьВВыборе, Предопределенный,
		РодительСсылка, Строка(РодительСсылка),
		Статистика.Количество, Статистика.Сумма, Статистика.ПериодПодпись);
	
КонецФункции

Функция АкцентКатегорий(ЭтоРасход)
	
	Если ЭтоРасход Тогда
		
		Возврат Новый Структура("Цвет, ФонИконки, Кнопка", "#DC2626", "#FEE2E2", "#DC2626");
		
	КонецЕсли;
	
	Возврат Новый Структура("Цвет, ФонИконки, Кнопка", "#16A34A", "#DCFCE7", "#16A34A");
	
КонецФункции

Функция КодИконкиКатегории(КодИконки, Наименование, ЭтоРасход)
	
	Если ЗначениеЗаполнено(КодИконки) Тогда
		
		Возврат КодИконки;
		
	КонецЕсли;
	
	Ключ = НРег(СокрЛП(Наименование));
	Карта = КартаИконокПоНаименованию(ЭтоРасход);
	Значение = Карта.Получить(Ключ);
	
	Если Значение <> Неопределено Тогда
		
		Возврат Значение;
		
	КонецЕсли;
	
	Возврат ?(ЭтоРасход, "other", "wallet");
	
КонецФункции

Функция КартаИконокПоНаименованию(ЭтоРасход)
	
	Карта = Новый Соответствие;
	
	Если ЭтоРасход Тогда
		
		Карта.Вставить("продукты", "cart");
		Карта.Вставить("азс", "fuel");
		Карта.Вставить("топливо", "fuel");
		Карта.Вставить("аренда", "home");
		Карта.Вставить("коммунальные услуги", "bolt");
		Карта.Вставить("электр./вода/газ", "bolt");
		Карта.Вставить("транспорт", "bus");
		Карта.Вставить("общественный транспорт", "bus");
		Карта.Вставить("такси", "car");
		Карта.Вставить("развлечения", "ticket");
		Карта.Вставить("кино", "ticket");
		Карта.Вставить("кафе", "cup");
		Карта.Вставить("обед", "cup");
		Карта.Вставить("одежда", "shirt");
		Карта.Вставить("одежда верхняя", "shirt");
		Карта.Вставить("здоровье", "medkit");
		Карта.Вставить("лекарства", "cross");
		Карта.Вставить("мобильная связь", "phone");
		Карта.Вставить("интернет дом./моб.", "wifi");
		Карта.Вставить("книги", "book");
		Карта.Вставить("подарки", "gift");
		Карта.Вставить("прочие расходы", "other");
		
	Иначе
		
		Карта.Вставить("зарплата", "wallet");
		Карта.Вставить("бонус", "gift");
		Карта.Вставить("проценты / кешбэк", "percent");
		Карта.Вставить("возврат средств", "refund");
		Карта.Вставить("прочие доходы", "other");
		Карта.Вставить("прочий доход", "other");
		
	КонецЕсли;
	
	Возврат Карта;
	
КонецФункции

Функция НаборКодовИконок(ЭтоРасход)
	
	Если ЭтоРасход Тогда
		
		Возврат СтрРазделить(
			"cart,fuel,home,bolt,bus,car,ticket,cup,shirt,medkit,cross,phone,wifi,book,gift,other", ",");
		
	КонецЕсли;
	
	Возврат СтрРазделить("wallet,gift,percent,refund,briefcase,chart,coin,other", ",");
	
КонецФункции

Функция ПредставлениеКоличестваОпераций(Количество)
	
	Остаток10 = Количество % 10;
	Остаток100 = Количество % 100;
	
	Если Остаток10 = 1 И Остаток100 <> 11 Тогда
		
		Возврат Формат(Количество, "ЧН=0; ЧГ=") + " операция";
		
	ИначеЕсли Остаток10 >= 2 И Остаток10 <= 4 И (Остаток100 < 12 Или Остаток100 > 14) Тогда
		
		Возврат Формат(Количество, "ЧН=0; ЧГ=") + " операции";
		
	КонецЕсли;
	
	Возврат Формат(Количество, "ЧН=0; ЧГ=") + " операций";
	
КонецФункции

Функция ПредставлениеИспользования(Количество, Сумма, ПериодПодпись)
	
	СуммаТекст = ОбщийМодульСервер_КурсыВалют.ПредставлениеСуммыВВалютеУчета(Сумма, Ложь);
	СуммаТекст = СтрЗаменить(СуммаТекст, Символы.НПП, " ");
	ПериодТекст = СокрЛП(Строка(ПериодПодпись));
	
	Если ПустаяСтрока(ПериодТекст) Тогда
		
		ПериодТекст = Формат(ТекущаяДата(), "ДФ='MMMM yyyy'");
		
	КонецЕсли;
	
	Текст = ПредставлениеКоличестваОпераций(Количество) + " - " + СуммаТекст + " за " + НРег(ПериодТекст);
	
	Возврат ЭкранироватьHTML(Текст);
	
КонецФункции

Процедура ДобавитьШапкуHTML(Строки, Стили)
	
	Строки.Добавить("<!DOCTYPE html><html lang=""ru""><head><meta charset=""utf-8"">");
	Строки.Добавить("<meta name=""viewport"" content=""width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no"">");
	Строки.Добавить("<style>" + Стили + "</style></head><body>");
	
КонецПроцедуры

