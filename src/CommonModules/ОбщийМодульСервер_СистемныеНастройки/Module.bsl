////////////////////////////////////////////////////////////////////////////////
// Общий модуль сервер: системные настройки.
// Первый запуск, валюта учёта, инициализация предопределённых счетов.
////////////////////////////////////////////////////////////////////////////////

#Область ПрограммныйИнтерфейс

// Возвращает признак завершения начальной настройки приложения.
// Истина — валюта учёта уже сохранена, повторный показ формы настроек не нужен.
// Соответствует константе ПервыйЗапуск (синоним: «Начальная настройка выполнена»).
//
Функция НачальнаяНастройкаВыполнена() Экспорт
	
	Возврат Константы.ПервыйЗапуск.Получить();
	
КонецФункции

// Совместимость со старым именем API (до переименования на НачальнаяНастройкаВыполнена).
//
Функция ПолучитьПараметрЗапуска() Экспорт
	
	Возврат НачальнаяНастройкаВыполнена();
	
КонецФункции

// Устанавливает признак завершения начальной настройки.
//
Процедура УстановитьНачальнаяНастройкаВыполнена(Выполнена = Истина) Экспорт
	
	Константы.ПервыйЗапуск.Установить(Выполнена);
	
КонецПроцедуры

// Совместимость со старым именем API (до переименования на УстановитьНачальнаяНастройкаВыполнена).
//
Процедура ПрошелПервыйЗапуск() Экспорт
	
	УстановитьНачальнаяНастройкаВыполнена(Истина);
	
КонецПроцедуры

// Возвращает валюту учёта из константы.
//
Функция ПолучитьВалютуРегламентированногоУчета() Экспорт
	
	Возврат Константы.ВалютаУчета.Получить();
	
КонецФункции

// Заполняет вид и наименование предопределённых счетов.
// Идемпотентно: пишет только при отличии значений.
//
Процедура ЗаполнитьПредопределенныеКошелькиНаСервере() Экспорт
	
	СоответствиеВидов = СоответствиеПредопределенныхСчетовИВидов();
	СоответствиеНаименований = СоответствиеПредопределенныхСчетовИНаименований();
	
	Для Каждого ЭлементСоответствия Из СоответствиеВидов Цикл
		
		СпрОбъект = Справочники.Счета[ЭлементСоответствия.Ключ].ПолучитьОбъект();
		ТребуетсяЗапись = Ложь;
		
		Если СпрОбъект.ВидСчета <> ЭлементСоответствия.Значение Тогда
			
			СпрОбъект.ВидСчета = ЭлементСоответствия.Значение;
			ТребуетсяЗапись = Истина;
			
		КонецЕсли;
		
		НовоеНаименование = СоответствиеНаименований.Получить(ЭлементСоответствия.Ключ);
		
		Если ЗначениеЗаполнено(НовоеНаименование) И СпрОбъект.Наименование <> НовоеНаименование Тогда
			
			СпрОбъект.Наименование = НовоеНаименование;
			ТребуетсяЗапись = Истина;
			
		КонецЕсли;
		
		Если ТребуетсяЗапись Тогда
			
			СпрОбъект.Записать();
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция СоответствиеПредопределенныхСчетовИВидов()
	
	Результат = Новый Соответствие;
	Результат.Вставить("БанковскийСчет", Перечисления.ВидСчета.БанковскийСчет);
	Результат.Вставить("Карта", Перечисления.ВидСчета.БанковскаяКарта);
	Результат.Вставить("Кошелек", Перечисления.ВидСчета.Кошелек);
	
	Возврат Результат;
	
КонецФункции

Функция СоответствиеПредопределенныхСчетовИНаименований()
	
	Результат = Новый Соответствие;
	Результат.Вставить("БанковскийСчет", "Банковский счёт");
	Результат.Вставить("Карта", "Банковская карта");
	Результат.Вставить("Кошелек", "Наличные");
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти
