Функция HTMLПереключателиПериода(ВидПериода)
	
	Части = Новый Массив;
	Части.Добавить("<div class=""periods"">");
	Части.Добавить(HTMLКнопкаПериода("Сегодня", ВидПериода));
	Части.Добавить(HTMLКнопкаПериода("Неделя", ВидПериода));
	Части.Добавить(HTMLКнопкаПериода("Месяц", ВидПериода));
	Части.Добавить("</div>");
	
	Возврат СтрСоединить(Части, "");
	
КонецФункции

Функция HTMLКнопкаПериода(ИмяПериода, ТекущийВид)
	
	Класс = ?(ИмяПериода = ТекущийВид, "active", "");
	
	Возврат "<a class=""" + Класс + """ href=""app:period:" + ИмяПериода + """>" + ИмяПериода + "</a>";
	
КонецФункции

Функция ПредставлениеПериодаОтчета(НачалоПериода, КонецПериода, ВалютаУчета)
	
	Если НачалоДня(НачалоПериода) = НачалоМесяца(НачалоПериода)
		И КонецДня(КонецПериода) = КонецМесяца(НачалоПериода) Тогда
		
		ПериодТекст = Формат(НачалоПериода, "ДФ='ММММ гггг'");
		
	ИначеЕсли НачалоДня(НачалоПериода) = НачалоДня(КонецПериода) Тогда
		
		ПериодТекст = Формат(НачалоПериода, "ДЛФ=D");
		
	Иначе
		
		ПериодТекст = Формат(НачалоПериода, "ДЛФ=D") + " – " + Формат(КонецПериода, "ДЛФ=D");
		
	КонецЕсли;
	
	КодВалюты = "";
	
	Если ЗначениеЗаполнено(ВалютаУчета) Тогда
		
		КодВалюты = Строка(ВалютаУчета.Код);
		
		Если Не ЗначениеЗаполнено(КодВалюты) Тогда
			
			КодВалюты = Строка(ВалютаУчета);
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(КодВалюты) Тогда
		
		Возврат ПериодТекст + " · " + КодВалюты;
		
	КонецЕсли;
	
	Возврат ПериодТекст;
	
КонецФункции

Функция ЭкранироватьHTML(Знач Текст)
	
	Результат = Строка(Текст);
	Результат = СтрЗаменить(Результат, "&", "&amp;");
	Результат = СтрЗаменить(Результат, "<", "&lt;");
	Результат = СтрЗаменить(Результат, ">", "&gt;");
	Результат = СтрЗаменить(Результат, """", "&quot;");
	
	Возврат Результат;
	
КонецФункции

