#Область ПрограммныйИнтерфейс

// Возвращает таблицу оборотов по категориям за период.
// Колонки: Категория, Сумма, Процент.
// Суммы — в валюте учёта (ресурс Сумма регистров).
//
Функция ОборотыПоКатегориям(ВидОперацииРасход, НачалоПериода, КонецПериода) Экспорт
	
	Запрос = Новый Запрос;
	
	Если ВидОперацииРасход Тогда
		
		Запрос.Текст =
		"ВЫБРАТЬ
		|	Обороты.КатегорияРасходов КАК Категория,
		|	СУММА(Обороты.СуммаОборот) КАК Сумма
		|ИЗ
		|	РегистрНакопления.Расходы.Обороты(&НачалоПериода, &КонецПериода) КАК Обороты
		|ГДЕ
		|	Обороты.СуммаОборот <> 0
		|
		|СГРУППИРОВАТЬ ПО
		|	Обороты.КатегорияРасходов
		|
		|УПОРЯДОЧИТЬ ПО
		|	Сумма УБЫВ";
		
	Иначе
		
		Запрос.Текст =
		"ВЫБРАТЬ
		|	Обороты.КатегорииДоходов КАК Категория,
		|	СУММА(Обороты.СуммаОборот) КАК Сумма
		|ИЗ
		|	РегистрНакопления.Доходы.Обороты(&НачалоПериода, &КонецПериода) КАК Обороты
		|ГДЕ
		|	Обороты.СуммаОборот <> 0
		|
		|СГРУППИРОВАТЬ ПО
		|	Обороты.КатегорииДоходов
		|
		|УПОРЯДОЧИТЬ ПО
		|	Сумма УБЫВ";
		
	КонецЕсли;
	
	Запрос.УстановитьПараметр("НачалоПериода", НачалоПериода);
	Запрос.УстановитьПараметр("КонецПериода", КонецПериода);
	
	Таблица = Запрос.Выполнить().Выгрузить();
	Таблица.Колонки.Добавить("Процент", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(10, 1)));
	
	Итого = 0;
	
	Для Каждого СтрокаТаблицы Из Таблица Цикл
		
		Итого = Итого + СтрокаТаблицы.Сумма;
		
	КонецЦикла;
	
	Если Итого <> 0 Тогда
		
		Для Каждого СтрокаТаблицы Из Таблица Цикл
			
			СтрокаТаблицы.Процент = Окр(100 * СтрокаТаблицы.Сумма / Итого, 1);
			
		КонецЦикла;
		
	КонецЕсли;
	
	СвернутьМелкиеКатегории(Таблица, Итого);
	
	Возврат Таблица;
	
КонецФункции

// Возвращает таблицу оборотов выбранной категории по дням.
// Колонки: День, Сумма, Процент.
//
Функция ОборотыКатегорииПоДням(ВидОперацииРасход, Категория, НачалоПериода, КонецПериода) Экспорт
	
	Запрос = Новый Запрос;
	
	Если ВидОперацииРасход Тогда
		
		Запрос.Текст =
		"ВЫБРАТЬ
		|	НАЧАЛОПЕРИОДА(Обороты.Период, ДЕНЬ) КАК День,
		|	СУММА(Обороты.СуммаОборот) КАК Сумма
		|ИЗ
		|	РегистрНакопления.Расходы.Обороты(&НачалоПериода, &КонецПериода, День, КатегорияРасходов = &Категория) КАК Обороты
		|ГДЕ
		|	Обороты.СуммаОборот <> 0
		|
		|СГРУППИРОВАТЬ ПО
		|	НАЧАЛОПЕРИОДА(Обороты.Период, ДЕНЬ)
		|
		|УПОРЯДОЧИТЬ ПО
		|	День УБЫВ";
		
	Иначе
		
		Запрос.Текст =
		"ВЫБРАТЬ
		|	НАЧАЛОПЕРИОДА(Обороты.Период, ДЕНЬ) КАК День,
		|	СУММА(Обороты.СуммаОборот) КАК Сумма
		|ИЗ
		|	РегистрНакопления.Доходы.Обороты(&НачалоПериода, &КонецПериода, День, КатегорииДоходов = &Категория) КАК Обороты
		|ГДЕ
		|	Обороты.СуммаОборот <> 0
		|
		|СГРУППИРОВАТЬ ПО
		|	НАЧАЛОПЕРИОДА(Обороты.Период, ДЕНЬ)
		|
		|УПОРЯДОЧИТЬ ПО
		|	День УБЫВ";
		
	КонецЕсли;
	
	Запрос.УстановитьПараметр("НачалоПериода", НачалоПериода);
	Запрос.УстановитьПараметр("КонецПериода", КонецПериода);
	Запрос.УстановитьПараметр("Категория", Категория);
	
	Таблица = Запрос.Выполнить().Выгрузить();
	Таблица.Колонки.Добавить("Процент", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(10, 1)));
	
	Итого = 0;
	
	Для Каждого СтрокаТаблицы Из Таблица Цикл
		
		Итого = Итого + СтрокаТаблицы.Сумма;
		
	КонецЦикла;
	
	Если Итого <> 0 Тогда
		
		Для Каждого СтрокаТаблицы Из Таблица Цикл
			
			СтрокаТаблицы.Процент = Окр(100 * СтрокаТаблицы.Сумма / Итого, 1);
			
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат Таблица;
	
КонецФункции

// Формирует HTML сводного отчёта: доходы и расходы за период.
//
Функция HTMLСводногоОтчетаПоОперациям(НачалоПериода, КонецПериода, ВидПериода) Экспорт
	
	Границы = ГраницыПериодаДляОтчета(НачалоПериода, КонецПериода);
	НачалоПериода = Границы.Начало;
	КонецПериода = Границы.Конец;
	
	ТаблицаДоходов = ОборотыПоКатегориям(Ложь, НачалоПериода, КонецПериода);
	ТаблицаРасходов = ОборотыПоКатегориям(Истина, НачалоПериода, КонецПериода);
	
	ИтогоДоходов = СуммаТаблицы(ТаблицаДоходов);
	ИтогоРасходов = СуммаТаблицы(ТаблицаРасходов);
	Разница = ИтогоДоходов - ИтогоРасходов;
	
	ВалютаУчета = Константы.ВалютаУчета.Получить();
	
	Строки = Новый Массив;
	ДобавитьОбщиеСтилиОтчета(Строки, "#1c2430");
	Строки.Добавить("<body>");
	Строки.Добавить("<a class=""back"" href=""app:back"">← Назад</a>");
	Строки.Добавить("<div class=""header"">");
	Строки.Добавить("<div class=""title"">Операции</div>");
	Строки.Добавить("<div class=""sub"">" + ЭкранироватьHTML(ПредставлениеПериодаОтчета(НачалоПериода, КонецПериода, ВалютаУчета)) + "</div>");
	Строки.Добавить("</div>");
	Строки.Добавить(HTMLПереключателиПериода(ВидПериода));
	
	Строки.Добавить("<div class=""summary-card"">");
	Строки.Добавить("<div class=""sum-line pos""><span>Доходы</span><span>"
		+ ЭкранироватьHTML(ОбщийМодульСервер_КурсыВалют.ПредставлениеСуммыВВалютеУчета(ИтогоДоходов, Истина)) + "</span></div>");
	Строки.Добавить("<div class=""sum-line neg""><span>Расходы</span><span>"
		+ ЭкранироватьHTML(ОбщийМодульСервер_КурсыВалют.ПредставлениеСуммыВВалютеУчета(-ИтогоРасходов, Истина)) + "</span></div>");
	Строки.Добавить("<div class=""sum-line total-line""><span>Итого</span><span>"
		+ ЭкранироватьHTML(ОбщийМодульСервер_КурсыВалют.ПредставлениеСуммыВВалютеУчета(Разница, Истина)) + "</span></div>");
	Строки.Добавить("</div>");
	
	Если ТаблицаДоходов.Количество() = 0 И ТаблицаРасходов.Количество() = 0 Тогда
		
		Строки.Добавить("<div class=""empty"">Операций за выбранный период нет</div>");
		
	Иначе
		
		ДобавитьБлокКатегорийВHTML(Строки, "Доходы", ТаблицаДоходов, Ложь, "#2e7d32");
		ДобавитьБлокКатегорийВHTML(Строки, "Расходы", ТаблицаРасходов, Истина, "#e53935");
		
	КонецЕсли;
	
	Строки.Добавить("</body></html>");
	
	Возврат СтрСоединить(Строки, Символы.ПС);
	
КонецФункции

// Формирует HTML отчёта по категориям (доходы или расходы).
// Макет: чипы периода, строка дат, итог, кольцевая диаграмма, список категорий.
//
Функция HTMLОтчетаПоКатегориям(ВидОперацииРасход, НачалоПериода, КонецПериода, ВидПериода) Экспорт
	
	Границы = ГраницыПериодаДляОтчета(НачалоПериода, КонецПериода);
	НачалоПериода = Границы.Начало;
	КонецПериода = Границы.Конец;
	
	Таблица = ОборотыПоКатегориям(ВидОперацииРасход, НачалоПериода, КонецПериода);
	Итого = 0;
	
	Для Каждого СтрокаТаблицы Из Таблица Цикл
		
		Итого = Итого + СтрокаТаблицы.Сумма;
		
	КонецЦикла;
	
	Акцент = "#2e7d32";
	ПодписьИтого = ПодписьИтогаОтчета(ВидОперацииРасход, НачалоПериода, КонецПериода, ВидПериода);
	ПустойТекст = ?(ВидОперацииРасход, "Расходов за выбранный период нет", "Доходов за выбранный период нет");
	
	Строки = Новый Массив;
	ДобавитьСтилиОтчетаПоКатегориям(Строки, Акцент);
	Строки.Добавить("<body>");
	Строки.Добавить(HTMLПереключателиПериода(ВидПериода));
	Строки.Добавить(HTMLСтрокаДиапазонаПериода(НачалоПериода, КонецПериода, ВидПериода));
	Строки.Добавить("<div class=""total"">" + ЭкранироватьHTML(ОбщийМодульСервер_КурсыВалют.ПредставлениеСуммыВВалютеУчета(Итого, Ложь)) + "</div>");
	Строки.Добавить("<div class=""total-sub"">" + ЭкранироватьHTML(ПодписьИтого) + "</div>");
	
	Если Таблица.Количество() = 0 Тогда
		
		Строки.Добавить("<div class=""empty"">" + ЭкранироватьHTML(ПустойТекст) + "</div>");
		
	Иначе
		
		Строки.Добавить(HTMLКольцеваяДиаграмма(Таблица, Итого));
		Строки.Добавить("<div class=""list"">");
		ИндексЦвета = 0;
		
		Для Каждого СтрокаТаблицы Из Таблица Цикл
			
			ИмяКатегории = ?(ЗначениеЗаполнено(СтрокаТаблицы.Категория), Строка(СтрокаТаблицы.Категория), "Прочее");
			СуммаТекст = ОбщийМодульСервер_КурсыВалют.ПредставлениеСуммыВВалютеУчета(СтрокаТаблицы.Сумма, Ложь);
			ПроцентТекст = Формат(СтрокаТаблицы.Процент, "ЧДЦ=0; ЧН=0; ЧГ=") + "%";
			Цвет = ЦветКатегорииОтчета(ИндексЦвета);
			ИндексЦвета = ИндексЦвета + 1;
			
			Содержимое = "<span class=""dot"" style=""background:" + Цвет + """></span>"
				+ "<span class=""name"">" + ЭкранироватьHTML(ИмяКатегории) + "</span>"
				+ "<span class=""right""><span class=""sum"">" + ЭкранироватьHTML(СуммаТекст)
				+ "</span><span class=""pct"">" + ЭкранироватьHTML(ПроцентТекст) + "</span></span>";
			
			Если ЗначениеЗаполнено(СтрокаТаблицы.Категория) Тогда
				
				Ссылка = "app:category:" + Строка(СтрокаТаблицы.Категория.УникальныйИдентификатор());
				Строки.Добавить("<a class=""row"" href=""" + Ссылка + """>" + Содержимое + "</a>");
				
			Иначе
				
				Строки.Добавить("<div class=""row static"">" + Содержимое + "</div>");
				
			КонецЕсли;
			
		КонецЦикла;
		
		Строки.Добавить("</div>");
		
	КонецЕсли;
	
	Строки.Добавить("</body></html>");
	
	Возврат СтрСоединить(Строки, Символы.ПС);
	
КонецФункции

// Формирует HTML отчёта по взаиморасчётам (доходы / расходы / остаток).
// Макет: период, карточка остатка со спарклайном, плитки, структура, сводка, нижняя навигация.
//
Функция HTMLОтчетаПоВзаиморасчетам(НачалоПериода, КонецПериода, ВидПериода) Экспорт
	
	Границы = ГраницыПериодаДляОтчета(НачалоПериода, КонецПериода);
	НачалоПериода = Границы.Начало;
	КонецПериода = Границы.Конец;
	
	ТаблицаДоходов = ОборотыПоКатегориям(Ложь, НачалоПериода, КонецПериода);
	ТаблицаРасходов = ОборотыПоКатегориям(Истина, НачалоПериода, КонецПериода);
	ИтогоДоходов = СуммаТаблицы(ТаблицаДоходов);
	ИтогоРасходов = СуммаТаблицы(ТаблицаРасходов);
	Остаток = ИтогоДоходов - ИтогоРасходов;
	
	ЦветОстатка = ?(Остаток >= 0, "#2e7d32", "#e53935");
	ФонКарточки = ?(Остаток >= 0, "#eaf7ec", "#fdecee");
	ПроцентРасходовОтДоходов = 0;
	
	Если ИтогоДоходов > 0 Тогда
		
		ПроцентРасходовОтДоходов = Окр(100 * ИтогоРасходов / ИтогоДоходов, 1);
		
	ИначеЕсли ИтогоРасходов > 0 Тогда
		
		ПроцентРасходовОтДоходов = 100;
		
	КонецЕсли;
	
	ШиринаБараРасходов = Формат(Мин(ПроцентРасходовОтДоходов, 100), "ЧДЦ=1; ЧРД=.; ЧН=0; ЧГ=");
	ПодписьОстатка = ПодписьИтоговогоОстатка(Остаток);
	
	Строки = Новый Массив;
	ДобавитьСтилиОтчетаПоВзаиморасчетам(Строки, ЦветОстатка);
	Строки.Добавить("<body>");
	Строки.Добавить(HTMLПереключателиПериода(ВидПериода));
	Строки.Добавить(HTMLСтрокаДиапазонаПериодаМакет(НачалоПериода, КонецПериода, ВидПериода));
	
	Строки.Добавить("<div class=""hero"" style=""background:" + ФонКарточки + """>");
	Строки.Добавить("<div class=""hero-main"">");
	Строки.Добавить("<div class=""hero-label"">Итоговый остаток</div>");
	Строки.Добавить("<div class=""hero-value"" style=""color:" + ЦветОстатка + """>"
		+ ЭкранироватьHTML(ОбщийМодульСервер_КурсыВалют.ПредставлениеСуммыВВалютеУчета(Остаток, Истина)) + "</div>");
	Строки.Добавить("<div class=""hero-sub"">" + ЭкранироватьHTML(ПодписьОстатка) + "</div>");
	Строки.Добавить("</div>");
	Строки.Добавить(HTMLСпарклайнСальдо(НачалоПериода, КонецПериода, ЦветОстатка));
	Строки.Добавить("</div>");
	
	Строки.Добавить("<div class=""tiles"">");
	Строки.Добавить("<div class=""tile"">");
	Строки.Добавить("<div class=""tile-ico income"">↓</div>");
	Строки.Добавить("<div class=""tile-label"">Доходы</div>");
	Строки.Добавить("<div class=""tile-value income"">"
		+ ЭкранироватьHTML(ОбщийМодульСервер_КурсыВалют.ПредставлениеСуммыВВалютеУчета(ИтогоДоходов, Ложь)) + "</div>");
	Строки.Добавить("<div class=""tile-pct"">100%</div>");
	Строки.Добавить("<div class=""tile-bar""><div class=""tile-fill income"" style=""width:100%""></div></div>");
	Строки.Добавить("</div>");
	Строки.Добавить("<div class=""tile"">");
	Строки.Добавить("<div class=""tile-ico expense"">↑</div>");
	Строки.Добавить("<div class=""tile-label"">Расходы</div>");
	Строки.Добавить("<div class=""tile-value expense"">"
		+ ЭкранироватьHTML(ОбщийМодульСервер_КурсыВалют.ПредставлениеСуммыВВалютеУчета(ИтогоРасходов, Ложь)) + "</div>");
	Строки.Добавить("<div class=""tile-pct"">" + ЭкранироватьHTML(Формат(ПроцентРасходовОтДоходов, "ЧДЦ=1; ЧН=0; ЧРД=,; ЧГ=")
		+ "% от доходов") + "</div>");
	Строки.Добавить("<div class=""tile-bar""><div class=""tile-fill expense"" style=""width:" + ШиринаБараРасходов + "%""></div></div>");
	Строки.Добавить("</div>");
	Строки.Добавить("</div>");
	
	ДобавитьБлокСтруктурыВзаиморасчетов(Строки, "Структура расходов", ТаблицаРасходов, ИтогоРасходов, Истина, 5);
	ДобавитьБлокСтруктурыВзаиморасчетов(Строки, "Структура доходов", ТаблицаДоходов, ИтогоДоходов, Ложь, 5);
	
	Строки.Добавить("<div class=""section-title"">Сводка</div>");
	Строки.Добавить("<div class=""summary"">");
	Строки.Добавить("<div class=""sum-row""><span>Доходы</span><span class=""income"">"
		+ ЭкранироватьHTML(ОбщийМодульСервер_КурсыВалют.ПредставлениеСуммыВВалютеУчета(ИтогоДоходов, Ложь)) + "</span></div>");
	Строки.Добавить("<div class=""sum-row""><span>Расходы</span><span class=""expense"">"
		+ ЭкранироватьHTML(ОбщийМодульСервер_КурсыВалют.ПредставлениеСуммыВВалютеУчета(ИтогоРасходов, Ложь)) + "</span></div>");
	Строки.Добавить("<div class=""sum-row total""><span>Итоговый остаток</span><span style=""color:" + ЦветОстатка + """>"
		+ ЭкранироватьHTML(ОбщийМодульСервер_КурсыВалют.ПредставлениеСуммыВВалютеУчета(Остаток, Истина)) + "</span></div>");
	Строки.Добавить("</div>");
	
	Строки.Добавить(HTMLНижняяНавигацияОтчета("reports"));
	Строки.Добавить("</body></html>");
	
	Возврат СтрСоединить(Строки, Символы.ПС);
	
КонецФункции

// Формирует HTML расшифровки категории по дням.
//
Функция HTMLРасшифровкиПоДням(ВидОперацииРасход, Категория, НачалоПериода, КонецПериода, ВидПериода) Экспорт
	
	Границы = ГраницыПериодаДляОтчета(НачалоПериода, КонецПериода);
	НачалоПериода = Границы.Начало;
	КонецПериода = Границы.Конец;
	
	Таблица = ОборотыКатегорииПоДням(ВидОперацииРасход, Категория, НачалоПериода, КонецПериода);
	Итого = 0;
	
	Для Каждого СтрокаТаблицы Из Таблица Цикл
		
		Итого = Итого + СтрокаТаблицы.Сумма;
		
	КонецЦикла;
	
	ВалютаУчета = Константы.ВалютаУчета.Получить();
	Акцент = ?(ВидОперацииРасход, "#e53935", "#2e7d32");
	ИмяКатегории = ?(ЗначениеЗаполнено(Категория), Строка(Категория), "Прочее");
	ПодписьИтого = ?(ВидОперацииРасход, "потрачено в категории", "получено в категории");
	
	Строки = Новый Массив;
	ДобавитьОбщиеСтилиОтчета(Строки, Акцент);
	Строки.Добавить("<body>");
	Строки.Добавить("<a class=""back"" href=""app:back"">← Назад</a>");
	Строки.Добавить("<div class=""header"">");
	Строки.Добавить("<div class=""title"">" + ЭкранироватьHTML(ИмяКатегории) + "</div>");
	Строки.Добавить("<div class=""sub"">" + ЭкранироватьHTML(ПредставлениеПериодаОтчета(НачалоПериода, КонецПериода, ВалютаУчета)) + "</div>");
	Строки.Добавить("</div>");
	Строки.Добавить("<div class=""total"">" + ЭкранироватьHTML(ОбщийМодульСервер_КурсыВалют.ПредставлениеСуммыВВалютеУчета(Итого, Ложь)) + "</div>");
	Строки.Добавить("<div class=""total-sub"">" + ЭкранироватьHTML(ПодписьИтого) + "</div>");
	Строки.Добавить(HTMLПереключателиПериода(ВидПериода));
	
	Если Таблица.Количество() = 0 Тогда
		
		Строки.Добавить("<div class=""empty"">По категории нет данных за выбранный период</div>");
		
	Иначе
		
		Строки.Добавить("<div class=""section"">По дням</div>");
		
		Для Каждого СтрокаТаблицы Из Таблица Цикл
			
			Ширина = Формат(Макс(СтрокаТаблицы.Процент, 0), "ЧДЦ=1; ЧРД=.; ЧН=0; ЧГ=");
			СуммаТекст = ОбщийМодульСервер_КурсыВалют.ПредставлениеСуммыВВалютеУчета(СтрокаТаблицы.Сумма, Ложь);
			ДатаТекст = Формат(СтрокаТаблицы.День, "ДЛФ=D");
			
			Строки.Добавить("<div class=""item static"">");
			Строки.Добавить("<div class=""item-top""><span class=""name"">" + ЭкранироватьHTML(ДатаТекст)
				+ "</span><span class=""meta"">" + ЭкранироватьHTML(СуммаТекст) + "</span></div>");
			Строки.Добавить("<div class=""bar""><div class=""bar-fill"" style=""width:" + Ширина + "%""></div></div>");
			Строки.Добавить("</div>");
			
		КонецЦикла;
		
	КонецЕсли;
	
	Строки.Добавить("</body></html>");
	
	Возврат СтрСоединить(Строки, Символы.ПС);
	
КонецФункции

// Устанавливает границы периода по виду: Сегодня / Неделя / Месяц.
//
Процедура УстановитьПериодПоВиду(ВидПериода, НачалоПериода, КонецПериода) Экспорт
	
	ТекущаяДатаСеанса = ТекущаяДата();
	
	Если ВидПериода = "Сегодня" Тогда
		
		НачалоПериода = НачалоДня(ТекущаяДатаСеанса);
		КонецПериода = КонецДня(ТекущаяДатаСеанса);
		
	ИначеЕсли ВидПериода = "Неделя" Тогда
		
		НачалоПериода = НачалоНедели(ТекущаяДатаСеанса);
		КонецПериода = КонецНедели(ТекущаяДатаСеанса);
		
	ИначеЕсли ВидПериода = "Год" Тогда
		
		НачалоПериода = НачалоГода(ТекущаяДатаСеанса);
		КонецПериода = КонецГода(ТекущаяДатаСеанса);
		
	ИначеЕсли ВидПериода = "Период" Тогда
		
		Если Не ЗначениеЗаполнено(НачалоПериода) Тогда
			
			НачалоПериода = НачалоМесяца(ТекущаяДатаСеанса);
			
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(КонецПериода) Тогда
			
			КонецПериода = КонецМесяца(ТекущаяДатаСеанса);
			
		КонецЕсли;
		
		НачалоПериода = НачалоДня(НачалоПериода);
		КонецПериода = КонецДня(КонецПериода);
		
	Иначе
		
		ВидПериода = "Месяц";
		НачалоПериода = НачалоМесяца(ТекущаяДатаСеанса);
		КонецПериода = КонецМесяца(ТекущаяДатаСеанса);
		
	КонецЕсли;
	
КонецПроцедуры

// Определяет вид периода по переданным датам.
//
Функция ОпределитьВидПериода(НачалоПериода, КонецПериода) Экспорт
	
	ТекущаяДатаСеанса = ТекущаяДата();
	Начало = НачалоДня(НачалоПериода);
	Конец = КонецДня(КонецПериода);
	
	Если Начало = НачалоДня(ТекущаяДатаСеанса) И Конец = КонецДня(ТекущаяДатаСеанса) Тогда
		
		Возврат "Сегодня";
		
	ИначеЕсли Начало = НачалоНедели(ТекущаяДатаСеанса) И Конец = КонецНедели(ТекущаяДатаСеанса) Тогда
		
		Возврат "Неделя";
		
	ИначеЕсли Начало = НачалоМесяца(ТекущаяДатаСеанса) И Конец = КонецМесяца(ТекущаяДатаСеанса) Тогда
		
		Возврат "Месяц";
		
	ИначеЕсли Начало = НачалоГода(ТекущаяДатаСеанса) И Конец = КонецГода(ТекущаяДатаСеанса) Тогда
		
		Возврат "Год";
		
	КонецЕсли;
	
	Возврат "Период";
	
КонецФункции

// Возвращает границы периода для запросов: начало дня и конец дня.
//
Функция ГраницыПериодаДляОтчета(НачалоПериода, КонецПериода) Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("Начало", НачалоДня(НачалоПериода));
	Результат.Вставить("Конец", КонецДня(КонецПериода));
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция СуммаТаблицы(Таблица)
	
	Итого = 0;
	
	Для Каждого СтрокаТаблицы Из Таблица Цикл
		
		Итого = Итого + СтрокаТаблицы.Сумма;
		
	КонецЦикла;
	
	Возврат Итого;
	
КонецФункции

Процедура ДобавитьБлокКатегорийВHTML(Строки, ЗаголовокБлока, Таблица, ВидОперацииРасход, Акцент)
	
	Если Таблица.Количество() = 0 Тогда
		
		Возврат;
		
	КонецЕсли;
	
	Строки.Добавить("<div class=""section"" style=""margin-top:16px"">" + ЭкранироватьHTML(ЗаголовокБлока) + "</div>");
	
	Для Каждого СтрокаТаблицы Из Таблица Цикл
		
		ИмяКатегории = ?(ЗначениеЗаполнено(СтрокаТаблицы.Категория), Строка(СтрокаТаблицы.Категория), "Прочее");
		Ширина = Формат(Макс(СтрокаТаблицы.Процент, 0), "ЧДЦ=1; ЧРД=.; ЧН=0; ЧГ=");
		СуммаТекст = ОбщийМодульСервер_КурсыВалют.ПредставлениеСуммыВВалютеУчета(СтрокаТаблицы.Сумма, Ложь);
		ПроцентТекст = Формат(СтрокаТаблицы.Процент, "ЧДЦ=0; ЧН=0; ЧГ=") + "%";
		СтрокаВерха = "<div class=""item-top""><span class=""name"">" + ЭкранироватьHTML(ИмяКатегории)
			+ "</span><span class=""meta"">" + ЭкранироватьHTML(СуммаТекст) + " · " + ЭкранироватьHTML(ПроцентТекст) + "</span></div>";
		СтрокаИндикатора = "<div class=""bar""><div class=""bar-fill"" style=""width:" + Ширина + "%;background:" + Акцент + """></div></div>";
		
		Если ЗначениеЗаполнено(СтрокаТаблицы.Категория) Тогда
			
			ВидСсылки = ?(ВидОперацииРасход, "rashod", "dohod");
			Ссылка = "app:category:" + ВидСсылки + ":" + Строка(СтрокаТаблицы.Категория.УникальныйИдентификатор());
			Строки.Добавить("<a class=""item"" href=""" + Ссылка + """>");
			Строки.Добавить(СтрокаВерха);
			Строки.Добавить(СтрокаИндикатора);
			Строки.Добавить("</a>");
			
		Иначе
			
			Строки.Добавить("<div class=""item static"">");
			Строки.Добавить(СтрокаВерха);
			Строки.Добавить(СтрокаИндикатора);
			Строки.Добавить("</div>");
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура СвернутьМелкиеКатегории(Таблица, Итого)
	
	МаксимумСтрок = 8;
	
	Если Таблица.Количество() <= МаксимумСтрок Или Итого = 0 Тогда
		
		Возврат;
		
	КонецЕсли;
	
	СуммаПрочего = 0;
	Индекс = Таблица.Количество() - 1;
	
	Пока Индекс >= МаксимумСтрок - 1 Цикл
		
		СуммаПрочего = СуммаПрочего + Таблица[Индекс].Сумма;
		Таблица.Удалить(Индекс);
		Индекс = Индекс - 1;
		
	КонецЦикла;
	
	Если СуммаПрочего = 0 Тогда
		
		Возврат;
		
	КонецЕсли;
	
	СтрокаПрочего = Таблица.Добавить();
	СтрокаПрочего.Категория = Неопределено;
	СтрокаПрочего.Сумма = СуммаПрочего;
	СтрокаПрочего.Процент = Окр(100 * СуммаПрочего / Итого, 1);
	
КонецПроцедуры

Функция ПодписьИтогаОтчета(ВидОперацииРасход, НачалоПериода, КонецПериода, ВидПериода)
	
	Если ВидОперацииРасход Тогда
		
		База = "потрачено";
		
	Иначе
		
		База = "получено";
		
	КонецЕсли;
	
	Если ВидПериода = "Месяц"
		Или (НачалоДня(НачалоПериода) = НачалоМесяца(НачалоПериода)
			И КонецДня(КонецПериода) = КонецМесяца(НачалоПериода)) Тогда
		
		Возврат База + " за " + Формат(НачалоПериода, "ДФ='ММММ гггг'");
		
	КонецЕсли;
	
	Возврат База + " за период";
	
КонецФункции

Функция ЦветКатегорииОтчета(Индекс)
	
	Цвета = СтрРазделить("#2e7d32,#66bb6a,#a5d6a7,#43a047,#81c784,#c8e6c9,#1b5e20,#4caf50", ",");
	
	Если Цвета.Количество() = 0 Тогда
		
		Возврат "#2e7d32";
		
	КонецЕсли;
	
	Возврат Цвета[Индекс % Цвета.Количество()];
	
КонецФункции

Функция HTMLКольцеваяДиаграмма(Таблица, Итого)
	
	Если Итого = 0 Или Таблица.Количество() = 0 Тогда
		
		Возврат "";
		
	КонецЕсли;
	
	Радиус = 54;
	ДлинаОкружности = 2 * 3.14159265 * Радиус;
	Смещение = 0;
	ИндексЦвета = 0;
	Части = Новый Массив;
	Части.Добавить("<div class=""chart-wrap""><svg class=""chart"" viewBox=""0 0 140 140"">");
	Части.Добавить("<circle cx=""70"" cy=""70"" r=""54"" fill=""none"" stroke=""#eef1f4"" stroke-width=""18""/>");
	
	Для Каждого СтрокаТаблицы Из Таблица Цикл
		
		Доля = СтрокаТаблицы.Сумма / Итого;
		ДлинаДуги = ДлинаОкружности * Доля;
		Цвет = ЦветКатегорииОтчета(ИндексЦвета);
		ИндексЦвета = ИндексЦвета + 1;
		
		Части.Добавить("<circle cx=""70"" cy=""70"" r=""54"" fill=""none"" stroke=""" + Цвет
			+ """ stroke-width=""18"" stroke-dasharray=""" + Формат(ДлинаДуги, "ЧДЦ=2; ЧРД=.; ЧН=0; ЧГ=")
			+ " " + Формат(ДлинаОкружности, "ЧДЦ=2; ЧРД=.; ЧН=0; ЧГ=")
			+ """ stroke-dashoffset=""" + Формат(-Смещение, "ЧДЦ=2; ЧРД=.; ЧН=0; ЧГ=")
			+ """ transform=""rotate(-90 70 70)""/>");
		
		Смещение = Смещение + ДлинаДуги;
		
	КонецЦикла;
	
	Части.Добавить("</svg></div>");
	
	Возврат СтрСоединить(Части, "");
	
КонецФункции

