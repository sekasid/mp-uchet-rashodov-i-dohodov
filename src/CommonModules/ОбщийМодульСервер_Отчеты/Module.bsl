#Область ПрограммныйИнтерфейс

// Возвращает таблицу оборотов по категориям за период.
// Колонки: Категория, Сумма, Процент.
// Суммы — в валюте учёта (ресурс Сумма регистров).
//
Функция ОборотыПоКатегориям(ВидОперацииРасход, НачалоПериода, КонецПериода) Экспорт
	
	Запрос = Новый Запрос;
	
	Если ВидОперацииРасход Тогда
		
		Запрос.Текст =
		"ВЫБРАТЬ
		|	Обороты.КатегорияРасходов КАК Категория,
		|	СУММА(Обороты.СуммаОборот) КАК Сумма
		|ИЗ
		|	РегистрНакопления.Расходы.Обороты(&НачалоПериода, &КонецПериода) КАК Обороты
		|ГДЕ
		|	Обороты.СуммаОборот <> 0
		|
		|СГРУППИРОВАТЬ ПО
		|	Обороты.КатегорияРасходов
		|
		|УПОРЯДОЧИТЬ ПО
		|	Сумма УБЫВ";
		
	Иначе
		
		Запрос.Текст =
		"ВЫБРАТЬ
		|	Обороты.КатегорииДоходов КАК Категория,
		|	СУММА(Обороты.СуммаОборот) КАК Сумма
		|ИЗ
		|	РегистрНакопления.Доходы.Обороты(&НачалоПериода, &КонецПериода) КАК Обороты
		|ГДЕ
		|	Обороты.СуммаОборот <> 0
		|
		|СГРУППИРОВАТЬ ПО
		|	Обороты.КатегорииДоходов
		|
		|УПОРЯДОЧИТЬ ПО
		|	Сумма УБЫВ";
		
	КонецЕсли;
	
	Запрос.УстановитьПараметр("НачалоПериода", НачалоПериода);
	Запрос.УстановитьПараметр("КонецПериода", КонецПериода);
	
	Таблица = Запрос.Выполнить().Выгрузить();
	Таблица.Колонки.Добавить("Процент", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(10, 1)));
	
	Итого = 0;
	
	Для Каждого СтрокаТаблицы Из Таблица Цикл
		
		Итого = Итого + СтрокаТаблицы.Сумма;
		
	КонецЦикла;
	
	Если Итого <> 0 Тогда
		
		Для Каждого СтрокаТаблицы Из Таблица Цикл
			
			СтрокаТаблицы.Процент = Окр(100 * СтрокаТаблицы.Сумма / Итого, 1);
			
		КонецЦикла;
		
	КонецЕсли;
	
	СвернутьМелкиеКатегории(Таблица, Итого);
	
	Возврат Таблица;
	
КонецФункции

// Возвращает таблицу оборотов выбранной категории по дням.
// Колонки: День, Сумма, Процент.
//
Функция ОборотыКатегорииПоДням(ВидОперацииРасход, Категория, НачалоПериода, КонецПериода) Экспорт
	
	Запрос = Новый Запрос;
	
	Если ВидОперацииРасход Тогда
		
		Запрос.Текст =
		"ВЫБРАТЬ
		|	НАЧАЛОПЕРИОДА(Обороты.Период, ДЕНЬ) КАК День,
		|	СУММА(Обороты.СуммаОборот) КАК Сумма
		|ИЗ
		|	РегистрНакопления.Расходы.Обороты(&НачалоПериода, &КонецПериода, День, КатегорияРасходов = &Категория) КАК Обороты
		|ГДЕ
		|	Обороты.СуммаОборот <> 0
		|
		|СГРУППИРОВАТЬ ПО
		|	НАЧАЛОПЕРИОДА(Обороты.Период, ДЕНЬ)
		|
		|УПОРЯДОЧИТЬ ПО
		|	День УБЫВ";
		
	Иначе
		
		Запрос.Текст =
		"ВЫБРАТЬ
		|	НАЧАЛОПЕРИОДА(Обороты.Период, ДЕНЬ) КАК День,
		|	СУММА(Обороты.СуммаОборот) КАК Сумма
		|ИЗ
		|	РегистрНакопления.Доходы.Обороты(&НачалоПериода, &КонецПериода, День, КатегорииДоходов = &Категория) КАК Обороты
		|ГДЕ
		|	Обороты.СуммаОборот <> 0
		|
		|СГРУППИРОВАТЬ ПО
		|	НАЧАЛОПЕРИОДА(Обороты.Период, ДЕНЬ)
		|
		|УПОРЯДОЧИТЬ ПО
		|	День УБЫВ";
		
	КонецЕсли;
	
	Запрос.УстановитьПараметр("НачалоПериода", НачалоПериода);
	Запрос.УстановитьПараметр("КонецПериода", КонецПериода);
	Запрос.УстановитьПараметр("Категория", Категория);
	
	Таблица = Запрос.Выполнить().Выгрузить();
	Таблица.Колонки.Добавить("Процент", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(10, 1)));
	
	Итого = 0;
	
	Для Каждого СтрокаТаблицы Из Таблица Цикл
		
		Итого = Итого + СтрокаТаблицы.Сумма;
		
	КонецЦикла;
	
	Если Итого <> 0 Тогда
		
		Для Каждого СтрокаТаблицы Из Таблица Цикл
			
			СтрокаТаблицы.Процент = Окр(100 * СтрокаТаблицы.Сумма / Итого, 1);
			
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат Таблица;
	
КонецФункции

// Формирует HTML сводного отчёта: доходы и расходы за период.
//
Функция HTMLСводногоОтчетаПоОперациям(НачалоПериода, КонецПериода, ВидПериода) Экспорт
	
	ТаблицаДоходов = ОборотыПоКатегориям(Ложь, НачалоПериода, КонецПериода);
	ТаблицаРасходов = ОборотыПоКатегориям(Истина, НачалоПериода, КонецПериода);
	
	ИтогоДоходов = СуммаТаблицы(ТаблицаДоходов);
	ИтогоРасходов = СуммаТаблицы(ТаблицаРасходов);
	Разница = ИтогоДоходов - ИтогоРасходов;
	
	ВалютаУчета = Константы.ВалютаУчета.Получить();
	
	Строки = Новый Массив;
	ДобавитьОбщиеСтилиОтчета(Строки, "#1c2430");
	Строки.Добавить("<body>");
	Строки.Добавить("<a class=""back"" href=""app:back"">← Назад</a>");
	Строки.Добавить("<div class=""header"">");
	Строки.Добавить("<div class=""title"">Операции</div>");
	Строки.Добавить("<div class=""sub"">" + ЭкранироватьHTML(ПредставлениеПериодаОтчета(НачалоПериода, КонецПериода, ВалютаУчета)) + "</div>");
	Строки.Добавить("</div>");
	Строки.Добавить(HTMLПереключателиПериода(ВидПериода));
	
	Строки.Добавить("<div class=""summary-card"">");
	Строки.Добавить("<div class=""sum-line pos""><span>Доходы</span><span>"
		+ ЭкранироватьHTML(ОбщийМодульСервер_КурсыВалют.ПредставлениеСуммыВВалютеУчета(ИтогоДоходов, Истина)) + "</span></div>");
	Строки.Добавить("<div class=""sum-line neg""><span>Расходы</span><span>"
		+ ЭкранироватьHTML(ОбщийМодульСервер_КурсыВалют.ПредставлениеСуммыВВалютеУчета(-ИтогоРасходов, Истина)) + "</span></div>");
	Строки.Добавить("<div class=""sum-line total-line""><span>Итого</span><span>"
		+ ЭкранироватьHTML(ОбщийМодульСервер_КурсыВалют.ПредставлениеСуммыВВалютеУчета(Разница, Истина)) + "</span></div>");
	Строки.Добавить("</div>");
	
	Если ТаблицаДоходов.Количество() = 0 И ТаблицаРасходов.Количество() = 0 Тогда
		
		Строки.Добавить("<div class=""empty"">Операций за выбранный период нет</div>");
		
	Иначе
		
		ДобавитьБлокКатегорийВHTML(Строки, "Доходы", ТаблицаДоходов, Ложь, "#2e7d32");
		ДобавитьБлокКатегорийВHTML(Строки, "Расходы", ТаблицаРасходов, Истина, "#e53935");
		
	КонецЕсли;
	
	Строки.Добавить("</body></html>");
	
	Возврат СтрСоединить(Строки, Символы.ПС);
	
КонецФункции

// Формирует HTML отчёта по категориям (доходы или расходы).
//
Функция HTMLОтчетаПоКатегориям(ВидОперацииРасход, НачалоПериода, КонецПериода, ВидПериода) Экспорт
	
	Таблица = ОборотыПоКатегориям(ВидОперацииРасход, НачалоПериода, КонецПериода);
	Итого = 0;
	
	Для Каждого СтрокаТаблицы Из Таблица Цикл
		
		Итого = Итого + СтрокаТаблицы.Сумма;
		
	КонецЦикла;
	
	ВалютаУчета = Константы.ВалютаУчета.Получить();
	Акцент = ?(ВидОперацииРасход, "#e53935", "#2e7d32");
	Заголовок = ?(ВидОперацииРасход, "Расходы", "Доходы");
	ПодписьИтого = ?(ВидОперацииРасход, "потрачено за период", "получено за период");
	ПустойТекст = ?(ВидОперацииРасход, "Расходов за выбранный период нет", "Доходов за выбранный период нет");
	ЗаголовокСписка = ?(ВидОперацииРасход, "Категории", "Источники дохода");
	
	Строки = Новый Массив;
	ДобавитьОбщиеСтилиОтчета(Строки, Акцент);
	Строки.Добавить("<body>");
	Строки.Добавить("<div class=""header"">");
	Строки.Добавить("<div class=""title"">" + ЭкранироватьHTML(Заголовок) + "</div>");
	Строки.Добавить("<div class=""sub"">" + ЭкранироватьHTML(ПредставлениеПериодаОтчета(НачалоПериода, КонецПериода, ВалютаУчета)) + "</div>");
	Строки.Добавить("</div>");
	Строки.Добавить("<div class=""total"">" + ЭкранироватьHTML(ОбщийМодульСервер_КурсыВалют.ПредставлениеСуммыВВалютеУчета(Итого, Ложь)) + "</div>");
	Строки.Добавить("<div class=""total-sub"">" + ЭкранироватьHTML(ПодписьИтого) + "</div>");
	Строки.Добавить(HTMLПереключателиПериода(ВидПериода));
	
	Если Таблица.Количество() = 0 Тогда
		
		Строки.Добавить("<div class=""empty"">" + ЭкранироватьHTML(ПустойТекст) + "</div>");
		
	Иначе
		
		Строки.Добавить("<div class=""section"">" + ЭкранироватьHTML(ЗаголовокСписка) + "</div>");
		
		Для Каждого СтрокаТаблицы Из Таблица Цикл
			
			ИмяКатегории = ?(ЗначениеЗаполнено(СтрокаТаблицы.Категория), Строка(СтрокаТаблицы.Категория), "Прочее");
			Ширина = Формат(Макс(СтрокаТаблицы.Процент, 0), "ЧДЦ=1; ЧРД=.; ЧН=0; ЧГ=");
			СуммаТекст = ОбщийМодульСервер_КурсыВалют.ПредставлениеСуммыВВалютеУчета(СтрокаТаблицы.Сумма, Ложь);
			ПроцентТекст = Формат(СтрокаТаблицы.Процент, "ЧДЦ=0; ЧН=0; ЧГ=") + "%";
			СтрокаВерха = "<div class=""item-top""><span class=""name"">" + ЭкранироватьHTML(ИмяКатегории)
				+ "</span><span class=""meta"">" + ЭкранироватьHTML(СуммаТекст) + " · " + ЭкранироватьHTML(ПроцентТекст) + "</span></div>";
			СтрокаИндикатора = "<div class=""bar""><div class=""bar-fill"" style=""width:" + Ширина + "%""></div></div>";
			
			Если ЗначениеЗаполнено(СтрокаТаблицы.Категория) Тогда
				
				Ссылка = "app:category:" + Строка(СтрокаТаблицы.Категория.УникальныйИдентификатор());
				Строки.Добавить("<a class=""item"" href=""" + Ссылка + """>");
				Строки.Добавить(СтрокаВерха);
				Строки.Добавить(СтрокаИндикатора);
				Строки.Добавить("</a>");
				
			Иначе
				
				Строки.Добавить("<div class=""item static"">");
				Строки.Добавить(СтрокаВерха);
				Строки.Добавить(СтрокаИндикатора);
				Строки.Добавить("</div>");
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
	Строки.Добавить("</body></html>");
	
	Возврат СтрСоединить(Строки, Символы.ПС);
	
КонецФункции

// Формирует HTML расшифровки категории по дням.
//
