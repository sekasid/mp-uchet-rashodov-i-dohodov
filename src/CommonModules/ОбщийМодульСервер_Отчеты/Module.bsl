Функция ПодписьИтоговогоОстатка(Остаток)
	
	Абс = ?(Остаток < 0, -Остаток, Остаток);
	СуммаТекст = ОбщийМодульСервер_КурсыВалют.ПредставлениеСуммыВВалютеУчета(Абс, Ложь);
	
	Если Остаток > 0 Тогда
		
		Возврат "Доходы больше расходов на " + СуммаТекст;
		
	ИначеЕсли Остаток < 0 Тогда
		
		Возврат "Расходы больше доходов на " + СуммаТекст;
		
	КонецЕсли;
	
	Возврат "Доходы равны расходам";
	
КонецФункции

Процедура ДобавитьБлокСтруктурыВзаиморасчетов(Строки, Заголовок, Таблица, Итого, ВидОперацииРасход, ЛимитСтрок)
	
	Строки.Добавить("<div class=""block-head"">");
	Строки.Добавить("<div class=""section-title"">" + ЭкранироватьHTML(Заголовок) + "</div>");
	Строки.Добавить("<a class=""all-link"" href=""app:all:" + ?(ВидОперацииРасход, "rashod", "dohod") + """>Все ›</a>");
	Строки.Добавить("</div>");
	
	Если Таблица.Количество() = 0 Или Итого = 0 Тогда
		
		Строки.Добавить("<div class=""empty-soft"">Нет данных за период</div>");
		Возврат;
		
	КонецЕсли;
	
	Строки.Добавить("<div class=""struct"">");
	Индекс = 0;
	
	Для Каждого СтрокаТаблицы Из Таблица Цикл
		
		Если Индекс >= ЛимитСтрок Тогда
			
			Прервать;
			
		КонецЕсли;
		
		ИмяКатегории = ?(ЗначениеЗаполнено(СтрокаТаблицы.Категория), Строка(СтрокаТаблицы.Категория), "Прочее");
		СуммаТекст = ОбщийМодульСервер_КурсыВалют.ПредставлениеСуммыВВалютеУчета(СтрокаТаблицы.Сумма, Ложь);
		ПроцентТекст = Формат(СтрокаТаблицы.Процент, "ЧДЦ=0; ЧН=0; ЧГ=") + "%";
		Цвет = ?(ВидОперацииРасход, ЦветКатегорииРасхода(Индекс), ЦветКатегорииОтчета(Индекс));
		
		Строки.Добавить("<div class=""struct-row"">");
		Строки.Добавить("<span class=""struct-ico"" style=""background:" + Цвет + """></span>");
		Строки.Добавить("<span class=""struct-name"">" + ЭкранироватьHTML(ИмяКатегории) + "</span>");
		Строки.Добавить("<span class=""struct-right""><span class=""struct-sum"">" + ЭкранироватьHTML(СуммаТекст)
			+ "</span><span class=""struct-pct"">" + ЭкранироватьHTML(ПроцентТекст) + "</span></span>");
		Строки.Добавить("</div>");
		
		Индекс = Индекс + 1;
		
	КонецЦикла;
	
	Строки.Добавить("</div>");
	
КонецПроцедуры

Функция ЦветКатегорииРасхода(Индекс)
	
	Цвета = СтрРазделить("#43a047,#7e57c2,#42a5f5,#ff9800,#90a4ae,#ef5350,#26a69a,#8d6e63", ",");
	
	Возврат Цвета[Индекс % Цвета.Количество()];
	
КонецФункции

Функция HTMLСпарклайнСальдо(НачалоПериода, КонецПериода, ЦветЛинии)
	
	Точки = ТочкиСпарклайнаСальдо(НачалоПериода, КонецПериода);
	
	Если Точки.Количество() < 2 Тогда
		
		Возврат "<div class=""spark""></div>";
		
	КонецЕсли;
	
	Ширина = 112;
	Высота = 52;
	Отступ = 4;
	МинЗнач = Точки[0];
	МаксЗнач = Точки[0];
	
	Для Каждого ЗначениеТочки Из Точки Цикл
		
		Если ЗначениеТочки < МинЗнач Тогда
			
			МинЗнач = ЗначениеТочки;
			
		КонецЕсли;
		
		Если ЗначениеТочки > МаксЗнач Тогда
			
			МаксЗнач = ЗначениеТочки;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Размах = МаксЗнач - МинЗнач;
	
	Если Размах = 0 Тогда
		
		Размах = 1;
		
	КонецЕсли;
	
	ШагX = (Ширина - 2 * Отступ) / (Точки.Количество() - 1);
	Координаты = Новый Массив;
	Индекс = 0;
	
	Для Каждого ЗначениеТочки Из Точки Цикл
		
		X = Отступ + Индекс * ШагX;
		Y = Высота - Отступ - (ЗначениеТочки - МинЗнач) / Размах * (Высота - 2 * Отступ);
		Координаты.Добавить(Формат(X, "ЧДЦ=1; ЧРД=.; ЧН=0; ЧГ=") + "," + Формат(Y, "ЧДЦ=1; ЧРД=.; ЧН=0; ЧГ="));
		Индекс = Индекс + 1;
		
	КонецЦикла;
	
	Полилиния = СтрСоединить(Координаты, " ");
	Последняя = Координаты[Координаты.Количество() - 1];
	ЧастиПоследней = СтрРазделить(Последняя, ",");
	КонецX = ЧастиПоследней[0];
	КонецY = ЧастиПоследней[1];
	Первая = Координаты[0];
	ЧастиПервой = СтрРазделить(Первая, ",");
	НачалоX = ЧастиПервой[0];
	
	Заливка = Полилиния + " " + КонецX + "," + Формат(Высота - Отступ, "ЧДЦ=1; ЧРД=.; ЧН=0; ЧГ=")
		+ " " + НачалоX + "," + Формат(Высота - Отступ, "ЧДЦ=1; ЧРД=.; ЧН=0; ЧГ=");
	
	Возврат "<div class=""spark""><svg viewBox=""0 0 " + Формат(Ширина, "ЧГ=") + " " + Формат(Высота, "ЧГ=")
		+ """ width=""112"" height=""52"" preserveAspectRatio=""none"">"
		+ "<polygon fill=""" + ЦветЛинии + """ fill-opacity=""0.12"" points=""" + Заливка + """/>"
		+ "<polyline fill=""none"" stroke=""" + ЦветЛинии + """ stroke-width=""2.2"" stroke-linecap=""round"" stroke-linejoin=""round"" points="""
		+ Полилиния + """/>"
		+ "<circle cx=""" + КонецX + """ cy=""" + КонецY + """ r=""3.2"" fill=""" + ЦветЛинии + """/>"
		+ "</svg></div>";
	
КонецФункции

Функция ТочкиСпарклайнаСальдо(НачалоПериода, КонецПериода)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	НАЧАЛОПЕРИОДА(ДоходыОбороты.Период, ДЕНЬ) КАК День,
	|	СУММА(ДоходыОбороты.СуммаОборот) КАК СуммаДоход,
	|	0 КАК СуммаРасход
	|ИЗ
	|	РегистрНакопления.Доходы.Обороты(&НачалоПериода, &КонецПериода, День) КАК ДоходыОбороты
	|
	|СГРУППИРОВАТЬ ПО
	|	НАЧАЛОПЕРИОДА(ДоходыОбороты.Период, ДЕНЬ)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	НАЧАЛОПЕРИОДА(РасходыОбороты.Период, ДЕНЬ) КАК День,
	|	0,
	|	СУММА(РасходыОбороты.СуммаОборот)
	|ИЗ
	|	РегистрНакопления.Расходы.Обороты(&НачалоПериода, &КонецПериода, День) КАК РасходыОбороты
	|
	|СГРУППИРОВАТЬ ПО
	|	НАЧАЛОПЕРИОДА(РасходыОбороты.Период, ДЕНЬ)
	|
	|УПОРЯДОЧИТЬ ПО
	|	День";
	Запрос.УстановитьПараметр("НачалоПериода", НачалоПериода);
	Запрос.УстановитьПараметр("КонецПериода", КонецПериода);
	
	ТаблицаДней = Запрос.Выполнить().Выгрузить();
	Сводка = Новый Соответствие;
	ПорядокДней = Новый Массив;
	
	Для Каждого СтрокаДня Из ТаблицаДней Цикл
		
		Значение = Сводка.Получить(СтрокаДня.День);
		
		Если Значение = Неопределено Тогда
			
			Значение = 0;
			ПорядокДней.Добавить(СтрокаДня.День);
			
		КонецЕсли;
		
		Сводка.Вставить(СтрокаДня.День, Значение + СтрокаДня.СуммаДоход - СтрокаДня.СуммаРасход);
		
	КонецЦикла;
	
	Точки = Новый Массив;
	
	Если ПорядокДней.Количество() = 0 Тогда
		
		Точки.Добавить(0);
		Точки.Добавить(0);
		Возврат Точки;
		
	КонецЕсли;
	
	Накопительно = 0;
	
	Для Каждого День Из ПорядокДней Цикл
		
		Накопительно = Накопительно + Сводка.Получить(День);
		Точки.Добавить(Накопительно);
		
	КонецЦикла;
	
	Если Точки.Количество() = 1 Тогда
		
		Точки.Вставить(0, 0);
		
	КонецЕсли;
	
	Возврат Точки;
	
КонецФункции

