Процедура ДобавитьШапкуСписка(Строки, Заголовок, СтрокаПоиска, Плейсхолдер, Инфо)
	
	Строки.Добавить("<div class=""top"">");
	Строки.Добавить("<a class=""icon-btn"" href=""app:back"">" + SVGНазад() + "</a>");
	Строки.Добавить("<div class=""title"">" + ЭкранироватьHTML(Заголовок) + "</div>");
	Строки.Добавить("<a class=""icon-btn"" href=""app:add"">" + SVGПлюс() + "</a></div>");
	Строки.Добавить("<a class=""search"" href=""app:search""><span class=""search-text"">"
		+ ЭкранироватьHTML(?(ПустаяСтрока(СтрокаПоиска), Плейсхолдер, СтрокаПоиска)) + "</span></a>");
	Строки.Добавить("<div class=""info"">" + ЭкранироватьHTML(Инфо) + "</div>");
	
КонецПроцедуры

Процедура ДобавитьШапкуЭлемента(Строки, Заголовок, Предопределенный)
	
	Строки.Добавить("<div class=""top"">");
	Строки.Добавить("<a class=""icon-btn"" href=""app:back"">" + SVGНазад() + "</a>");
	Строки.Добавить("<div class=""title"">" + ЭкранироватьHTML(Заголовок) + "</div>");
	
	Если Предопределенный Тогда
		
		Строки.Добавить("<span class=""icon-btn ghost""></span>");
		
	Иначе
		
		Строки.Добавить("<a class=""icon-btn"" href=""app:delete"">" + SVGКорзина() + "</a>");
		
	КонецЕсли;
	
	Строки.Добавить("</div>");
	
КонецПроцедуры

Процедура ДобавитьКнопкуЗаписи(Строки, МожноЗаписать, ТекстАктивной, ТекстНеактивной)
	
	Класс = ?(МожноЗаписать, "btn", "btn disabled");
	Ссылка = ?(МожноЗаписать, "app:save", "app:noop");
	Текст = ?(МожноЗаписать, ТекстАктивной, ТекстНеактивной);
	Строки.Добавить("<div class=""footer""><a class=""" + Класс + """ href=""" + Ссылка + """>"
		+ ЭкранироватьHTML(Текст) + "</a></div>");
	
