// HTML элемента контакта.
//
Функция HTMLЭлементаКонтакта(Данные) Экспорт
	
	Акцент = АкцентКонтактов();
	Наименование = ?(ЗначениеЗаполнено(Данные.Наименование), Данные.Наименование, "Без имени");
	ТелефонЗаполнен = ЗначениеЗаполнено(ТолькоЦифрыТелефона(Данные.Телефон));
	Телефон = ?(ТелефонЗаполнен, ФорматТелефонаПоМаске(Данные.Телефон), "Добавить телефон");
	Почта = ?(ЗначениеЗаполнено(Данные.Почта), Данные.Почта, "Добавить почту");
	Комментарий = ?(ЗначениеЗаполнено(Данные.Комментарий), Данные.Комментарий, "Добавить комментарий");
	МожноЗаписать = ЗначениеЗаполнено(Данные.Наименование);
	КлассТелефона = ?(ТелефонЗаполнен, "value", "value muted");
	КлассПочты = ?(ЗначениеЗаполнено(Данные.Почта), "value", "value muted");
	КлассКомментария = ?(ЗначениеЗаполнено(Данные.Комментарий), "value", "value muted");
	
	Строки = Новый Массив;
	ДобавитьШапку(Строки, СтилиЭлемента(Акцент));
	ДобавитьШапкуЭлемента(Строки, "Контакт", Ложь);
	Строки.Добавить("<a class=""card"" href=""app:name""><span class=""label"">Имя</span>"
		+ "<span class=""value"">" + ЭкранироватьHTML(Наименование) + "</span></a>");
	Строки.Добавить("<a class=""card"" href=""app:phone""><span class=""label"">Телефон</span>"
		+ "<span class=""" + КлассТелефона + """>" + ЭкранироватьHTML(Телефон) + "</span></a>");
	Строки.Добавить("<a class=""card"" href=""app:email""><span class=""label"">Почта</span>"
		+ "<span class=""" + КлассПочты + """>" + ЭкранироватьHTML(Почта) + "</span></a>");
	Строки.Добавить("<a class=""card"" href=""app:comment""><span class=""label"">Комментарий</span>"
		+ "<span class=""" + КлассКомментария + """>" + ЭкранироватьHTML(Комментарий) + "</span></a>");
	Строки.Добавить("<div class=""info"">Контакт будет доступен в документах передачи средств в долг</div>");
	ДобавитьКнопкуЗаписи(Строки, МожноЗаписать, "Записать контакт", "Укажите имя");
	Строки.Добавить("</body></html>");
	
	Возврат СтрСоединить(Строки, Символы.ПС);
	
КонецФункции

Функция КонтактПоИдентификатору(ИдентификаторСтрокой) Экспорт
	
	Если Не ЗначениеЗаполнено(ИдентификаторСтрокой) Тогда
		
		Возврат Справочники.Контакты.ПустаяСсылка();
		
	КонецЕсли;
	
