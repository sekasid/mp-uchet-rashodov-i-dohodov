#Область ПрограммныйИнтерфейс

#Область Счета

// HTML списка счетов.
//
Функция HTMLСпискаСчетов(СтрокаПоиска = "") Экспорт
	
	Акцент = АкцентСчетов();
	Таблица = ТаблицаСчетов(СтрокаПоиска);
	
	Строки = Новый Массив;
	ДобавитьШапку(Строки, СтилиСписка(Акцент));
	ДобавитьШапкуСписка(Строки, "Счета", СтрокаПоиска, "Поиск счёта",
		"Счета используются в операциях и переводах");
	Строки.Добавить("<div class=""list"">");
	
	Если Таблица.Количество() = 0 Тогда
		
		Строки.Добавить("<div class=""empty"">Счета не найдены</div>");
		
	Иначе
		
		Для Каждого СтрокаСчета Из Таблица Цикл
			
			Ссылка = "app:open:" + Строка(СтрокаСчета.Ссылка.УникальныйИдентификатор());
			Подпись = ПредставлениеВидаСчета(СтрокаСчета.ВидСчета);
			Строки.Добавить("<a class=""item"" href=""" + Ссылка + """>");
			Строки.Добавить("<span class=""mid""><span class=""name"">" + ЭкранироватьHTML(СтрокаСчета.Наименование)
				+ "</span><span class=""sub"">" + ЭкранироватьHTML(Подпись) + "</span></span>");
			Строки.Добавить("<span class=""chev"">›</span></a>");
			
		КонецЦикла;
		
	КонецЕсли;
	
	Строки.Добавить("</div></body></html>");
	
	Возврат СтрСоединить(Строки, Символы.ПС);
	
КонецФункции

// HTML выбора счёта.
//
Функция HTMLВыбораСчетов(ТекущийСчет = Неопределено, СтрокаПоиска = "") Экспорт
	
	Акцент = АкцентСчетов();
	Таблица = ТаблицаСчетов(СтрокаПоиска);
	
	Строки = Новый Массив;
	ДобавитьШапку(Строки, СтилиСписка(Акцент) + СтилиКнопки(Акцент));
	ДобавитьШапкуСписка(Строки, "Выбор счёта", СтрокаПоиска, "Найти счёт",
		"Выберите счёт для операции");
	Строки.Добавить("<div class=""list choice"">");
	
	Если Таблица.Количество() = 0 Тогда
		
		Строки.Добавить("<div class=""empty"">Счета не найдены</div>");
		
	Иначе
		
		Для Каждого СтрокаСчета Из Таблица Цикл
			
			Выбран = ЗначениеЗаполнено(ТекущийСчет) И СтрокаСчета.Ссылка = ТекущийСчет;
			Класс = ?(Выбран, "item selected", "item");
			Ссылка = "app:pick:" + Строка(СтрокаСчета.Ссылка.УникальныйИдентификатор());
			Подпись = ПредставлениеВидаСчета(СтрокаСчета.ВидСчета);
			Строки.Добавить("<a class=""" + Класс + """ href=""" + Ссылка + """>");
			Строки.Добавить("<span class=""mid""><span class=""name"">" + ЭкранироватьHTML(СтрокаСчета.Наименование)
				+ "</span><span class=""sub"">" + ЭкранироватьHTML(Подпись) + "</span></span>");
			Строки.Добавить(?(Выбран, "<span class=""check"">✓</span>", "<span class=""chev"">›</span>"));
			Строки.Добавить("</a>");
			
		КонецЦикла;
		
	КонецЕсли;
	
	Строки.Добавить("</div>");
	
	Если ЗначениеЗаполнено(ТекущийСчет) Тогда
		
		Строки.Добавить("<div class=""footer""><a class=""btn"" href=""app:confirm"">Выбрать: "
			+ ЭкранироватьHTML(Строка(ТекущийСчет)) + "</a></div>");
		
	КонецЕсли;
	
	Строки.Добавить("</body></html>");
	
	Возврат СтрСоединить(Строки, Символы.ПС);
	
КонецФункции

// HTML элемента счёта.
//
Функция HTMLЭлементаСчета(Данные, РежимВыбораВида = Ложь) Экспорт
	
	Акцент = АкцентСчетов();
	
	Если РежимВыбораВида Тогда
		
		Возврат HTMLВыбораВидаСчета(Данные, Акцент);
		
	КонецЕсли;
	
	Наименование = ?(ЗначениеЗаполнено(Данные.Наименование), Данные.Наименование, "Без названия");
	ВидТекст = ?(ЗначениеЗаполнено(Данные.ВидСчетаТекст), Данные.ВидСчетаТекст, "Выберите вид счёта");
	МожноЗаписать = ЗначениеЗаполнено(Данные.Наименование) И ЗначениеЗаполнено(Данные.ВидСчета);
	
	Строки = Новый Массив;
	ДобавитьШапку(Строки, СтилиЭлемента(Акцент));
	ДобавитьШапкуЭлемента(Строки, "Счёт", Данные.Предопределенный);
	Строки.Добавить("<a class=""card"" href=""app:name""><span class=""label"">Наименование</span>"
		+ "<span class=""value"">" + ЭкранироватьHTML(Наименование) + "</span></a>");
	Строки.Добавить("<a class=""card"" href=""app:kind""><span class=""label"">Вид счёта</span>"
		+ "<span class=""value"">" + ЭкранироватьHTML(ВидТекст) + "</span></a>");
	Строки.Добавить("<div class=""info"">Счёт будет доступен в документах дохода, расхода и переводах</div>");
	ДобавитьКнопкуЗаписи(Строки, МожноЗаписать, "Записать счёт", "Укажите наименование и вид");
	Строки.Добавить("</body></html>");
	
	Возврат СтрСоединить(Строки, Символы.ПС);
	
КонецФункции

Функция СчетПоИдентификатору(ИдентификаторСтрокой) Экспорт
	
	Если Не ЗначениеЗаполнено(ИдентификаторСтрокой) Тогда
		
		Возврат Справочники.Счета.ПустаяСсылка();
		
	КонецЕсли;
	
	Возврат Справочники.Счета.ПолучитьСсылку(Новый УникальныйИдентификатор(ИдентификаторСтрокой));
	
КонецФункции

Функция ВидСчетаПоИмени(ИмяВида) Экспорт
	
	Если ИмяВида = "Кошелек" Тогда
		
		Возврат Перечисления.ВидСчета.Кошелек;
		
	ИначеЕсли ИмяВида = "БанковскаяКарта" Тогда
		
		Возврат Перечисления.ВидСчета.БанковскаяКарта;
		
	ИначеЕсли ИмяВида = "БанковскийСчет" Тогда
		
		Возврат Перечисления.ВидСчета.БанковскийСчет;
		
	КонецЕсли;
	
	Возврат Перечисления.ВидСчета.ПустаяСсылка();
	
КонецФункции

Функция ПредставлениеВидаСчета(ВидСчета) Экспорт
	
	Если ВидСчета = Перечисления.ВидСчета.Кошелек Тогда
		
		Возврат "Наличные";
		
	ИначеЕсли ВидСчета = Перечисления.ВидСчета.БанковскаяКарта Тогда
		
		Возврат "Банковская карта";
		
	ИначеЕсли ВидСчета = Перечисления.ВидСчета.БанковскийСчет Тогда
		
		Возврат "Банковский счёт";
		
	КонецЕсли;
	
	Возврат "Не указан";
	
КонецФункции

