Функция HTMLВыбораВидаСчета(Данные, Акцент)
	
	Варианты = Новый Массив;
	Варианты.Добавить(Новый Структура("Имя, Текст", "Кошелек", "Наличные"));
	Варианты.Добавить(Новый Структура("Имя, Текст", "БанковскаяКарта", "Банковская карта"));
	Варианты.Добавить(Новый Структура("Имя, Текст", "БанковскийСчет", "Банковский счёт"));
	
	Строки = Новый Массив;
	ДобавитьШапку(Строки, СтилиСписка(Акцент));
	Строки.Добавить("<div class=""top"">");
	Строки.Добавить("<a class=""icon-btn"" href=""app:kind-back"">" + SVGНазад() + "</a>");
	Строки.Добавить("<div class=""title"">Вид счёта</div>");
	Строки.Добавить("<span class=""icon-btn ghost""></span></div>");
	Строки.Добавить("<div class=""list"">");
	
	Для Каждого Вариант Из Варианты Цикл
		
		Выбран = Данные.ВидСчетаИмя = Вариант.Имя;
		Класс = ?(Выбран, "item selected", "item");
		Строки.Добавить("<a class=""" + Класс + """ href=""app:set-kind:" + Вариант.Имя + """>");
		Строки.Добавить("<span class=""mid""><span class=""name"">" + ЭкранироватьHTML(Вариант.Текст)
			+ "</span></span>");
		Строки.Добавить(?(Выбран, "<span class=""check"">✓</span>", "<span class=""chev"">›</span>"));
		Строки.Добавить("</a>");
		
	КонецЦикла;
	
	Строки.Добавить("</div></body></html>");
	
	Возврат СтрСоединить(Строки, Символы.ПС);
	
КонецФункции

