////////////////////////////////////////////////////////////////////////////////
// Общий модуль клиент.
// Клиентские процедуры интерфейса и вызовы серверных операций учёта.
////////////////////////////////////////////////////////////////////////////////

#Область ПрограммныйИнтерфейс

// Устанавливает единый размер шрифта элементов формы (кроме групп и полей без свойства Шрифт).
//
Процедура ИзменитьРазмерШрифтаЭлементов(Форма) Экспорт
	
	Шрифт12 = Новый Шрифт(, 10,);
	
	Для Каждого СтрокаЭлемента Из Форма.Элементы Цикл
		
		Если ТипЗнч(СтрокаЭлемента) = Тип("ГруппаФормы") Тогда
			
			Продолжить;
			
		КонецЕсли;
		
		Если ТипЗнч(СтрокаЭлемента) = Тип("ПолеФормы")
			И СтрокаЭлемента.Вид = ВидПоляФормы.ПолеHTMLДокумента Тогда
			
			Продолжить;
			
		КонецЕсли;
		
		Если ТипЗнч(СтрокаЭлемента) = Тип("ДекорацияФормы")
			И СтрокаЭлемента.Вид = ВидДекорацииФормы.Картинка Тогда
			
			Продолжить;
			
		КонецЕсли;
		
		СтрокаЭлемента.Шрифт = Шрифт12;
		
	КонецЦикла;
	
КонецПроцедуры

// Заполняет виды предопределённых счетов на сервере.
//
Процедура ЗаполнитьПредопределенныеКошельки() Экспорт
	
	ОбщийМодульСервер_СистемныеНастройки.ЗаполнитьПредопределенныеКошелькиНаСервере();
	
КонецПроцедуры

// Синхронно создаёт и проводит операцию учёта на сервере.
//
Процедура СоздатьИПровестиОперацию(ДатаДокумента, ВидОперации, Категория, Счет, Валюта, СуммаДокумента) Экспорт
	
	ОбщийМодульСервер_ОперацииУчета.СоздатьИПровестиОперацию(ДатаДокумента, ВидОперации, Категория, Счет, Валюта, СуммаДокумента);
	
КонецПроцедуры

// Открывает цифровую клавиатуру Wallet для ввода суммы.
// ОписаниеОповещения получает Число или Неопределено (отмена).
// Режим: "income" | "expense" | "transfer" — цвет суммы; либо ЦветСуммы (#HEX).
//
Процедура ПоказатьВводСуммы(ОписаниеОповещения, Сумма = 0, Заголовок = "Сумма", Режим = "transfer", ЦветСуммы = "") Экспорт
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Сумма", Сумма);
	ПараметрыФормы.Вставить("Заголовок", Заголовок);
	ПараметрыФормы.Вставить("Режим", Режим);
	
	Если ЗначениеЗаполнено(ЦветСуммы) Тогда
		
		ПараметрыФормы.Вставить("ЦветСуммы", ЦветСуммы);
		
	КонецЕсли;
	
	ОткрытьФорму("ОбщаяФорма.ФормаЦифровойКлавиатуры", ПараметрыФормы, , , , , ОписаниеОповещения,
		РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
	
КонецПроцедуры

// Открывает выбор счёта в стиле Wallet.
// ОписаниеОповещения получает СправочникСсылка.Счета или Неопределено.
//
Процедура ПоказатьВыборСчета(ОписаниеОповещения, ТекущийСчет = Неопределено, Заголовок = "Выбор счёта",
	ИсключитьСчет = Неопределено) Экспорт
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("ТекущийСчет", ТекущийСчет);
	ПараметрыФормы.Вставить("Заголовок", Заголовок);
	ПараметрыФормы.Вставить("ИсключитьСчет", ИсключитьСчет);
	
	ОткрытьФорму("ОбщаяФорма.ФормаВыбораСчета", ПараметрыФормы, , , , , ОписаниеОповещения,
		РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
	
КонецПроцедуры

// Открывает текстовую клавиатуру Wallet.
// ОписаниеОповещения получает Строку или Неопределено (отмена).
//
Процедура ПоказатьВводТекста(ОписаниеОповещения, Текст = "", Заголовок = "Текст", МаксДлина = 100) Экспорт
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Текст", Текст);
	ПараметрыФормы.Вставить("Заголовок", Заголовок);
	ПараметрыФормы.Вставить("МаксДлина", МаксДлина);
	
	ОткрытьФорму("ОбщаяФорма.ФормаТекстовойКлавиатуры", ПараметрыФормы, , , , , ОписаниеОповещения,
		РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
	
КонецПроцедуры

#КонецОбласти
