////////////////////////////////////////////////////////////////////////////////
// Форма документа Переводы.
// HTML-интерфейс «Новый перевод» по макету Wallet.
////////////////////////////////////////////////////////////////////////////////

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Ключ.Пустая() Тогда
		
		Объект.Дата = ТекущаяДата();
		Объект.Валюта = ОбщийМодульСервер_СистемныеНастройки.ПолучитьВалютуРегламентированногоУчета();
		ЗаполнитьСчетаПоУмолчанию();
		Заголовок = "Новый перевод";
		
	Иначе
		
		Заголовок = "Перевод";
		
	КонецЕсли;
	
	ОбновитьHTMLНаСервере();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовФормы

&НаКлиенте
Процедура ПолеHTMLПриНажатии(Элемент, ДанныеСобытия, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	КомандаПриложения = ИзвлечьКомандуИзСсылки(ДанныеСобытия.Href);
	
	Если Не ЗначениеЗаполнено(КомандаПриложения) Тогда
		
		Возврат;
		
	КонецЕсли;
	
	ОбработатьКомандуHTML(КомандаПриложения);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ОбработатьКомандуHTML(КомандаПриложения)
	
	Если КомандаПриложения = "back"
		Или КомандаПриложения = "home"
		Или КомандаПриложения = "operations"
		Или КомандаПриложения = "reports"
		Или КомандаПриложения = "catalogs"
		Или КомандаПриложения = "settings" Тогда
		
		Закрыть();
		
	ИначеЕсли КомандаПриложения = "history" Тогда
		
		ОткрытьФорму("Документ.Переводы.Форма.ФормаСписка", , ЭтотОбъект, , , , ,
			РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
		
	ИначеЕсли КомандаПриложения = "from" Тогда
		
		НачатьВыборСчета("from");
		
	ИначеЕсли КомандаПриложения = "to" Тогда
		
		НачатьВыборСчета("to");
		
	ИначеЕсли КомандаПриложения = "swap" Тогда
		
		ПоменятьСчетаМестами();
		
	ИначеЕсли КомандаПриложения = "clear-sum" Тогда
		
		Объект.Сумма = 0;
		ОбновитьHTMLНаСервере();
		
	ИначеЕсли КомандаПриложения = "edit-sum" Или КомандаПриложения = "other-sum" Тогда
		
		НачатьВводСуммы();
		
	ИначеЕсли СтрНачинаетсяС(КомандаПриложения, "add:") Тогда
		
		Добавка = Число(Сред(КомандаПриложения, СтрДлина("add:") + 1));
		Объект.Сумма = Объект.Сумма + Добавка;
		ОбновитьHTMLНаСервере();
		
	ИначеЕсли КомандаПриложения = "edit-comment" Тогда
		
		НачатьВводКомментария();
		
	ИначеЕсли КомандаПриложения = "submit" Тогда
		
		ВыполнитьПеревод();
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура НачатьВыборСчета(РежимВыбора)
	
	РежимВыбораСчета = РежимВыбора;
	ОписаниеОповещения = Новый ОписаниеОповещения("ПослеВыбораСчетаИзФормы", ЭтотОбъект);
	
	Если РежимВыбора = "from" Тогда
		
		ОбщийМодульКлиент.ПоказатьВыборСчета(ОписаниеОповещения, Объект.СчетИсточник, "Счет списания");
		
	Иначе
		
		ОбщийМодульКлиент.ПоказатьВыборСчета(ОписаниеОповещения, Объект.СчетПолучатель, "Счет зачисления",
			Объект.СчетИсточник);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеВыбораСчетаИзФормы(ВыбранныйСчет, ДополнительныеПараметры) Экспорт
	
	Если ВыбранныйСчет = Неопределено Тогда
		
		Возврат;
		
	КонецЕсли;
	
	Если РежимВыбораСчета = "from" Тогда
		
		Объект.СчетИсточник = ВыбранныйСчет;
		
	Иначе
		
		Объект.СчетПолучатель = ВыбранныйСчет;
		
	КонецЕсли;
	
	ОбновитьHTMLНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура НачатьВводСуммы()
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ПослеВводаСуммы", ЭтотОбъект);
	ОбщийМодульКлиент.ПоказатьВводСуммы(ОписаниеОповещения, Объект.Сумма, "Сумма перевода", "transfer");
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеВводаСуммы(Число, ДополнительныеПараметры) Экспорт
	
	Если Число = Неопределено Тогда
		
		Возврат;
		
	КонецЕсли;
	
	Если Число < 0 Тогда
		
		Число = 0;
		
	КонецЕсли;
	
	Объект.Сумма = Число;
	ОбновитьHTMLНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура НачатьВводКомментария()
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ПослеВводаКомментария", ЭтотОбъект);
	ОбщийМодульКлиент.ПоказатьВводТекста(ОписаниеОповещения, Объект.Комментарий, "Комментарий", 100);
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеВводаКомментария(Строка, ДополнительныеПараметры) Экспорт
	
	Если Строка = Неопределено Тогда
		
		Возврат;
		
	КонецЕсли;
	
	Объект.Комментарий = Лев(Строка, 100);
	ОбновитьHTMLНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура ПоменятьСчетаМестами()
	
	ВременныйСчет = Объект.СчетИсточник;
	Объект.СчетИсточник = Объект.СчетПолучатель;
	Объект.СчетПолучатель = ВременныйСчет;
	ОбновитьHTMLНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура ВыполнитьПеревод()
	
	Если Не ЗначениеЗаполнено(Объект.СчетИсточник) Тогда
		
		ПоказатьПредупреждение(, "Выберите счёт списания.");
		Возврат;
		
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Объект.СчетПолучатель) Тогда
		
		ПоказатьПредупреждение(, "Выберите счёт зачисления.");
		Возврат;
		
	КонецЕсли;
	
	Если Объект.СчетИсточник = Объект.СчетПолучатель Тогда
		
		ПоказатьПредупреждение(, "Счета списания и зачисления должны отличаться.");
		Возврат;
		
	КонецЕсли;
	
	Если Объект.Сумма <= 0 Тогда
		
		ПоказатьПредупреждение(, "Укажите сумму перевода больше нуля.");
		Возврат;
		
	КонецЕсли;
	
	ПараметрыЗаписи = Новый Структура("РежимЗаписи", РежимЗаписиДокумента.Проведение);
	
	Если Записать(ПараметрыЗаписи) Тогда
		
		Закрыть();
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьHTMLНаСервере()
	
	ТекстHTML = СобратьHTMLФормыПеревода();
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСчетаПоУмолчанию()
	
	ТаблицаСчетов = ТаблицаСчетовСОстатками();
	
	Если ТаблицаСчетов.Количество() = 0 Тогда
		
		Возврат;
		
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Объект.СчетИсточник) Тогда
		
		Объект.СчетИсточник = ТаблицаСчетов[0].Счет;
		
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Объект.СчетПолучатель) Тогда
		
		Для Каждого СтрокаСчета Из ТаблицаСчетов Цикл
			
			Если СтрокаСчета.Счет <> Объект.СчетИсточник Тогда
				
				Объект.СчетПолучатель = СтрокаСчета.Счет;
				Прервать;
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ТаблицаСчетовСОстатками()
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Кошелек.Ссылка КАК Счет,
	|	Кошелек.Наименование КАК Наименование,
	|	Кошелек.ВидСчета КАК ВидСчета,
	|	СУММА(ЕСТЬNULL(БалансОстатки.СуммаОстаток, 0)) КАК Остаток
	|ИЗ
	|	Справочник.Счета КАК Кошелек
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.Баланс.Остатки(&Период, ) КАК БалансОстатки
	|		ПО БалансОстатки.Счета = Кошелек.Ссылка
	|ГДЕ
	|	НЕ Кошелек.ПометкаУдаления
	|
	|СГРУППИРОВАТЬ ПО
	|	Кошелек.Ссылка,
	|	Кошелек.Наименование,
	|	Кошелек.ВидСчета
	|
	|УПОРЯДОЧИТЬ ПО
	|	Наименование";
	Запрос.УстановитьПараметр("Период", ТекущаяДата());
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

&НаСервере
Функция НайтиСтрокуСчета(ТаблицаСчетов, Счет)
	
	Если Не ЗначениеЗаполнено(Счет) Тогда
		
		Возврат Неопределено;
		
	КонецЕсли;
	
	Для Каждого СтрокаСчета Из ТаблицаСчетов Цикл
		
		Если СтрокаСчета.Счет = Счет Тогда
			
			Возврат СтрокаСчета;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Неопределено;
	
КонецФункции

&НаСервере
Функция СобратьHTMLФормыПеревода()
	
	ТаблицаСчетов = ТаблицаСчетовСОстатками();
	СтрокаИсточник = НайтиСтрокуСчета(ТаблицаСчетов, Объект.СчетИсточник);
	СтрокаПолучатель = НайтиСтрокуСчета(ТаблицаСчетов, Объект.СчетПолучатель);
	
	ОстатокИсточник = ?(СтрокаИсточник = Неопределено, 0, СтрокаИсточник.Остаток);
	ОстатокПолучатель = ?(СтрокаПолучатель = Неопределено, 0, СтрокаПолучатель.Остаток);
	ОстатокИсточникПосле = ОстатокИсточник - Объект.Сумма;
	ОстатокПолучательПосле = ОстатокПолучатель + Объект.Сумма;
	
	ИмяИсточник = ?(СтрокаИсточник = Неопределено, "Выберите счёт", СтрокаИсточник.Наименование);
	ИмяПолучатель = ?(СтрокаПолучатель = Неопределено, "Выберите счёт", СтрокаПолучатель.Наименование);
	ПодписьИсточник = ?(СтрокаИсточник = Неопределено, "Счёт списания", ПредставлениеВидаСчета(СтрокаИсточник.ВидСчета));
	ПодписьПолучатель = ?(СтрокаПолучатель = Неопределено, "Счёт зачисления", ПредставлениеВидаСчета(СтрокаПолучатель.ВидСчета));
	
	СуммаТекст = ОбщийМодульСервер_КурсыВалют.ПредставлениеСуммыВВалютеУчетаДляHTML(Объект.Сумма, Ложь);
	ОстатокИсточникТекст = ОбщийМодульСервер_КурсыВалют.ПредставлениеСуммыВВалютеУчетаДляHTML(ОстатокИсточник, Ложь);
	ОстатокПолучательТекст = ОбщийМодульСервер_КурсыВалют.ПредставлениеСуммыВВалютеУчетаДляHTML(ОстатокПолучатель, Ложь);
	ОстатокИсточникПослеТекст = ОбщийМодульСервер_КурсыВалют.ПредставлениеСуммыВВалютеУчетаДляHTML(ОстатокИсточникПосле, Ложь);
	ОстатокПолучательПослеТекст = ОбщийМодульСервер_КурсыВалют.ПредставлениеСуммыВВалютеУчетаДляHTML(ОстатокПолучательПосле, Ложь);
	
	Комментарий = СокрЛП(Объект.Комментарий);
	ДлинаКомментария = СтрДлина(Комментарий);
	ТекстКомментария = ?(ПустаяСтрока(Комментарий), "Добавить комментарий", Комментарий);
	КлассКомментария = ?(ПустаяСтрока(Комментарий), "placeholder", "");
	
	КнопкаСуммы = ОбщийМодульСервер_КурсыВалют.ПредставлениеСуммыВВалютеУчетаДляHTML(Объект.Сумма, Ложь);
	
	Строки = Новый Массив;
	Строки.Добавить("<!DOCTYPE html><html lang=""ru""><head><meta charset=""utf-8"">");
	Строки.Добавить("<meta name=""viewport"" content=""width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no"">");
	Строки.Добавить("<style>");
	Строки.Добавить(СтилиФормыПеревода());
	Строки.Добавить("</style></head><body>");
	
	Строки.Добавить("<div class=""top"">");
	Строки.Добавить("<a class=""icon-btn"" href=""app:back"">" + SVGСтрелкаНазад() + "</a>");
	Строки.Добавить("<div class=""title"">" + ЭкранироватьHTML(Заголовок) + "</div>");
	Строки.Добавить("<a class=""icon-btn"" href=""app:history"">" + SVGИстория() + "</a>");
	Строки.Добавить("</div>");
	
	Строки.Добавить("<div class=""lbl"">Счет списания</div>");
	Строки.Добавить(HTMLКарточкаСчета("from", "#EFF6FF", "#2563EB", SVGКарта(), ИмяИсточник, ПодписьИсточник, ОстатокИсточникТекст));
	
	Строки.Добавить("<div class=""swap-wrap""><a class=""swap"" href=""app:swap"">" + SVGСтрелкаВниз() + "</a></div>");
	
	Строки.Добавить("<div class=""lbl"">Счет зачисления</div>");
	Строки.Добавить(HTMLКарточкаСчета("to", "#F0FDFA", "#14B8A6", SVGКошелек(), ИмяПолучатель, ПодписьПолучатель, ОстатокПолучательТекст));
	
	Строки.Добавить("<div class=""card amount-card"">");
	Строки.Добавить("<div class=""lbl"">Сумма перевода</div>");
	Строки.Добавить("<div class=""amount-row"">");
	Строки.Добавить("<a class=""amount"" href=""app:edit-sum"">" + СуммаТекст + "</a>");
	Строки.Добавить("<a class=""clear"" href=""app:clear-sum"">" + SVGОчистить() + "</a>");
	Строки.Добавить("</div>");
	Строки.Добавить("<div class=""chips"">");
	Строки.Добавить("<a class=""chip"" href=""app:add:1000"">+1&nbsp;000</a>");
	Строки.Добавить("<a class=""chip"" href=""app:add:5000"">+5&nbsp;000</a>");
	Строки.Добавить("<a class=""chip"" href=""app:add:10000"">+10&nbsp;000</a>");
	Строки.Добавить("<a class=""chip"" href=""app:other-sum"">Другая</a>");
	Строки.Добавить("</div></div>");
	
	Строки.Добавить("<a class=""card comment-card"" href=""app:edit-comment"">");
	Строки.Добавить("<div class=""lbl"">Комментарий</div>");
	Строки.Добавить("<div class=""comment " + КлассКомментария + """>" + ЭкранироватьHTML(ТекстКомментария) + "</div>");
	Строки.Добавить("<div class=""counter"">" + Формат(ДлинаКомментария, "ЧН=0; ЧГ=") + "/100</div>");
	Строки.Добавить("</a>");
	
	Если ЗначениеЗаполнено(Объект.СчетИсточник) И ЗначениеЗаполнено(Объект.СчетПолучатель) И Объект.Сумма > 0 Тогда
		
		Строки.Добавить("<div class=""info"">");
		Строки.Добавить("<div class=""info-ico"">" + SVGИнфо() + "</div>");
		Строки.Добавить("<div class=""info-body"">");
		Строки.Добавить("<div class=""info-title"">После перевода:</div>");
		Строки.Добавить("<div class=""info-row""><span>" + ЭкранироватьHTML(ИмяИсточник) + "</span><span>"
			+ ОстатокИсточникПослеТекст + "</span></div>");
		Строки.Добавить("<div class=""info-row""><span>" + ЭкранироватьHTML(ИмяПолучатель) + "</span><span>"
			+ ОстатокПолучательПослеТекст + "</span></div>");
		Строки.Добавить("</div></div>");
		
	КонецЕсли;
	
	Строки.Добавить("<div class=""actions"">");
	Строки.Добавить("<a class=""submit"" href=""app:submit"">" + SVGОтправить() + "<span>Перевести "
		+ КнопкаСуммы + "</span></a>");
	Строки.Добавить("</div>");
	
	Строки.Добавить(HTMLНижняяНавигация());
	Строки.Добавить("</body></html>");
	
	Возврат СтрСоединить(Строки, Символы.ПС);
	
КонецФункции

&НаСервере
Функция HTMLКарточкаСчета(Команда, ФонИконки, ЦветИконки, SVG, Имя, Подпись, ОстатокТекст)
	
	Возврат "<a class=""card account"" href=""app:" + Команда + """>"
		+ "<span class=""acc-ico"" style=""background:" + ФонИконки + ";color:" + ЦветИконки + """>" + SVG + "</span>"
		+ "<span class=""acc-mid""><span class=""acc-name"">" + ЭкранироватьHTML(Имя) + "</span>"
		+ "<span class=""acc-sub"">" + ЭкранироватьHTML(Подпись) + "</span></span>"
		+ "<span class=""acc-right""><span class=""acc-sum"">" + ОстатокТекст + "</span>"
		+ "<span class=""chev"">▾</span></span></a>";
	
КонецФункции

&НаСервере
Функция ПредставлениеВидаСчета(ВидСчета)
	
	Если ВидСчета = Перечисления.ВидСчета.Кошелек Тогда
		
		Возврат "Наличные";
		
	ИначеЕсли ВидСчета = Перечисления.ВидСчета.БанковскаяКарта Тогда
		
		Возврат "Банковская карта";
		
	ИначеЕсли ВидСчета = Перечисления.ВидСчета.БанковскийСчет Тогда
		
		Возврат "Банковский счёт";
		
	КонецЕсли;
	
	Возврат "Счёт";
	
КонецФункции

&НаСервере
Функция СтилиФормыПеревода()
	
	Возврат "*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}"
		+ "body{font-family:-apple-system,BlinkMacSystemFont,""Segoe UI"",Roboto,Arial,sans-serif;background:#FAFAFA;color:#111827;padding:12px 16px 160px;line-height:1.3}"
		+ "a{text-decoration:none;color:inherit}"
		+ ".top{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px}"
		+ ".title{font-size:18px;font-weight:700;color:#111827}"
		+ ".icon-btn{width:36px;height:36px;border-radius:50%;background:#F3F4F6;display:flex;align-items:center;justify-content:center;color:#6B7280}"
		+ ".lbl{font-size:12px;font-weight:600;color:#6B7280;margin:0 0 6px 2px}"
