&НаСервере
Функция HTMLНижняяНавигация()
	
	Возврат "<nav class=""nav"">"
		+ "<a class=""active"" href=""app:home""><span class=""ico"">" + SVGДом() + "</span>Главная</a>"
		+ "<a href=""app:operations""><span class=""ico"">" + SVGОперации() + "</span>Операции</a>"
		+ "<a href=""app:reports""><span class=""ico"">" + SVGДиаграмма() + "</span>Отчёты</a>"
		+ "<a href=""app:catalogs""><span class=""ico"">" + SVGПапка() + "</span>Справочники</a>"
		+ "<a href=""app:settings""><span class=""ico"">" + SVGНастройки() + "</span>Настройки</a>"
		+ "</nav>";
	
КонецФункции

&НаСервере
Функция ЭкранироватьHTML(Знач Текст)
	
	Результат = Строка(Текст);
	Результат = СтрЗаменить(Результат, "&", "&amp;");
	Результат = СтрЗаменить(Результат, "<", "&lt;");
	Результат = СтрЗаменить(Результат, ">", "&gt;");
	Результат = СтрЗаменить(Результат, """", "&quot;");
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Функция ИзвлечьКомандуИзСсылки(Знач АдресСсылки)
	
	Если Не ЗначениеЗаполнено(АдресСсылки) Тогда
		
		Возврат "";
		
	КонецЕсли;
	
	АдресСсылки = СокрЛП(АдресСсылки);
	Префикс = "app:";
	Позиция = СтрНайти(НРег(АдресСсылки), Префикс);
	
	Если Позиция = 0 Тогда
		
		Возврат "";
		
	КонецЕсли;
	
	Возврат Сред(АдресСсылки, Позиция + СтрДлина(Префикс));
	
КонецФункции

