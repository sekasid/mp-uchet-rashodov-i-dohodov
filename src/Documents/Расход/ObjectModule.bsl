////////////////////////////////////////////////////////////////////////////////
// Модуль объекта документа Расход.
// Валидация реквизитов при записи и формирование движений по регистрам Расходы и Баланс.
// Сумма в регистрах — в валюте учёта; ВалютнаяСумма — в валюте операции.
////////////////////////////////////////////////////////////////////////////////

#Область ОбработчикиСобытий

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	
	Если ОбменДанными.Загрузка Тогда
		
		Возврат;
		
	КонецЕсли;
	
	Если РежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения Тогда
		
		Возврат;
		
	КонецЕсли;
	
	ПроверитьРеквизитыДокумента(Отказ);
	
	Если Не Отказ Тогда
		
		ПроверитьКурсВалютыОперации(Отказ);
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)
	
	// Сумма проверяется отдельно: fillChecking считает 0 незаполненным,
	// но для отрицательных значений нужна явная проверка «больше нуля».
	ИндексСуммы = ПроверяемыеРеквизиты.Найти("Сумма");
	
	Если ИндексСуммы <> Неопределено Тогда
		
		ПроверяемыеРеквизиты.Удалить(ИндексСуммы);
		
	КонецЕсли;
	
	Если Сумма <= 0 Тогда
		
		Отказ = Истина;
		СообщитьОшибкуЗаполнения("Сумма расхода должна быть больше нуля.", "Сумма");
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, РежимПроведения)
	
	СуммаУчета = ОбщийМодульСервер_КурсыВалют.СуммаВВалютеУчета(Сумма, Валюта, Дата);
	
	// регистр Расходы
	Движения.Расходы.Записывать = Истина;
	Движение = Движения.Расходы.Добавить();
	Движение.Период = Дата;
	Движение.КатегорияРасходов = КатегорияРасхода;
	Движение.Валюта = Валюта;
	Движение.Сумма = СуммаУчета;
	Движение.ВалютнаяСумма = Сумма;
	
	// регистр Баланс — расход уменьшает остаток по счёту
	Движения.Баланс.Записывать = Истина;
	Движение = Движения.Баланс.Добавить();
	Движение.ВидДвижения = ВидДвиженияНакопления.Расход;
	Движение.Период = Дата;
	Движение.Валюта = Валюта;
	Движение.Счета = Счет;
	Движение.Сумма = СуммаУчета;
	Движение.ВалютнаяСумма = Сумма;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Проверяет обязательные реквизиты документа независимо от способа создания
// (стандартная форма, быстрый ввод, программная запись).
//
Процедура ПроверитьРеквизитыДокумента(Отказ)
	
	Если Не ЗначениеЗаполнено(Дата) Тогда
		
		Отказ = Истина;
		СообщитьОшибкуЗаполнения("Не заполнена дата.", "Дата");
		
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Счет) Тогда
		
		Отказ = Истина;
		СообщитьОшибкуЗаполнения("Не заполнен счет.", "Счет");
		
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Валюта) Тогда
		
		Отказ = Истина;
		СообщитьОшибкуЗаполнения("Не заполнена валюта.", "Валюта");
		
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(КатегорияРасхода) Тогда
		
		Отказ = Истина;
		СообщитьОшибкуЗаполнения("Не заполнена категория расходов.", "КатегорияРасхода");
		
	КонецЕсли;
	
	Если Сумма <= 0 Тогда
		
		Отказ = Истина;
		СообщитьОшибкуЗаполнения("Сумма расхода должна быть больше нуля.", "Сумма");
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ПроверитьКурсВалютыОперации(Отказ)
	
	ВалютаУчета = Константы.ВалютаУчета.Получить();
	
	Если Валюта = ВалютаУчета Тогда
		
		Возврат;
		
	КонецЕсли;
	
	Если ОбщийМодульСервер_КурсыВалют.ПолучитьДанныеКурса(Валюта, Дата) = Неопределено Тогда
		
		Отказ = Истина;
		СообщитьОшибкуЗаполнения(ОбщийМодульСервер_КурсыВалют.ТекстСообщенияОбОтсутствииКурса(Валюта, Дата), "Валюта");
		
	КонецЕсли;
	
КонецПроцедуры

Процедура СообщитьОшибкуЗаполнения(ТекстСообщения, ИмяПоля)
	
	Сообщение = Новый СообщениеПользователю;
	Сообщение.Текст = ТекстСообщения;
	Сообщение.Поле = ИмяПоля;
	Сообщение.УстановитьДанные(ЭтотОбъект);
	Сообщение.Сообщить();
	
КонецПроцедуры

#КонецОбласти
