////////////////////////////////////////////////////////////////////////////////
// Форма документа ПередачаСредствВДолг.
// HTML-интерфейс «Долги» по макету Wallet.
////////////////////////////////////////////////////////////////////////////////

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Ключ.Пустая() Тогда
		
		Объект.Дата = ТекущаяДата();
		Объект.Валюта = ОбщийМодульСервер_СистемныеНастройки.ПолучитьВалютуРегламентированногоУчета();
		Объект.ВидОперации = Перечисления.ВидОперацииДолга.ДаюВДолг;
		Объект.ТипОперации = Перечисления.ТипОперацииДолга.ВыдачаДенег;
		ЗаполнитьСчетПоУмолчанию();
		
	Иначе
		
		ДозаполнитьТипОперацииДляСтарыхДокументов();
		
	КонецЕсли;
	
	Заголовок = "Долги";
	ОбновитьHTMLНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия <> "ВыборДаты" Тогда
		
		Возврат;
		
	КонецЕсли;
	
	Если ТипЗнч(Параметр) <> Тип("Структура") Тогда
		
		Возврат;
		
	КонецЕсли;
	
	Если РежимВыбораДаты = "due" Тогда
		
		Объект.СрокВозврата = НачалоДня(Параметр.Период);
		
	Иначе
		
		Если ЗначениеЗаполнено(Параметр.Время) Тогда
			
			Часов = Час(Параметр.Время);
			Минут = Минута(Параметр.Время);
			Секунд = Секунда(Параметр.Время);
			ВсегоСекунд = Часов * 3600 + Минут * 60 + Секунд;
			
		Иначе
			
			ВсегоСекунд = 0;
			
		КонецЕсли;
		
		Объект.Дата = Параметр.Период + ВсегоСекунд;
		
	КонецЕсли;
	
	ОбновитьHTMLНаСервере();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовФормы

&НаКлиенте
Процедура ПолеHTMLПриНажатии(Элемент, ДанныеСобытия, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	КомандаПриложения = ИзвлечьКомандуИзСсылки(ДанныеСобытия.Href);
	
	Если Не ЗначениеЗаполнено(КомандаПриложения) Тогда
		
		Возврат;
		
	КонецЕсли;
	
	ОбработатьКомандуHTML(КомандаПриложения);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ОбработатьКомандуHTML(КомандаПриложения)
	
	Если КомандаПриложения = "back" Тогда
		
		Закрыть();
		
	ИначеЕсли КомандаПриложения = "dir:owe" Тогда
		
		Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидОперацииДолга.БеруВДолг");
		ОбновитьHTMLНаСервере();
		
	ИначеЕсли КомандаПриложения = "dir:owed" Тогда
		
		Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидОперацииДолга.ДаюВДолг");
		ОбновитьHTMLНаСервере();
		
	ИначеЕсли КомандаПриложения = "op:issue" Тогда
		
		Объект.ТипОперации = ПредопределенноеЗначение("Перечисление.ТипОперацииДолга.ВыдачаДенег");
		ОбновитьHTMLНаСервере();
		
	ИначеЕсли КомандаПриложения = "op:return" Тогда
		
		Объект.ТипОперации = ПредопределенноеЗначение("Перечисление.ТипОперацииДолга.ВозвратДенег");
		ОбновитьHTMLНаСервере();
		
	ИначеЕсли КомандаПриложения = "edit-sum" Тогда
		
		НачатьВводСуммы();
		
	ИначеЕсли КомандаПриложения = "contact" Тогда
		
		НачатьВыборКонтакта();
		
	ИначеЕсли КомандаПриложения = "account" Тогда
		
		НачатьВыборСчета();
		
	ИначеЕсли КомандаПриложения = "date" Тогда
		
		НачатьВыборДаты("date");
		
	ИначеЕсли КомандаПриложения = "due" Тогда
		
		НачатьВыборДаты("due");
		
	ИначеЕсли КомандаПриложения = "edit-comment" Тогда
		
		НачатьВводКомментария();
		
	ИначеЕсли КомандаПриложения = "submit" Тогда
		
		ЗаписатьДокументДолга();
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура НачатьВводСуммы()
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ПослеВводаСуммы", ЭтотОбъект);
	РежимЦвета = ?(Объект.ТипОперации = ПредопределенноеЗначение("Перечисление.ТипОперацииДолга.ВозвратДенег"),
		"income", "expense");
	ОбщийМодульКлиент.ПоказатьВводСуммы(ОписаниеОповещения, Объект.Сумма, "Сумма операции", РежимЦвета);
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеВводаСуммы(Число, ДополнительныеПараметры) Экспорт
	
	Если Число = Неопределено Тогда
		
		Возврат;
		
	КонецЕсли;
	
	Если Число < 0 Тогда
		
		Число = 0;
		
	КонецЕсли;
	
	Объект.Сумма = Число;
	ОбновитьHTMLНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура НачатьВыборКонтакта()
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("РежимВыбора", Истина);
	
	Если ЗначениеЗаполнено(Объект.Контакт) Тогда
		
		ПараметрыФормы.Вставить("ТекущаяСтрока", Объект.Контакт);
		
	КонецЕсли;
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ПослеВыбораКонтакта", ЭтотОбъект);
	ОткрытьФорму("Справочник.Контакты.ФормаВыбора", ПараметрыФормы, ЭтотОбъект, , , , ОписаниеОповещения,
		РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеВыбораКонтакта(ВыбранныйКонтакт, ДополнительныеПараметры) Экспорт
	
	Если ВыбранныйКонтакт = Неопределено Тогда
		
		Возврат;
		
	КонецЕсли;
	
	Объект.Контакт = ВыбранныйКонтакт;
	ОбновитьHTMLНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура НачатьВыборСчета()
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ПослеВыбораСчета", ЭтотОбъект);
	ОбщийМодульКлиент.ПоказатьВыборСчета(ОписаниеОповещения, Объект.Счет, "Счет");
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеВыбораСчета(ВыбранныйСчет, ДополнительныеПараметры) Экспорт
	
	Если ВыбранныйСчет = Неопределено Тогда
		
		Возврат;
		
	КонецЕсли;
	
	Объект.Счет = ВыбранныйСчет;
	ОбновитьHTMLНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура НачатьВыборДаты(Режим)
	
	РежимВыбораДаты = Режим;
	ПараметрыКалендаря = Новый Структура;
	ПараметрыКалендаря.Вставить("ТолькоДата", Истина);
	
	Если Режим = "due" Тогда
		
		Если ЗначениеЗаполнено(Объект.СрокВозврата) Тогда
			
			ПараметрыКалендаря.Вставить("Дата", Объект.СрокВозврата);
			
		КонецЕсли;
		
	ИначеЕсли ЗначениеЗаполнено(Объект.Дата) Тогда
		
		ПараметрыКалендаря.Вставить("Дата", Объект.Дата);
		
	КонецЕсли;
	
	ОткрытьФорму("ОбщаяФорма.ФормаКалендаря", ПараметрыКалендаря, ЭтотОбъект, , , , ,
		РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
	
КонецПроцедуры

&НаКлиенте
Процедура НачатьВводКомментария()
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ПослеВводаКомментария", ЭтотОбъект);
	ОбщийМодульКлиент.ПоказатьВводТекста(ОписаниеОповещения, Объект.Комментарий, "Комментарий", 200);
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеВводаКомментария(Строка, ДополнительныеПараметры) Экспорт
	
	Если Строка = Неопределено Тогда
		
		Возврат;
		
	КонецЕсли;
	
	Объект.Комментарий = Лев(Строка, 200);
	ОбновитьHTMLНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаписатьДокументДолга()
	
	Если Не ЗначениеЗаполнено(Объект.ВидОперации) Тогда
		
		ПоказатьПредупреждение(, "Выберите тип долга.");
		Возврат;
		
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Объект.ТипОперации) Тогда
		
		ПоказатьПредупреждение(, "Выберите тип операции.");
		Возврат;
		
	КонецЕсли;
	
	Если Объект.Сумма <= 0 Тогда
		
		ПоказатьПредупреждение(, "Укажите сумму операции больше нуля.");
		Возврат;
		
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Объект.Контакт) Тогда
		
		ПоказатьПредупреждение(, "Выберите контакт.");
		Возврат;
		
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Объект.Счет) Тогда
		
		ПоказатьПредупреждение(, "Выберите счёт.");
		Возврат;
		
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Объект.Валюта) Тогда
		
		Объект.Валюта = ПолучитьВалютуУчетаНаСервере();
		
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Объект.Дата) Тогда
		
		Объект.Дата = ТекущаяДата();
		
	КонецЕсли;
	
	// Запись из OnClick HTML на мобильном клиенте надёжнее через отложенный вызов.
	ПодключитьОбработчикОжидания("ВыполнитьЗаписьДокументаДолга", 0.1, Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура ВыполнитьЗаписьДокументаДолга()
	
	ТекстОшибки = ЗаписатьИПровестиНаСервере();
	
	Если ПустаяСтрока(ТекстОшибки) Тогда
		
		Закрыть(Истина);
		
	Иначе
		
		ПоказатьПредупреждение(, ТекстОшибки);
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ЗаписатьИПровестиНаСервере()
	
	Если Не ЗначениеЗаполнено(Объект.Валюта) Тогда
		
		Объект.Валюта = ОбщийМодульСервер_СистемныеНастройки.ПолучитьВалютуРегламентированногоУчета();
		
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Объект.Дата) Тогда
		
		Объект.Дата = ТекущаяДата();
		
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Объект.ВидОперации) Тогда
		
		Возврат "Выберите тип долга.";
		
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Объект.ТипОперации) Тогда
		
		Возврат "Выберите тип операции.";
		
	КонецЕсли;
	
	Если Объект.Сумма <= 0 Тогда
		
		Возврат "Укажите сумму операции больше нуля.";
		
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Объект.Контакт) Тогда
		
		Возврат "Выберите контакт.";
		
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Объект.Счет) Тогда
		
		Возврат "Выберите счёт.";
		
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Объект.Валюта) Тогда
		
		Возврат "Не заполнена валюта учёта.";
		
	КонецЕсли;
	
	ДокументОбъект = РеквизитФормыВЗначение("Объект");
	ДокументОбъект.Записать(РежимЗаписиДокумента.Проведение);
	ЗначениеВРеквизитФормы(ДокументОбъект, "Объект");
	
	Возврат "";
	
КонецФункции

&НаСервереБезКонтекста
Функция ПолучитьВалютуУчетаНаСервере()
	
	Возврат ОбщийМодульСервер_СистемныеНастройки.ПолучитьВалютуРегламентированногоУчета();
	
КонецФункции

&НаСервере
Процедура ОбновитьHTMLНаСервере()
	
	ТекстHTML = СобратьHTMLФормыДолга();
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСчетПоУмолчанию()
	
	Если ЗначениеЗаполнено(Объект.Счет) Тогда
		
		Возврат;
		
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Кошелек.Ссылка КАК Счет
	|ИЗ
	|	Справочник.Счета КАК Кошелек
	|ГДЕ
	|	НЕ Кошелек.ПометкаУдаления
	|
	|УПОРЯДОЧИТЬ ПО
	|	Кошелек.Наименование";
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		
		Объект.Счет = Выборка.Счет;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ДозаполнитьТипОперацииДляСтарыхДокументов()
	
	Если ЗначениеЗаполнено(Объект.ТипОперации) Тогда
		
		Возврат;
		
	КонецЕсли;
	
	Если Объект.ВидОперации = Перечисления.ВидОперацииДолга.БеруВДолг Тогда
		
		Объект.ТипОперации = Перечисления.ТипОперацииДолга.ВозвратДенег;
		
	Иначе
		
		Объект.ТипОперации = Перечисления.ТипОперацииДолга.ВыдачаДенег;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция СобратьHTMLФормыДолга()
	
	МнеДолжны = (Объект.ВидОперации = Перечисления.ВидОперацииДолга.ДаюВДолг);
	ВозвратДенег = (Объект.ТипОперации = Перечисления.ТипОперацииДолга.ВозвратДенег);
	ЦветСуммы = ?(ВозвратДенег, "#16A34A", "#DC2626");
	
	СуммаТекст = ОбщийМодульСервер_КурсыВалют.ПредставлениеСуммыВВалютеУчетаДляHTML(Объект.Сумма, Ложь);
	
	Если Объект.Сумма <= 0 Тогда
		
		СуммаТекст = "0&nbsp;" + ЭкранироватьHTML(ОбщийМодульСервер_КурсыВалют.СимволВалюты(
			ОбщийМодульСервер_СистемныеНастройки.ПолучитьВалютуРегламентированногоУчета()));
		
	КонецЕсли;
	
	ИмяКонтакта = ?(ЗначениеЗаполнено(Объект.Контакт), Строка(Объект.Контакт), "Выберите контакт");
	КлассКонтакта = ?(ЗначениеЗаполнено(Объект.Контакт), "", "placeholder");
	ИмяСчета = ?(ЗначениеЗаполнено(Объект.Счет), Строка(Объект.Счет), "Выберите счёт");
	КлассСчета = ?(ЗначениеЗаполнено(Объект.Счет), "", "placeholder");
	
	ТекстДаты = ?(ЗначениеЗаполнено(Объект.Дата), Формат(Объект.Дата, "ДФ=dd.MM.yyyy"), "Выберите дату");
	КлассДаты = ?(ЗначениеЗаполнено(Объект.Дата), "", "placeholder");
	ТекстСрока = ?(ЗначениеЗаполнено(Объект.СрокВозврата), Формат(Объект.СрокВозврата, "ДФ=dd.MM.yyyy"), "Укажите срок");
	КлассСрока = ?(ЗначениеЗаполнено(Объект.СрокВозврата), "", "placeholder");
	
	Комментарий = СокрЛП(Объект.Комментарий);
	ТекстКомментария = ?(ПустаяСтрока(Комментарий), "Добавить комментарий", Комментарий);
	КлассКомментария = ?(ПустаяСтрока(Комментарий), "placeholder", "");
	
	МожноЗаписать = ЗначениеЗаполнено(Объект.ВидОперации)
		И ЗначениеЗаполнено(Объект.ТипОперации)
		И Объект.Сумма > 0
		И ЗначениеЗаполнено(Объект.Контакт)
		И ЗначениеЗаполнено(Объект.Счет);
	КлассКнопки = "submit";
	ПодписьКнопки = ?(МожноЗаписать, "Записать", "Заполнить обязательные поля");
	
	Строки = Новый Массив;
	Строки.Добавить("<!DOCTYPE html><html lang=""ru""><head><meta charset=""utf-8"">");
	Строки.Добавить("<meta name=""viewport"" content=""width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no"">");
	Строки.Добавить("<style>" + СтилиФормыДолга() + "</style></head><body>");
	
	Строки.Добавить("<div class=""top"">");
	Строки.Добавить("<a class=""icon-btn"" href=""app:back"">" + SVGСтрелкаНазад() + "</a>");
	Строки.Добавить("<div class=""title"">Долги</div>");
	Строки.Добавить("<span class=""icon-btn ghost""></span></div>");
	
	Строки.Добавить("<div class=""seg"">");
	Строки.Добавить("<a class=""seg-item" + ?(Не МнеДолжны, " active", "") + """ href=""app:dir:owe"">Я должен</a>");
	Строки.Добавить("<a class=""seg-item" + ?(МнеДолжны, " active", "") + """ href=""app:dir:owed"">Мне должны</a>");
	Строки.Добавить("</div>");
	
	Строки.Добавить("<div class=""card"">");
	Строки.Добавить("<div class=""card-title"">Тип операции</div>");
	Строки.Добавить("<div class=""seg inner"">");
	Строки.Добавить("<a class=""seg-item" + ?(Не ВозвратДенег, " active", "") + """ href=""app:op:issue"">Выдача денег</a>");
	Строки.Добавить("<a class=""seg-item" + ?(ВозвратДенег, " active", "") + """ href=""app:op:return"">Возврат денег</a>");
	Строки.Добавить("</div></div>");
	
	Строки.Добавить("<a class=""amount-block"" href=""app:edit-sum"">");
	Строки.Добавить("<div class=""amount"" style=""color:" + ЦветСуммы + """>" + СуммаТекст + "</div>");
	Строки.Добавить("<div class=""amount-lbl"">Сумма операции</div></a>");
	
	Строки.Добавить(HTMLПоле("contact", "Контакт", ИмяКонтакта, КлассКонтакта, SVGКонтакт()));
	Строки.Добавить(HTMLПоле("account", "Счет", ИмяСчета, КлассСчета, SVGКарта()));
	Строки.Добавить(HTMLПоле("date", "Дата", ТекстДаты, КлассДаты, SVGКалендарь()));
	Строки.Добавить(HTMLПоле("due", "Срок возврата", ТекстСрока, КлассСрока, SVGКалендарь()));
	
	Строки.Добавить("<a class=""field comment"" href=""app:edit-comment"">");
	Строки.Добавить("<div class=""field-lbl"">Комментарий</div>");
	Строки.Добавить("<div class=""field-val " + КлассКомментария + """>" + ЭкранироватьHTML(ТекстКомментария) + "</div>");
	Строки.Добавить("</a>");
	
	Строки.Добавить("<div class=""actions"">");
	Строки.Добавить("<a class=""" + КлассКнопки + """ href=""app:submit"">" + ПодписьКнопки + "</a>");
	Строки.Добавить("</div>");
	
	Строки.Добавить("</body></html>");
	
	Возврат СтрСоединить(Строки, Символы.ПС);
	
КонецФункции

&НаСервере
Функция HTMLПоле(Команда, Подпись, Значение, КлассЗначения, SVG)
	
	Возврат "<a class=""field"" href=""app:" + Команда + """>"
		+ "<div class=""field-mid""><div class=""field-lbl"">" + ЭкранироватьHTML(Подпись) + "</div>"
		+ "<div class=""field-val " + КлассЗначения + """>" + ЭкранироватьHTML(Значение) + "</div></div>"
		+ "<div class=""field-ico"">" + SVG + "</div></a>";
	
КонецФункции

