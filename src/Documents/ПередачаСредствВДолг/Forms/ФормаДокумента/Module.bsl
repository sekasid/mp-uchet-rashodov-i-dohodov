		+ "color:#6B7280}"
		+ ".seg-item.active{background:#2563EB;color:#fff;box-shadow:0 2px 8px rgba(37,99,235,0.25)}"
		+ ".card{background:#fff;border:1px solid #E5E7EB;border-radius:16px;padding:14px;margin-bottom:12px;"
		+ "box-shadow:0 1px 3px rgba(17,24,39,0.04)}"
		+ ".card-title{font-size:13px;font-weight:700;color:#6B7280;margin-bottom:10px}"
		+ ".amount-block{display:block;text-align:center;padding:18px 8px 20px}"
		+ ".amount{font-size:36px;font-weight:700;letter-spacing:-0.02em}"
		+ ".amount-lbl{margin-top:6px;font-size:13px;font-weight:600;color:#6B7280}"
		+ ".field{display:flex;align-items:center;background:#fff;border:1px solid #E5E7EB;border-radius:12px;"
