////////////////////////////////////////////////////////////////////////////////
// Форма обработки «Начальный экран».
// Сводка доходов/расходов, остатки по счетам, быстрый ввод и переход к отчётам.
////////////////////////////////////////////////////////////////////////////////

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ВалютаУчета = Константы.ВалютаУчета.Получить();
	
	Если ЗначениеЗаполнено(ВалютаУчета) Тогда
		
		Элементы.Декорация2.Заголовок = ВалютаУчета;
		Элементы.Декорация4.Заголовок = ВалютаУчета;
		
	КонецЕсли;
	
	ПодготовитьФормуНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ОбщийМодульКлиент.ИзменитьРазмерШрифтаЭлементов(ЭтаФорма);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ДобавитьРасход(Команда)
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ПослеЗакрытияФормыДокумента", ЭтотОбъект);
	ОткрытьФорму("ОбщаяФорма.ОбщаяФормаДокумента",
		Новый Структура("ВидОперации", ПолучитьВидОперации("Расход")),
		ЭтотОбъект, , , , ОписаниеОповещения);
	
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьДоход(Команда)
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ПослеЗакрытияФормыДокумента", ЭтотОбъект);
	ОткрытьФорму("ОбщаяФорма.ОбщаяФормаДокумента",
		Новый Структура("ВидОперации", ПолучитьВидОперации("Приход")),
		ЭтотОбъект, , , , ОписаниеОповещения);
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗакрытияФормыДокумента(Результат, ПараметрыРезультата) Экспорт
	
	Если Результат <> Истина Тогда
		
		Возврат;
		
	КонецЕсли;
	
	ПодготовитьФормуНаСервере();
	ОбщийМодульКлиент.ИзменитьРазмерШрифтаЭлементов(ЭтаФорма);
	
КонецПроцедуры

&НаКлиенте
Процедура СформироватьОтчетРасходы(Команда)
	
	ОткрытьФорму("Отчет.ОтчетПоРасходам.Форма");
	
КонецПроцедуры

&НаКлиенте
Процедура СформироватьОтчетПоДоходам(Команда)
	
	ОткрытьФорму("Отчет.ОтчетПоДоходам.Форма");
	
КонецПроцедуры

&НаКлиенте
Процедура СформироватьОтчетПоВзаиморасчетам(Команда)
	
	ПараметрыОтчета = Новый Структура;
	ПараметрыОтчета.Вставить("СформироватьПриОткрытии", Истина);
	ПараметрыОтчета.Вставить("Счет", ПустаяСсылкаСчета());
	ПараметрыОтчета.Вставить("НачалоПериода", НачалоДня(ТекущаяДата()));
	ПараметрыОтчета.Вставить("КонецПериода", КонецДня(ТекущаяДата()));
	
	ОткрытьФорму("Отчет.ОтчетПоВзаиморасчетам.Форма.ФормаОтчета", ПараметрыОтчета);
	
КонецПроцедуры

&НаКлиенте
Процедура ВернутьсяНаОсновнуюСтраницу(Команда)
	
	Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаСтраницаОсновная;
	
КонецПроцедуры

&НаКлиенте
Процедура ВоспроизвестиМузыку(Команда)
	
	ИмяМелодии = ВоспроизвестиМузыкуВозврат();
	
	#Если МобильноеПриложениеКлиент Тогда
	СредстваМультимедиа.ВоспроизвестиАудио(ИмяМелодии, , , Истина);
	#КонецЕсли
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовФормы

&НаКлиенте
Процедура ДекорацияСписокОтчетовНажатие(Элемент)
	
	Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаСтраницаОтчеты;
	
КонецПроцедуры

&НаКлиенте
Процедура ДекорацияВоспроизвестиМузыкуНажатие(Элемент)
	
	Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаМедиаПлеер;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаНавигационнойСсылки(Элемент, НавигационнаяСсылкаФорматированнойСтроки, СтандартнаяОбработка = Ложь)
	
	ПодсказкаНавигации = Элемент.Подсказка;
	
	Если Не ЗначениеЗаполнено(ПодсказкаНавигации) Тогда
		
		Возврат;
		
	КонецЕсли;
	
	ЧастиПодсказки = СтрРазделить(ПодсказкаНавигации, "|");
	
	Если ЧастиПодсказки.Количество() < 2 Тогда
		
		Возврат;
		
	КонецЕсли;
	
	ВидНавигации = ЧастиПодсказки[0];
	
	Если ВидНавигации = "Счет" Тогда
		
		ОткрытьОтчетПоСчету(ЧастиПодсказки[1]);
		
	ИначеЕсли ВидНавигации = "Расходы" Или ВидНавигации = "Доходы" Тогда
		
		ОткрытьОтчетПоПериоду(ВидНавигации, ЧастиПодсказки[1]);
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ПодготовитьФормуНаСервере()
	
	СформироватьДанныеПоРасходамДоходам("Расходы", "ГруппаДанныеРасходовЛево", "ГруппаДанныеРасходовПраво");
	СформироватьДанныеПоРасходамДоходам("Доходы", "ГруппаДанныеДоходовЛево", "ГруппаДанныеДоходовПраво");
	СформироватьСписокСчетов();
	
КонецПроцедуры

&НаСервере
Процедура СформироватьДанныеПоРасходамДоходам(ВидОперации, ИмяГруппаЛево, ИмяГруппаПраво)
	
	ОбщийМодульСервер.ОчиститьПодчиненныеЭлементыГруппы(ЭтотОбъект, ИмяГруппаЛево);
	ОбщийМодульСервер.ОчиститьПодчиненныеЭлементыГруппы(ЭтотОбъект, ИмяГруппаПраво);
	
	Запрос = Новый Запрос;
	Запрос.Текст = ПолучитьТекстЗапроса(ВидОперации);
	УстановитьПараметрыЗапроса(Запрос);
	Результат = Запрос.Выполнить();
	
	Если Результат.Пустой() Тогда
		
		Возврат;
		
	КонецЕсли;
	
	Выборка = Результат.Выбрать();
	
	Если Не Выборка.Следующий() Тогда
		
		Возврат;
		
	КонецЕсли;
	
	Для НомерПериода = 1 По 3 Цикл
		
		Если НомерПериода = 1 Тогда
			
			ИмяПериода = "Сегодня";
			Сумма = Выборка.Сегодня;
			
		ИначеЕсли НомерПериода = 2 Тогда
			
			ИмяПериода = "Неделя";
			Сумма = Выборка.Неделя;
			
		Иначе
			
			ИмяПериода = "Месяц";
			Сумма = Выборка.Месяц;
			
		КонецЕсли;
		
		Если Сумма = NULL Или Сумма = 0 Тогда
			
			Продолжить;
			
		КонецЕсли;
		
		ПодсказкаНавигации = ВидОперации + "|" + ИмяПериода;
		
		ОбщийМодульСервер.ДобавитьДекорациюНаФорму(ЭтотОбъект, "Декорация" + ВидОперации + ИмяПериода,
			ИмяПериода, ИмяГруппаЛево, Ложь, Истина, ПодсказкаНавигации);
		ОбщийМодульСервер.ДобавитьДекорациюНаФорму(ЭтотОбъект, "Декорация" + ВидОперации + ИмяПериода + "Сумма",
			Строка(Сумма), ИмяГруппаПраво, Ложь, Ложь, ПодсказкаНавигации);
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура СформироватьСписокСчетов()
	
	ОбщийМодульСервер.ОчиститьПодчиненныеЭлементыГруппы(ЭтотОбъект, "ГруппаСчета");
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Кошелек.Ссылка КАК СчетСсылка,
	|	Кошелек.Наименование КАК НаименованиеСчета,
	|	Кошелек.ВидСчета КАК ВидСчета,
	|	БалансОстатки.Валюта КАК Валюта,
	|	БалансОстатки.СуммаОстаток КАК Сумма
	|ИЗ
	|	Справочник.Счета КАК Кошелек
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.Баланс.Остатки(&Период, ) КАК БалансОстатки
	|		ПО БалансОстатки.Счета = Кошелек.Ссылка
	|
	|УПОРЯДОЧИТЬ ПО
	|	НаименованиеСчета,
	|	Валюта";
	Запрос.УстановитьПараметр("Период", ТекущаяДата());
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		КлючЭлемента = КлючЭлементаСчета(Выборка.СчетСсылка, Выборка.Валюта);
		ИмяГруппы = "Группа" + КлючЭлемента;
		ПодсказкаНавигации = "Счет|" + Строка(Выборка.СчетСсылка.УникальныйИдентификатор());
		ЗаголовокСчета = ЗаголовокСтрокиСчета(Выборка.НаименованиеСчета, Выборка.Валюта);
		ПредставлениеСуммы = ?(Выборка.Сумма = NULL, "0", Строка(Выборка.Сумма));
		
		ОбщийМодульСервер.ДобавитьГруппуНаФорму(ЭтотОбъект, ИмяГруппы, Выборка.НаименованиеСчета, "ГруппаСчета");
		ОбщийМодульСервер.ДобавитьКартинкуСчетаДекорации(ЭтотОбъект, "ДекорацияКартинка" + КлючЭлемента,
			ИмяГруппы, Выборка.ВидСчета);
		ОбщийМодульСервер.ДобавитьДекорациюНаФорму(ЭтотОбъект, "Декорация" + КлючЭлемента,
			ЗаголовокСчета, ИмяГруппы, Ложь, Истина, ПодсказкаНавигации);
		ОбщийМодульСервер.ДобавитьДекорациюНаФорму(ЭтотОбъект, "Декорация" + КлючЭлемента + "Сумма",
			ПредставлениеСуммы, ИмяГруппы, Ложь, Ложь, ПодсказкаНавигации);
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Функция КлючЭлементаСчета(СчетСсылка, Валюта)
	
	КлючСчета = ОбщийМодульСервер.ИдентификаторДляИмениЭлемента(СчетСсылка.УникальныйИдентификатор());
	
	Если ЗначениеЗаполнено(Валюта) Тогда
		
		КлючВалюты = ОбщийМодульСервер.ИдентификаторДляИмениЭлемента(Валюта.УникальныйИдентификатор());
		
	Иначе
		
		КлючВалюты = "0";
		
	КонецЕсли;
	
	Возврат "С" + КлючСчета + "В" + КлючВалюты;
	
КонецФункции

&НаСервере
Функция ЗаголовокСтрокиСчета(НаименованиеСчета, Валюта)
	
	Если ЗначениеЗаполнено(Валюта) Тогда
		
		Возврат НаименованиеСчета + " (" + Строка(Валюта) + ")";
		
	КонецЕсли;
	
	Возврат НаименованиеСчета;
	
КонецФункции

&НаСервере
Функция ПолучитьТекстЗапроса(ИмяРегистра)
	
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	СУММА(ОборотыРегистра.СуммаОборот) КАК Сегодня
	|ПОМЕСТИТЬ ВТ_Сегодня
	|ИЗ
	|	РегистрНакопления." + ИмяРегистра + ".Обороты(&НачалоДня, &КонецДня, , Валюта = &Валюта) КАК ОборотыРегистра
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СУММА(ОборотыРегистра.СуммаОборот) КАК Неделя
	|ПОМЕСТИТЬ ВТ_Неделя
	|ИЗ
	|	РегистрНакопления." + ИмяРегистра + ".Обороты(&НачалоНедели, &КонецНедели, , Валюта = &Валюта) КАК ОборотыРегистра
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СУММА(ОборотыРегистра.СуммаОборот) КАК Месяц
	|ПОМЕСТИТЬ ВТ_Месяц
	|ИЗ
	|	РегистрНакопления." + ИмяРегистра + ".Обороты(&НачалоМесяца, &КонецМесяца, , Валюта = &Валюта) КАК ОборотыРегистра
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Месяц.Месяц КАК Месяц,
	|	ВТ_Неделя.Неделя КАК Неделя,
	|	ВТ_Сегодня.Сегодня КАК Сегодня
	|ИЗ
	|	ВТ_Сегодня КАК ВТ_Сегодня
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_Неделя КАК ВТ_Неделя
	|		ПО (ИСТИНА)
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_Месяц КАК ВТ_Месяц
	|		ПО (ИСТИНА)";
	
	Возврат ТекстЗапроса;
	
КонецФункции

&НаСервере
Процедура УстановитьПараметрыЗапроса(Запрос)
	
	ТекущаяДатаСеанса = ТекущаяДата();
	Запрос.УстановитьПараметр("НачалоДня", НачалоДня(ТекущаяДатаСеанса));
	Запрос.УстановитьПараметр("КонецДня", КонецДня(ТекущаяДатаСеанса));
	Запрос.УстановитьПараметр("НачалоНедели", НачалоНедели(ТекущаяДатаСеанса));
	Запрос.УстановитьПараметр("КонецНедели", КонецНедели(ТекущаяДатаСеанса));
	Запрос.УстановитьПараметр("НачалоМесяца", НачалоМесяца(ТекущаяДатаСеанса));
	Запрос.УстановитьПараметр("КонецМесяца", КонецМесяца(ТекущаяДатаСеанса));
	Запрос.УстановитьПараметр("Валюта", ВалютаУчета);
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьОтчетПоПериоду(ИмяРегистра, ИмяПериода)
	
	ТекущаяДатаКлиента = ТекущаяДата();
	
	Если ИмяПериода = "Сегодня" Тогда
		
		НачалоПериода = НачалоДня(ТекущаяДатаКлиента);
		КонецПериода = КонецДня(ТекущаяДатаКлиента);
		
	ИначеЕсли ИмяПериода = "Неделя" Тогда
		
		НачалоПериода = НачалоНедели(ТекущаяДатаКлиента);
		КонецПериода = КонецНедели(ТекущаяДатаКлиента);
		
	ИначеЕсли ИмяПериода = "Месяц" Тогда
		
		НачалоПериода = НачалоМесяца(ТекущаяДатаКлиента);
		КонецПериода = КонецМесяца(ТекущаяДатаКлиента);
		
	Иначе
		
		Возврат;
		
	КонецЕсли;
	
	ПараметрыОтчета = Новый Структура;
	ПараметрыОтчета.Вставить("НачалоПериода", НачалоПериода);
	ПараметрыОтчета.Вставить("КонецПериода", КонецПериода);
	ПараметрыОтчета.Вставить("СформироватьПриОткрытии", Истина);
	
	Если ИмяРегистра = "Расходы" Тогда
		
		ОткрытьФорму("Отчет.ОтчетПоРасходам.Форма", ПараметрыОтчета);
		
	Иначе
		
		ОткрытьФорму("Отчет.ОтчетПоДоходам.Форма", ПараметрыОтчета);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьОтчетПоСчету(ИдентификаторСчетаСтрокой)
	
	Счет = НайтиСчетПоИдентификатору(ИдентификаторСчетаСтрокой);
	
	Если Не ЗначениеЗаполнено(Счет) Тогда
		
		Возврат;
		
	КонецЕсли;
	
	ПараметрыОтчета = Новый Структура;
	ПараметрыОтчета.Вставить("СформироватьПриОткрытии", Истина);
	ПараметрыОтчета.Вставить("Счет", Счет);
	ПараметрыОтчета.Вставить("НачалоПериода", НачалоДня(ТекущаяДата()));
	ПараметрыОтчета.Вставить("КонецПериода", КонецДня(ТекущаяДата()));
	
	ОткрытьФорму("Отчет.ОтчетПоВзаиморасчетам.Форма.ФормаОтчета", ПараметрыОтчета);
	
КонецПроцедуры

&НаСервере
Функция НайтиСчетПоИдентификатору(ИдентификаторСчетаСтрокой)
	
	Возврат Справочники.Счета.ПолучитьСсылку(Новый УникальныйИдентификатор(ИдентификаторСчетаСтрокой));
	
КонецФункции

&НаСервереБезКонтекста
Функция ПустаяСсылкаСчета()
	
	Возврат Справочники.Счета.ПустаяСсылка();
	
КонецФункции

&НаСервере
Функция ВоспроизвестиМузыкуВозврат()
	
	Возврат ОбщийМодульСервер.ПолучитьИмяЗвуковогоФайла("РингтонЗвонка");
	
КонецФункции

&НаСервере
Функция ПолучитьВидОперации(ВидОперации)
	
	Возврат Перечисления.ВидОперацииДокумента[ВидОперации];
	
КонецФункции

#КонецОбласти
