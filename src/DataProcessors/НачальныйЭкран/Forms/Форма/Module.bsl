&НаКлиенте
Процедура ПослеЗакрытияФормыДокумента(Результат, ПараметрыРезультата) Экспорт
	
	Если Результат <> Истина Тогда
		
		Возврат;
		
	КонецЕсли;
	
	ПодготовитьФормуНаСервере();
	
	ОбщийМодульКлиент.ИзменитьРазмерШрифтаЭлементов(ЭтаФорма);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаНавигационнойСсылки(Элемент, НавигационнаяСсылкаФорматированнойСтроки, СтандартнаяОбработка = Ложь)
	
	Если НЕ СтрНайти(Элемент.Подсказка, "Команда") Тогда
		ИмяРегистра = ?(СтрНайти(Элемент.Подсказка, "Расходы"), "Расходы", "Доходы");
		Период = СтрЗаменить(Элемент.Подсказка, ИмяРегистра, "");
		
		Если Период = "Сегодня" Тогда
			НачалоПериода 	= НачалоДня(ТекущаяДата());
			КонецПериода 	= КонецДня(ТекущаяДата());
		ИначеЕсли Период = "Неделя" Тогда
			НачалоПериода 	= НачалоНедели(ТекущаяДата());
			КонецПериода 	= КонецНедели(ТекущаяДата());
		ИначеЕсли Период = "Месяц" Тогда
			НачалоПериода 	= НачалоМесяца(ТекущаяДата());
			КонецПериода 	= КонецМесяца(ТекущаяДата());
		КонецЕсли;
		
		ПараметрыОтчета = Новый Структура;
		ПараметрыОтчета.Вставить("НачалоПериода", НачалоПериода);
		ПараметрыОтчета.Вставить("КонецПериода", КонецПериода);
		ПараметрыОтчета.Вставить("СформироватьПриОткрытии", Истина);
		
		Если ИмяРегистра = "Расходы" Тогда
			ОткрытьФорму("Отчет.ОтчетПоРасходам.Форма", ПараметрыОтчета);
		Иначе
			ОткрытьФорму("Отчет.ОтчетПоДоходам.Форма", ПараметрыОтчета);
		КонецЕсли;
	Иначе
		ИмяСчета = СтрЗаменить(Элемент.Подсказка, "Команда", "");
		Счет = НайтиСчетПоНаименованию(ИмяСчета);
		
		ПараметрыОтчета = Новый Структура;
		ПараметрыОтчета.Вставить("СформироватьПриОткрытии", Истина);
		ПараметрыОтчета.Вставить("Счет", Счет);
		ПараметрыОтчета.Вставить("НачалоПериода", НачалоДня(ТекущаяДата()));
		ПараметрыОтчета.Вставить("КонецПериода", КонецДня(ТекущаяДата()));
		
		ОткрытьФорму("Отчет.ОтчетПоВзаиморасчетам.Форма.ФормаОтчета", ПараметрыОтчета);
		
		
	КонецЕсли;
	
КонецПроцедуры

