	Строки.Добавить(".action.dolgi{background:#f3eaff;border-color:#e1bee7}");
	Строки.Добавить(".action.dolgi .label{color:#8e24aa}");
	Строки.Добавить(".card{background:#fff;border-radius:16px;padding:14px 16px;margin-bottom:14px;border:1px solid #eceff3}");
	Строки.Добавить(".card h2{font-size:16px;font-weight:700;margin-bottom:4px;color:#1c2430}");
	Строки.Добавить(".row{display:flex;align-items:center;justify-content:space-between;padding:12px 0;border-top:1px solid #eef1f4;gap:10px}");
	Строки.Добавить(".row:first-of-type{border-top:none}");
	Строки.Добавить(".row .name{font-size:15px;color:#3d4a5c;flex:1;min-width:0}");
	Строки.Добавить(".row .sum{font-size:15px;font-weight:600;white-space:nowrap}");
	Строки.Добавить(".row .sum.neg{color:#e53935}");
	Строки.Добавить(".row .sum.pos{color:#2e7d32}");
	Строки.Добавить(".row .sum.zero{color:#1c2430}");
	Строки.Добавить(".row .left{display:flex;align-items:center;gap:10px;flex:1;min-width:0}");
	Строки.Добавить(".row .ico-wrap{width:28px;height:28px;flex-shrink:0;display:flex;align-items:center;justify-content:center;color:#5b6573}");
	Строки.Добавить(".row .ico-wrap svg{display:block}");
	Строки.Добавить(".footer-note{margin-top:4px;padding-top:12px;border-top:1px solid #eef1f4;font-size:13px;font-weight:600}");
	Строки.Добавить(".footer-note.pos{color:#2e7d32}");
	Строки.Добавить(".footer-note.neg{color:#e53935}");
	Строки.Добавить(".footer-note.zero{color:#8b95a5}");
	Строки.Добавить(".empty{padding:8px 0;font-size:14px;color:#8b95a5}");
	Строки.Добавить(".nav{position:fixed;left:0;right:0;bottom:0;background:#fff;border-top:1px solid #e6ebf0;display:flex;padding:8px 8px calc(8px + env(safe-area-inset-bottom,0px));z-index:10}");
	Строки.Добавить(".nav a{flex:1;text-align:center;padding:6px 4px;color:#8b95a5;font-size:11px;font-weight:600}");
	Строки.Добавить(".nav .ico{height:22px;display:flex;align-items:center;justify-content:center;margin-bottom:4px}");
	Строки.Добавить(".nav .ico svg{display:block}");
	Строки.Добавить(".nav a.active{color:#1c2430}");
	Строки.Добавить("</style>");
	Строки.Добавить("</head>");
	Строки.Добавить("<body>");
	Строки.Добавить("<div class=""header"">");
	Строки.Добавить("<h1>Учёт</h1>");
	Строки.Добавить("<div class=""sub"">#Подзаголовок#</div>");
