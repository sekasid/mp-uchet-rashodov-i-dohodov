////////////////////////////////////////////////////////////////////////////////
// Форма элемента справочника Валюта (Wallet HTML).
////////////////////////////////////////////////////////////////////////////////

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Заголовок = "Валюта";
	ОбновитьHTMLНаСервере();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовФормы

&НаКлиенте
Процедура ПолеHTMLПриНажатии(Элемент, ДанныеСобытия, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	КомандаПриложения = ИзвлечьКомандуИзСсылки(ДанныеСобытия.Href);
	
	Если Не ЗначениеЗаполнено(КомандаПриложения) Или КомандаПриложения = "noop" Тогда
		
		Возврат;
		
	КонецЕсли;
	
	Если КомандаПриложения = "back" Тогда
		
		Закрыть();
		
	ИначеЕсли КомандаПриложения = "code" Тогда
		
		ОписаниеОповещения = Новый ОписаниеОповещения("ПослеВводаКода", ЭтотОбъект);
		ОбщийМодульКлиент.ПоказатьВводТекста(ОписаниеОповещения, Объект.Код, "Код валюты", 3);
		
	ИначеЕсли КомандаПриложения = "name" Тогда
		
		ОписаниеОповещения = Новый ОписаниеОповещения("ПослеВводаНаименования", ЭтотОбъект);
		ОбщийМодульКлиент.ПоказатьВводТекста(ОписаниеОповещения, Объект.Наименование, "Наименование", 25);
		
	ИначеЕсли КомандаПриложения = "save" Тогда
		
		ПодключитьОбработчикОжидания("ЗаписатьОтложенно", 0.05, Истина);
		
	ИначеЕсли КомандаПриложения = "delete" Тогда
		
		Если Объект.Предопределенный Тогда
			
			Возврат;
			
		КонецЕсли;
		
		ОписаниеОповещения = Новый ОписаниеОповещения("ПослеПодтвержденияУдаления", ЭтотОбъект);
		ПоказатьВопрос(ОписаниеОповещения, "Удалить валюту?", РежимДиалогаВопрос.ДаНет);
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ПослеВводаКода(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		
		Возврат;
		
	КонецЕсли;
	
	Объект.Код = ВРег(СокрЛП(Результат));
	ОбновитьHTMLНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеВводаНаименования(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		
		Возврат;
		
	КонецЕсли;
	
	Объект.Наименование = Результат;
	ОбновитьHTMLНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеПодтвержденияУдаления(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат <> КодВозвратаДиалога.Да Тогда
		
		Возврат;
		
	КонецЕсли;
	
	Если УдалитьНаСервере() Тогда
		
		Оповестить("ВалютыИзменены");
		Закрыть();
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаписатьОтложенно() Экспорт
	
	ТекстОшибки = ЗаписатьНаСервере();
	
	Если ЗначениеЗаполнено(ТекстОшибки) Тогда
		
		ПоказатьПредупреждение(, ТекстОшибки);
		Возврат;
		
	КонецЕсли;
	
	Оповестить("ВалютыИзменены");
	
	Если Открыта() Тогда
		
		Закрыть();
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ЗаписатьНаСервере()
	
	Если Не ЗначениеЗаполнено(Объект.Код) Тогда
		
		Возврат "Укажите код валюты";
		
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Объект.Наименование) Тогда
		
		Возврат "Укажите наименование";
		
	КонецЕсли;
	
	СправочникОбъект = РеквизитФормыВЗначение("Объект");
	СправочникОбъект.Записать();
	ЗначениеВРеквизитФормы(СправочникОбъект, "Объект");
	
	Возврат "";
	
КонецФункции

&НаСервере
Функция УдалитьНаСервере()
	
	Если Объект.Ссылка.Пустая() Тогда
		
		Возврат Истина;
		
	КонецЕсли;
	
	Объект.Ссылка.ПолучитьОбъект().УстановитьПометкуУдаления(Истина);
	
	Возврат Истина;
	
КонецФункции

&НаСервере
Процедура ОбновитьHTMLНаСервере()
	
	Данные = Новый Структура("Код, Наименование, Предопределенный", Объект.Код, Объект.Наименование, Объект.Предопределенный);
	ТекстHTML = ОбщийМодульСервер_СправочникиUI.HTMLЭлементаВалюты(Данные);
	
КонецПроцедуры

&НаКлиенте
Функция ИзвлечьКомандуИзСсылки(АдресСсылки)
	
	Если Не ЗначениеЗаполнено(АдресСсылки) Тогда
		
		Возврат "";
		
	КонецЕсли;
	
	Позиция = СтрНайти(НРег(АдресСсылки), "app:");
	
	Если Позиция = 0 Тогда
		
		Возврат "";
		
	КонецЕсли;
	
	Возврат Сред(АдресСсылки, Позиция + 4);
	
КонецФункции

#КонецОбласти
