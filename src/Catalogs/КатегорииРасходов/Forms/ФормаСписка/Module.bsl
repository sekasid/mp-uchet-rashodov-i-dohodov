////////////////////////////////////////////////////////////////////////////////
// Форма списка категорий расходов (Wallet HTML).
////////////////////////////////////////////////////////////////////////////////

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Заголовок = "Расходы";
	ОбновитьHTMLНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "КатегорииРасходовИзменены" Тогда
		
		ОбновитьHTMLНаСервере();
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовФормы

&НаКлиенте
Процедура ПолеHTMLПриНажатии(Элемент, ДанныеСобытия, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	КомандаПриложения = ИзвлечьКомандуИзСсылки(ДанныеСобытия.Href);
	
	Если Не ЗначениеЗаполнено(КомандаПриложения) Тогда
		
		Возврат;
		
	КонецЕсли;
	
	Если КомандаПриложения = "back" Тогда
		
		Если ЗначениеЗаполнено(ТекущийРодитель) Тогда
			
			ТекущийРодитель = РодительКатегорииНаСервере(ТекущийРодитель);
			СтрокаПоиска = "";
			ОбновитьHTMLНаСервере();
			
		Иначе
			
			Закрыть();
			
		КонецЕсли;
		
	ИначеЕсли КомандаПриложения = "add" Тогда
		
		ПараметрыФормы = Новый Структура;
		
		Если ЗначениеЗаполнено(ТекущийРодитель) Тогда
			
			ПараметрыФормы.Вставить("ЗначенияЗаполнения", Новый Структура("Родитель", ТекущийРодитель));
			
		КонецЕсли;
		
		ОткрытьФорму("Справочник.КатегорииРасходов.ФормаОбъекта", ПараметрыФормы, ЭтотОбъект, , , , ,
			РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
		
	ИначеЕсли КомандаПриложения = "search" Тогда
		
		ОписаниеОповещения = Новый ОписаниеОповещения("ПослеВводаПоиска", ЭтотОбъект);
		ОбщийМодульКлиент.ПоказатьВводТекста(ОписаниеОповещения, СтрокаПоиска, "Поиск категории", 100);
		
	ИначеЕсли СтрНачинаетсяС(КомандаПриложения, "folder:") Тогда
		
		ТекущийРодитель = ОбщийМодульСервер_Категории.КатегорияПоИдентификатору(Истина, Сред(КомандаПриложения, 8));
		СтрокаПоиска = "";
		ОбновитьHTMLНаСервере();
		
	ИначеЕсли СтрНачинаетсяС(КомандаПриложения, "open:") Тогда
		
		Категория = ОбщийМодульСервер_Категории.КатегорияПоИдентификатору(Истина, Сред(КомандаПриложения, 6));
		
		Если ЗначениеЗаполнено(Категория) Тогда
			
			ПараметрыФормы = Новый Структура("Ключ", Категория);
			ОткрытьФорму("Справочник.КатегорииРасходов.ФормаОбъекта", ПараметрыФормы, ЭтотОбъект, , , , ,
				РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ПослеВводаПоиска(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		
		Возврат;
		
	КонецЕсли;
	
	СтрокаПоиска = Результат;
	ОбновитьHTMLНаСервере();
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьHTMLНаСервере()
	
	ТекстHTML = ОбщийМодульСервер_Категории.HTMLСпискаКатегорий(Истина, СтрокаПоиска, ТекущийРодитель);
	
КонецПроцедуры

&НаСервере
Функция РодительКатегорииНаСервере(Категория)
	
	Возврат Категория.Родитель;
	
КонецФункции

&НаКлиенте
Функция ИзвлечьКомандуИзСсылки(АдресСсылки)
	
	Если Не ЗначениеЗаполнено(АдресСсылки) Тогда
		
		Возврат "";
		
	КонецЕсли;
	
	Позиция = СтрНайти(НРег(АдресСсылки), "app:");
	
	Если Позиция = 0 Тогда
		
		Возврат "";
		
	КонецЕсли;
	
	Возврат Сред(АдресСсылки, Позиция + 4);
	
КонецФункции

#КонецОбласти
