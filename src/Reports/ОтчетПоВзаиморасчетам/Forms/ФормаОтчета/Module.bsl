////////////////////////////////////////////////////////////////////////////////
// Форма отчёта по взаиморасчётам: применение параметров с начального экрана.
////////////////////////////////////////////////////////////////////////////////

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ПрименитьПараметрыОткрытия();
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ПрименитьПараметрыОткрытия()
	
	ПараметрыДанных = Отчет.КомпоновщикНастроек.Настройки.ПараметрыДанных;
	
	Если Параметры.Свойство("НачалоПериода") И ЗначениеЗаполнено(Параметры.НачалоПериода) Тогда
		
		УстановитьПараметрКомпоновки(ПараметрыДанных, "НачалоПериода", Параметры.НачалоПериода);
		
	КонецЕсли;
	
	Если Параметры.Свойство("КонецПериода") И ЗначениеЗаполнено(Параметры.КонецПериода) Тогда
		
		УстановитьПараметрКомпоновки(ПараметрыДанных, "КонецПериода", Параметры.КонецПериода);
		
	КонецЕсли;
	
	Если Параметры.Свойство("Счет") Тогда
		
		УстановитьПараметрКомпоновки(ПараметрыДанных, "Счет", Параметры.Счет);
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьПараметрКомпоновки(ПараметрыДанных, ИмяПараметра, ЗначениеПараметра)
	
	ЭлементПараметра = ПараметрыДанных.НайтиЗначениеПараметра(Новый ПараметрКомпоновкиДанных(ИмяПараметра));
	
	Если ЭлементПараметра = Неопределено Тогда
		
		Возврат;
		
	КонецЕсли;
	
	ЭлементПараметра.Использование = Истина;
	ЭлементПараметра.Значение = ЗначениеПараметра;
	
КонецПроцедуры

#КонецОбласти
