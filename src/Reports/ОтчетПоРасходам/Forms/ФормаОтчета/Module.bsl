////////////////////////////////////////////////////////////////////////////////
// Форма отчёта по расходам: мобильная аналитика по категориям.
// Расшифровка категории открывается в том же HTML (без отдельного окна).
////////////////////////////////////////////////////////////////////////////////

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Элементы.ГруппаПериод.Видимость = Ложь;
	РежимРасшифровки = Ложь;
	ИнициализироватьПараметрыОтчета();
	СформироватьОтчетНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия <> "ВыборДаты" Или ТипЗнч(Параметр) <> Тип("Структура") Тогда
		
		Возврат;
		
	КонецЕсли;
	
	Если Не Параметр.Свойство("Период") Или Не ЗначениеЗаполнено(Параметр.Период) Тогда
		
		Возврат;
		
	КонецЕсли;
	
	Если РежимВыбораДатыПериода = "Начало" Тогда
		
		НачалоПериода = НачалоДня(Параметр.Период);
		
		Если КонецПериода < НачалоПериода Тогда
			
			КонецПериода = НачалоПериода;
			
		КонецЕсли;
		
	ИначеЕсли РежимВыбораДатыПериода = "Конец" Тогда
		
		КонецПериода = НачалоДня(Параметр.Период);
		
		Если КонецПериода < НачалоПериода Тогда
			
			НачалоПериода = КонецПериода;
			
		КонецЕсли;
		
	Иначе
		
		Возврат;
		
	КонецЕсли;
	
	РежимВыбораДатыПериода = "";
	ВидПериода = "Период";
	СформироватьТекущуюСтраницуНаСервере();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовФормы

&НаКлиенте
Процедура ПолеHTMLПриНажатии(Элемент, ДанныеСобытия, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	КомандаПриложения = КомандаИзДанныхСобытия(ДанныеСобытия);
	
	Если Не ЗначениеЗаполнено(КомандаПриложения) Тогда
		
		Возврат;
		
	КонецЕсли;
	
	Если КомандаПриложения = "back" Тогда
		
		ВернутьсяКСпискуКатегорий();
		
	ИначеЕсли СтрНачинаетсяС(КомандаПриложения, "period:") Тогда
		
		УстановитьВидПериода(Сред(КомандаПриложения, СтрДлина("period:") + 1));
		
	ИначеЕсли КомандаПриложения = "date-start" Тогда
		
		ОткрытьВыборДатыПериода("Начало");
		
	ИначеЕсли КомандаПриложения = "date-end" Тогда
		
		ОткрытьВыборДатыПериода("Конец");
		
	ИначеЕсли СтрНачинаетсяС(КомандаПриложения, "category:") Тогда
		
		ПоказатьРасшифровкуКатегории(Сред(КомандаПриложения, СтрДлина("category:") + 1));
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ИнициализироватьПараметрыОтчета()
	
	Если Параметры.Свойство("НачалоПериода") И ЗначениеЗаполнено(Параметры.НачалоПериода)
		И Параметры.Свойство("КонецПериода") И ЗначениеЗаполнено(Параметры.КонецПериода) Тогда
		
		НачалоПериода = НачалоДня(Параметры.НачалоПериода);
		КонецПериода = НачалоДня(Параметры.КонецПериода);
		ВидПериода = ОбщийМодульСервер_Отчеты.ОпределитьВидПериода(НачалоПериода, КонецДня(КонецПериода));
		
	Иначе
		
		ВидПериода = "Месяц";
		ОбщийМодульСервер_Отчеты.УстановитьПериодПоВиду(ВидПериода, НачалоПериода, КонецПериода);
		НачалоПериода = НачалоДня(НачалоПериода);
		КонецПериода = НачалоДня(КонецПериода);
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура СформироватьОтчетНаСервере()
	
	РежимРасшифровки = Ложь;
	КатегорияРасшифровки = Справочники.КатегорииРасходов.ПустаяСсылка();
	Границы = ОбщийМодульСервер_Отчеты.ГраницыПериодаДляОтчета(НачалоПериода, КонецПериода);
	ТекстHTML = ОбщийМодульСервер_Отчеты.HTMLОтчетаПоКатегориям(Истина, Границы.Начало, Границы.Конец, ВидПериода);
	Заголовок = "Отчет по расходам";
	
КонецПроцедуры

&НаСервере
Процедура СформироватьРасшифровкуНаСервере()
	
	Границы = ОбщийМодульСервер_Отчеты.ГраницыПериодаДляОтчета(НачалоПериода, КонецПериода);
	ТекстHTML = ОбщийМодульСервер_Отчеты.HTMLРасшифровкиПоДням(
		Истина, КатегорияРасшифровки, Границы.Начало, Границы.Конец, ВидПериода);
	
	Если ЗначениеЗаполнено(КатегорияРасшифровки) Тогда
		
		Заголовок = Строка(КатегорияРасшифровки);
		
	Иначе
		
		Заголовок = "Прочее";
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура СформироватьТекущуюСтраницуНаСервере()
	
	Если РежимРасшифровки Тогда
		
		СформироватьРасшифровкуНаСервере();
		
	Иначе
		
		СформироватьОтчетНаСервере();
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьВидПериода(НовыйВидПериода)
	
	ВидПериода = НовыйВидПериода;
	УстановитьПериодИСформироватьНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьВыборДатыПериода(РежимВыбора)
	
	РежимВыбораДатыПериода = РежимВыбора;
	ПараметрыКалендаря = Новый Структура;
	ПараметрыКалендаря.Вставить("ТолькоДата", Истина);
	ПараметрыКалендаря.Вставить("Дата", ?(РежимВыбора = "Начало", НачалоПериода, КонецПериода));
	ОткрытьФорму("ОбщаяФорма.ФормаКалендаря", ПараметрыКалендаря, ЭтотОбъект, , , , ,
		РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
	
КонецПроцедуры

&НаСервере
Процедура УстановитьПериодИСформироватьНаСервере()
	
	Если ВидПериода <> "Период" Тогда
		
		ОбщийМодульСервер_Отчеты.УстановитьПериодПоВиду(ВидПериода, НачалоПериода, КонецПериода);
		НачалоПериода = НачалоДня(НачалоПериода);
		КонецПериода = НачалоДня(КонецПериода);
		
	КонецЕсли;
	
	СформироватьТекущуюСтраницуНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура ПоказатьРасшифровкуКатегории(ИдентификаторКатегории)
	
	ПоказатьРасшифровкуКатегорииНаСервере(ИдентификаторКатегории);
	
КонецПроцедуры

&НаСервере
Процедура ПоказатьРасшифровкуКатегорииНаСервере(ИдентификаторКатегории)
	
	КатегорияРасшифровки = КатегорияПоИдентификатору(ИдентификаторКатегории);
	РежимРасшифровки = Истина;
	СформироватьРасшифровкуНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура ВернутьсяКСпискуКатегорий()
	
	ВернутьсяКСпискуКатегорийНаСервере();
	
КонецПроцедуры

&НаСервере
Процедура ВернутьсяКСпискуКатегорийНаСервере()
	
	СформироватьОтчетНаСервере();
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция КатегорияПоИдентификатору(ИдентификаторКатегории)
	
	Если Не ЗначениеЗаполнено(ИдентификаторКатегории) Тогда
		
		Возврат Справочники.КатегорииРасходов.ПустаяСсылка();
		
	КонецЕсли;
	
	Возврат Справочники.КатегорииРасходов.ПолучитьСсылку(Новый УникальныйИдентификатор(ИдентификаторКатегории));
	
КонецФункции

&НаКлиенте
Функция КомандаИзДанныхСобытия(ДанныеСобытия)
	
	Если ДанныеСобытия = Неопределено Тогда
		
		Возврат "";
		
	КонецЕсли;
	
	Адрес = СокрЛП(Строка(ДанныеСобытия.Href));
	
	Если Не ЗначениеЗаполнено(Адрес) Тогда
		
		Адрес = СокрЛП(Строка(ДанныеСобытия.Anchor));
		
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Адрес) Тогда
		
		Возврат "";
		
	КонецЕсли;
	
	Маркер = "app:";
	Позиция = СтрНайти(Адрес, Маркер);
	
	Если Позиция = 0 Тогда
		
		Возврат "";
		
	КонецЕсли;
	
	КомандаПриложения = Сред(Адрес, Позиция + СтрДлина(Маркер));
	ПозицияПараметров = СтрНайти(КомандаПриложения, "?");
	
	Если ПозицияПараметров > 0 Тогда
		
		КомандаПриложения = Лев(КомандаПриложения, ПозицияПараметров - 1);
		
	КонецЕсли;
	
	ПозицияЯкоря = СтрНайти(КомандаПриложения, "#");
	
	Если ПозицияЯкоря > 0 Тогда
		
		КомандаПриложения = Лев(КомандаПриложения, ПозицияЯкоря - 1);
		
	КонецЕсли;
	
	Возврат КомандаПриложения;
	
КонецФункции

#КонецОбласти
