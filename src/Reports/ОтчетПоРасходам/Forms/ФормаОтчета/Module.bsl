////////////////////////////////////////////////////////////////////////////////
// Форма отчёта по расходам: мобильная аналитика по категориям.
////////////////////////////////////////////////////////////////////////////////

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ИнициализироватьПараметрыОтчета();
	СформироватьОтчетНаСервере();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовФормы

&НаКлиенте
Процедура ПолеHTMLПриНажатии(Элемент, ДанныеСобытия, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	КомандаПриложения = КомандаИзДанныхСобытия(ДанныеСобытия);
	
	Если Не ЗначениеЗаполнено(КомандаПриложения) Тогда
		
		Возврат;
		
	КонецЕсли;
	
	Если СтрНачинаетсяС(КомандаПриложения, "period:") Тогда
		
		УстановитьВидПериода(Сред(КомандаПриложения, СтрДлина("period:") + 1));
		
	ИначеЕсли СтрНачинаетсяС(КомандаПриложения, "category:") Тогда
		
		ОткрытьРасшифровкуКатегории(Сред(КомандаПриложения, СтрДлина("category:") + 1));
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ИнициализироватьПараметрыОтчета()
	
	Если Параметры.Свойство("НачалоПериода") И ЗначениеЗаполнено(Параметры.НачалоПериода)
		И Параметры.Свойство("КонецПериода") И ЗначениеЗаполнено(Параметры.КонецПериода) Тогда
		
		НачалоПериода = Параметры.НачалоПериода;
		КонецПериода = Параметры.КонецПериода;
		ВидПериода = ОбщийМодульСервер_Отчеты.ОпределитьВидПериода(НачалоПериода, КонецПериода);
		
	Иначе
		
		ВидПериода = "Месяц";
		ОбщийМодульСервер_Отчеты.УстановитьПериодПоВиду(ВидПериода, НачалоПериода, КонецПериода);
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура СформироватьОтчетНаСервере()
	
	ТекстHTML = ОбщийМодульСервер_Отчеты.HTMLОтчетаПоКатегориям(Истина, НачалоПериода, КонецПериода, ВидПериода);
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьВидПериода(НовыйВидПериода)
	
	ВидПериода = НовыйВидПериода;
	УстановитьПериодИСформироватьНаСервере();
	
КонецПроцедуры

&НаСервере
Процедура УстановитьПериодИСформироватьНаСервере()
	
	ОбщийМодульСервер_Отчеты.УстановитьПериодПоВиду(ВидПериода, НачалоПериода, КонецПериода);
	СформироватьОтчетНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьРасшифровкуКатегории(ИдентификаторКатегории)
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("ВидОперацииРасход", Истина);
	ПараметрыФормы.Вставить("Категория", КатегорияПоИдентификатору(ИдентификаторКатегории));
	ПараметрыФормы.Вставить("НачалоПериода", НачалоПериода);
	ПараметрыФормы.Вставить("КонецПериода", КонецПериода);
	ПараметрыФормы.Вставить("ВидПериода", ВидПериода);
	ПараметрыФормы.Вставить("СформироватьПриОткрытии", Истина);
	
	ОткрытьФорму("ОбщаяФорма.ФормаРасшифровкиКатегорииПоДням", ПараметрыФормы, ЭтотОбъект, , , , ,
		РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция КатегорияПоИдентификатору(ИдентификаторКатегории)
	
	Если Не ЗначениеЗаполнено(ИдентификаторКатегории) Тогда
		
		Возврат Справочники.КатегорииРасходов.ПустаяСсылка();
		
	КонецЕсли;
	
	Возврат Справочники.КатегорииРасходов.ПолучитьСсылку(Новый УникальныйИдентификатор(ИдентификаторКатегории));
	
КонецФункции

&НаКлиенте
Функция КомандаИзДанныхСобытия(ДанныеСобытия)
	
	Адрес = "";
	
	Если ТипЗнч(ДанныеСобытия) = Тип("Структура") Тогда
		
		Если ДанныеСобытия.Свойство("Href") Тогда
			
			Адрес = Строка(ДанныеСобытия.Href);
			
		ИначеЕсли ДанныеСобытия.Свойство("Anchor") Тогда
			
			Адрес = Строка(ДанныеСобытия.Anchor);
			
		КонецЕсли;
		
	КонецЕсли;
	
	Маркер = "app:";
	Позиция = СтрНайти(Адрес, Маркер);
	
	Если Позиция = 0 Тогда
		
		Возврат "";
		
	КонецЕсли;
	
	Возврат Сред(Адрес, Позиция + СтрДлина(Маркер));
	
КонецФункции

#КонецОбласти
