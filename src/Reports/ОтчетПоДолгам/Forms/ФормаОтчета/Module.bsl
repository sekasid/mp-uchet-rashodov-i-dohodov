////////////////////////////////////////////////////////////////////////////////
// Форма отчёта по долгам: остатки по контактам в стиле Wallet.
////////////////////////////////////////////////////////////////////////////////

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ФильтрДолгов = "all";
	РежимРасшифровки = Ложь;
	Заголовок = "Отчет по долгам";
	СформироватьОтчетНаСервере();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовФормы

&НаКлиенте
Процедура ПолеHTMLПриНажатии(Элемент, ДанныеСобытия, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	КомандаПриложения = КомандаИзДанныхСобытия(ДанныеСобытия);
	
	Если Не ЗначениеЗаполнено(КомандаПриложения) Тогда
		
		Возврат;
		
	КонецЕсли;
	
	Если КомандаПриложения = "back" Тогда
		
		Если РежимРасшифровки Тогда
			
			РежимРасшифровки = Ложь;
			КонтактРасшифровки = ПредопределенноеЗначение("Справочник.Контакты.ПустаяСсылка");
			СформироватьОтчетНаСервере();
			
		Иначе
			
			Закрыть();
			
		КонецЕсли;
		
	ИначеЕсли КомандаПриложения = "home"
		Или КомандаПриложения = "reports"
		Или КомандаПриложения = "menu" Тогда
		
		Оповестить("МобильнаяНавигация", КомандаПриложения);
		Закрыть();
		
	ИначеЕсли СтрНачинаетсяС(КомандаПриложения, "filter:") Тогда
		
		ФильтрДолгов = Сред(КомандаПриложения, СтрДлина("filter:") + 1);
		РежимРасшифровки = Ложь;
		СформироватьОтчетНаСервере();
		
	ИначеЕсли СтрНачинаетсяС(КомандаПриложения, "contact:") Тогда
		
		ПоказатьРасшифровкуКонтакта(Сред(КомандаПриложения, СтрДлина("contact:") + 1));
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура СформироватьОтчетНаСервере()
	
	Если РежимРасшифровки Тогда
		
		ТекстHTML = ОбщийМодульСервер_Отчеты.HTMLРасшифровкиДолгаПоКонтакту(КонтактРасшифровки);
		Заголовок = ?(ЗначениеЗаполнено(КонтактРасшифровки), Строка(КонтактРасшифровки), "Долг");
		
	Иначе
		
		ТекстHTML = ОбщийМодульСервер_Отчеты.HTMLОтчетаПоДолгам(ФильтрДолгов);
		Заголовок = "Отчет по долгам";
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПоказатьРасшифровкуКонтакта(ИдентификаторКонтакта)
	
	КонтактРасшифровки = КонтактПоИдентификатору(ИдентификаторКонтакта);
	
	Если Не ЗначениеЗаполнено(КонтактРасшифровки) Тогда
		
		Возврат;
		
	КонецЕсли;
	
	РежимРасшифровки = Истина;
	СформироватьОтчетНаСервере();
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция КонтактПоИдентификатору(ИдентификаторКонтакта)
	
	Если Не ЗначениеЗаполнено(ИдентификаторКонтакта) Тогда
		
		Возврат Справочники.Контакты.ПустаяСсылка();
		
	КонецЕсли;
	
	Возврат Справочники.Контакты.ПолучитьСсылку(Новый УникальныйИдентификатор(ИдентификаторКонтакта));
	
КонецФункции

&НаКлиенте
Функция КомандаИзДанныхСобытия(ДанныеСобытия)
	
	Если ДанныеСобытия = Неопределено Или Не ЗначениеЗаполнено(ДанныеСобытия.Href) Тогда
		
		Возврат "";
		
	КонецЕсли;
	
	АдресСсылки = СокрЛП(Строка(ДанныеСобытия.Href));
	Позиция = СтрНайти(НРег(АдресСсылки), "app:");
	
	Если Позиция = 0 Тогда
		
		Возврат "";
		
	КонецЕсли;
	
	Возврат Сред(АдресСсылки, Позиция + 4);
	
КонецФункции

#КонецОбласти
