////////////////////////////////////////////////////////////////////////////////
// Общая форма расшифровки категории по дням.
// Открывается из отчётов по доходам/расходам; документы не открывает.
////////////////////////////////////////////////////////////////////////////////

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Свойство("ВидОперацииРасход") Тогда
		
		ВидОперацииРасход = Параметры.ВидОперацииРасход;
		
	КонецЕсли;
	
	Если Параметры.Свойство("Категория") Тогда
		
		Категория = Параметры.Категория;
		
	КонецЕсли;
	
	Если Параметры.Свойство("НачалоПериода") И Параметры.Свойство("КонецПериода")
		И ЗначениеЗаполнено(Параметры.НачалоПериода) И ЗначениеЗаполнено(Параметры.КонецПериода) Тогда
		
		НачалоПериода = Параметры.НачалоПериода;
		КонецПериода = Параметры.КонецПериода;
		
		Если Параметры.Свойство("ВидПериода") И ЗначениеЗаполнено(Параметры.ВидПериода) Тогда
			
			ВидПериода = Параметры.ВидПериода;
			
		Иначе
			
			ВидПериода = ОбщийМодульСервер_Отчеты.ОпределитьВидПериода(НачалоПериода, КонецПериода);
			
		КонецЕсли;
		
	Иначе
		
		ВидПериода = "Месяц";
		ОбщийМодульСервер_Отчеты.УстановитьПериодПоВиду(ВидПериода, НачалоПериода, КонецПериода);
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Категория) Тогда
		
		Заголовок = Строка(Категория);
		
	Иначе
		
		Заголовок = "Прочее";
		
	КонецЕсли;
	
	СформироватьОтчетНаСервере();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовФормы

&НаКлиенте
Процедура ПолеHTMLПриНажатии(Элемент, ДанныеСобытия, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	КомандаПриложения = КомандаИзДанныхСобытия(ДанныеСобытия);
	
	Если СтрНачинаетсяС(КомандаПриложения, "period:") Тогда
		
		ВидПериода = Сред(КомандаПриложения, СтрДлина("period:") + 1);
		УстановитьПериодИСформироватьНаСервере();
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура СформироватьОтчетНаСервере()
	
	ТекстHTML = ОбщийМодульСервер_Отчеты.HTMLРасшифровкиПоДням(
		ВидОперацииРасход, Категория, НачалоПериода, КонецПериода, ВидПериода);
	
КонецПроцедуры

&НаСервере
Процедура УстановитьПериодИСформироватьНаСервере()
	
	ОбщийМодульСервер_Отчеты.УстановитьПериодПоВиду(ВидПериода, НачалоПериода, КонецПериода);
	СформироватьОтчетНаСервере();
	
КонецПроцедуры

&НаКлиенте
Функция КомандаИзДанныхСобытия(ДанныеСобытия)
	
	Адрес = "";
	
	Если ТипЗнч(ДанныеСобытия) = Тип("Структура") Тогда
		
		Если ДанныеСобытия.Свойство("Href") Тогда
			
			Адрес = Строка(ДанныеСобытия.Href);
			
		ИначеЕсли ДанныеСобытия.Свойство("Anchor") Тогда
			
			Адрес = Строка(ДанныеСобытия.Anchor);
			
		КонецЕсли;
		
	КонецЕсли;
	
	Маркер = "app:";
	Позиция = СтрНайти(Адрес, Маркер);
	
	Если Позиция = 0 Тогда
		
		Возврат "";
		
	КонецЕсли;
	
	Возврат Сред(Адрес, Позиция + СтрДлина(Маркер));
	
КонецФункции

#КонецОбласти
