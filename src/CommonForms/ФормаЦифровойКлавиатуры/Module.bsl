////////////////////////////////////////////////////////////////////////////////
// Общая форма цифровой клавиатуры Wallet.
// Режимы: сумма (1–9, 00, 0, запятая) и телефон (маска 9-999-999-99-99).
////////////////////////////////////////////////////////////////////////////////

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	РежимВвода = "сумма";
	ЗаголовокКлавиатуры = "Сумма";
	ЦветСуммы = "#2563EB";
	НачальнаяСумма = 0;
	СимволВалюты = "";
	ТекстВвода = "";
	
	Если Параметры.Свойство("РежимВвода") И ЗначениеЗаполнено(Параметры.РежимВвода) Тогда
		
		РежимВвода = НРег(Параметры.РежимВвода);
		
	КонецЕсли;
	
	Если Параметры.Свойство("Заголовок") И ЗначениеЗаполнено(Параметры.Заголовок) Тогда
		
		ЗаголовокКлавиатуры = Параметры.Заголовок;
		
	КонецЕсли;
	
	Если РежимВвода = "телефон" Тогда
		
		Если Не ЗначениеЗаполнено(ЗаголовокКлавиатуры) Или ЗаголовокКлавиатуры = "Сумма" Тогда
			
			ЗаголовокКлавиатуры = "Телефон";
			
		КонецЕсли;
		
		Если Параметры.Свойство("Телефон") Тогда
			
			ТекстВвода = ТолькоЦифрыТелефона(Параметры.Телефон);
			
		КонецЕсли;
		
	Иначе
		
		Если Параметры.Свойство("ЦветСуммы") И ЗначениеЗаполнено(Параметры.ЦветСуммы) Тогда
			
			ЦветСуммы = Параметры.ЦветСуммы;
			
		ИначеЕсли Параметры.Свойство("Режим") Тогда
			
			ЦветСуммы = ЦветПоРежиму(Параметры.Режим);
			
		КонецЕсли;
		
		Если Параметры.Свойство("Сумма") Тогда
			
			НачальнаяСумма = Параметры.Сумма;
			
		КонецЕсли;
		
		ВалютаУчета = Константы.ВалютаУчета.Получить();
		СимволВалюты = ОбщийМодульСервер_КурсыВалют.СимволВалюты(ВалютаУчета);
		ТекстВвода = ТекстВводаИзЧисла(НачальнаяСумма);
		
	КонецЕсли;
	
	Заголовок = ЗаголовокКлавиатуры;
	ОбновитьHTMLНаСервере();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовФормы

&НаКлиенте
Процедура ПолеHTMLПриНажатии(Элемент, ДанныеСобытия, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	КомандаПриложения = ИзвлечьКомандуИзСсылки(ДанныеСобытия.Href);
	
	Если Не ЗначениеЗаполнено(КомандаПриложения) Тогда
		
		Возврат;
		
	КонецЕсли;
	
	ОбработатьКомандуHTML(КомандаПриложения);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ОбработатьКомандуHTML(КомандаПриложения)
	
	Если КомандаПриложения = "back" Или КомандаПриложения = "cancel" Тогда
		
		Закрыть(Неопределено);
		
	ИначеЕсли КомандаПриложения = "done" Тогда
		
		Если РежимВвода = "телефон" Тогда
			
			Закрыть(ФорматТелефонаПоМаске(ТекстВвода));
			
		Иначе
			
			Сумма = ЧислоИзТекстаВвода(ТекстВвода);
			
			Если Сумма <= 0 Тогда
				
				Возврат;
				
			КонецЕсли;
			
			Закрыть(Сумма);
			
		КонецЕсли;
		
	ИначеЕсли КомандаПриложения = "noop" Тогда
		
		Возврат;
		
	ИначеЕсли КомандаПриложения = "clear" Тогда
		
		ТекстВвода = "";
		ОбновитьHTMLНаСервере();
		
	ИначеЕсли КомандаПриложения = "backspace" Тогда
		
		Если СтрДлина(ТекстВвода) > 0 Тогда
			
			ТекстВвода = Лев(ТекстВвода, СтрДлина(ТекстВвода) - 1);
			
		КонецЕсли;
		
		ОбновитьHTMLНаСервере();
		
	ИначеЕсли КомандаПриложения = "dot" Тогда
		
		Если РежимВвода = "телефон" Тогда
			
			Возврат;
			
		КонецЕсли;
		
		ДобавитьРазделитель();
		ОбновитьHTMLНаСервере();
		
	ИначеЕсли СтрНачинаетсяС(КомандаПриложения, "digit:") Тогда
		
		ДобавитьЦифры(Сред(КомандаПриложения, СтрДлина("digit:") + 1));
		ОбновитьHTMLНаСервере();
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьРазделитель()
	
	Если СтрНайти(ТекстВвода, ",") > 0 Тогда
		
		Возврат;
		
	КонецЕсли;
	
	Если ПустаяСтрока(ТекстВвода) Тогда
		
		ТекстВвода = "0,";
		
	Иначе
		
		ТекстВвода = ТекстВвода + ",";
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьЦифры(Цифры)
	
	Если РежимВвода = "телефон" Тогда
		
		ДобавитьЦифрыТелефона(Цифры);
		Возврат;
		
	КонецЕсли;
	
	ПозицияЗапятой = СтрНайти(ТекстВвода, ",");
	
	Если ПозицияЗапятой > 0 Тогда
		
		ДлинаДробной = СтрДлина(ТекстВвода) - ПозицияЗапятой;
		
		Если ДлинаДробной + СтрДлина(Цифры) > 2 Тогда
			
			Возврат;
			
		КонецЕсли;
		
		ТекстВвода = ТекстВвода + Цифры;
		Возврат;
		
	КонецЕсли;
	
	Если ТекстВвода = "0" Тогда
		
		Если Цифры = "00" Тогда
			
			Возврат;
			
		КонецЕсли;
		
		ТекстВвода = Цифры;
		Возврат;
		
	КонецЕсли;
	
	ЦелаяЧасть = ТекстВвода;
	
	Если СтрДлина(ЦелаяЧасть) + СтрДлина(Цифры) > 12 Тогда
		
		Возврат;
		
	КонецЕсли;
	
	ТекстВвода = ТекстВвода + Цифры;
	
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьЦифрыТелефона(Цифры)
	
	МаксЦифр = 11;
	Остаток = МаксЦифр - СтрДлина(ТекстВвода);
	
	Если Остаток <= 0 Тогда
		
		Возврат;
		
	КонецЕсли;
	
	Если СтрДлина(Цифры) > Остаток Тогда
		
		Цифры = Лев(Цифры, Остаток);
		
	КонецЕсли;
	
	ТекстВвода = ТекстВвода + Цифры;
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьHTMLНаСервере()
	
	ТекстHTML = СобратьHTMLКлавиатуры();
	
КонецПроцедуры

&НаСервере
Функция СобратьHTMLКлавиатуры()
	
	Если РежимВвода = "телефон" Тогда
		
		Возврат СобратьHTMLТелефона();
		
	КонецЕсли;
	
	СуммаЧисло = ЧислоИзТекстаВвода(ТекстВвода);
	СуммаОтображение = ПредставлениеСуммыДляЭкрана(ТекстВвода, СимволВалюты);
	КнопкаГотовоАктивна = СуммаЧисло > 0;
	КлассГотово = ?(КнопкаГотовоАктивна, "done", "done disabled");
	СсылкаГотово = ?(КнопкаГотовоАктивна, "app:done", "app:noop");
	
	Строки = Новый Массив;
	Строки.Добавить("<!DOCTYPE html><html lang=""ru""><head><meta charset=""utf-8"">");
	Строки.Добавить("<meta name=""viewport"" content=""width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no"">");
	Строки.Добавить("<style>");
	Строки.Добавить(СтилиКлавиатуры(ЦветСуммы));
	Строки.Добавить("</style></head><body>");
	
	Строки.Добавить("<div class=""sheet"">");
	Строки.Добавить("<div class=""top"">");
	Строки.Добавить("<a class=""icon-btn"" href=""app:back"">" + SVGСтрелкаНазад() + "</a>");
	Строки.Добавить("<div class=""title"">" + ЭкранироватьHTML(ЗаголовокКлавиатуры) + "</div>");
	Строки.Добавить("<span class=""icon-btn ghost""></span>");
	Строки.Добавить("</div>");
	
	Строки.Добавить("<div class=""amount"" style=""color:" + ЦветСуммы + """>" + СуммаОтображение + "</div>");
	Строки.Добавить("<div class=""hint"">Введите сумму</div>");
	
	Строки.Добавить("<div class=""pad"">");
	Строки.Добавить(HTMLРядКлавиш("1", "2", "3"));
	Строки.Добавить(HTMLРядКлавиш("4", "5", "6"));
	Строки.Добавить(HTMLРядКлавиш("7", "8", "9"));
	Строки.Добавить("<div class=""row"">");
	Строки.Добавить(HTMLКлавиша("00", "digit:00"));
	Строки.Добавить(HTMLКлавиша("0", "digit:0"));
	Строки.Добавить(HTMLКлавиша(",", "dot"));
	Строки.Добавить("</div>");
	Строки.Добавить("<div class=""row"">");
	Строки.Добавить(HTMLКлавиша(SVGBackspace(), "backspace", "danger"));
	Строки.Добавить(HTMLКлавиша("Очистить", "clear", "danger-text wide"));
	Строки.Добавить("</div>");
	Строки.Добавить("</div>");
	
	Строки.Добавить("<a class=""" + КлассГотово + """ href=""" + СсылкаГотово + """>Готово</a>");
	Строки.Добавить("</div></body></html>");
	
	Возврат СтрСоединить(Строки, Символы.ПС);
	
КонецФункции

&НаСервере
Функция СобратьHTMLТелефона()
	
	Отображение = ФорматТелефонаПоМаске(ТекстВвода);
	
	Если ПустаяСтрока(Отображение) Тогда
		
		Отображение = "9-999-999-99-99";
		КлассЭкрана = "amount placeholder";
		
	Иначе
		
		КлассЭкрана = "amount";
		
	КонецЕсли;
	
	Строки = Новый Массив;
	Строки.Добавить("<!DOCTYPE html><html lang=""ru""><head><meta charset=""utf-8"">");
	Строки.Добавить("<meta name=""viewport"" content=""width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no"">");
	Строки.Добавить("<style>");
	Строки.Добавить(СтилиКлавиатуры(ЦветСуммы));
	Строки.Добавить("</style></head><body>");
	
	Строки.Добавить("<div class=""sheet"">");
	Строки.Добавить("<div class=""top"">");
	Строки.Добавить("<a class=""icon-btn"" href=""app:back"">" + SVGСтрелкаНазад() + "</a>");
	Строки.Добавить("<div class=""title"">" + ЭкранироватьHTML(ЗаголовокКлавиатуры) + "</div>");
	Строки.Добавить("<a class=""done-top"" href=""app:done"">Готово</a>");
	Строки.Добавить("</div>");
	
	Строки.Добавить("<div class=""" + КлассЭкрана + """ style=""color:" + ЦветСуммы + """>"
		+ ЭкранироватьHTML(Отображение) + "</div>");
	Строки.Добавить("<div class=""hint"">Маска: 9-999-999-99-99</div>");
	
	Строки.Добавить("<div class=""pad"">");
	Строки.Добавить(HTMLРядКлавиш("1", "2", "3"));
	Строки.Добавить(HTMLРядКлавиш("4", "5", "6"));
	Строки.Добавить(HTMLРядКлавиш("7", "8", "9"));
	Строки.Добавить("<div class=""row"">");
	Строки.Добавить(HTMLКлавиша(SVGBackspace(), "backspace", "danger"));
	Строки.Добавить(HTMLКлавиша("0", "digit:0"));
	Строки.Добавить(HTMLКлавиша("Очистить", "clear", "danger-text"));
	Строки.Добавить("</div>");
	Строки.Добавить("</div>");
	Строки.Добавить("</div></body></html>");
	
	Возврат СтрСоединить(Строки, Символы.ПС);
	
КонецФункции

&НаСервере
Функция HTMLРядКлавиш(А, Б, В)
	
	Возврат "<div class=""row"">"
		+ HTMLКлавиша(А, "digit:" + А)
		+ HTMLКлавиша(Б, "digit:" + Б)
		+ HTMLКлавиша(В, "digit:" + В)
		+ "</div>";
	
КонецФункции

&НаСервере
Функция HTMLКлавиша(Содержимое, Команда, ДопКласс = "")
	
	Класс = "key";
	
	Если ЗначениеЗаполнено(ДопКласс) Тогда
		
		Класс = Класс + " " + ДопКласс;
		
	КонецЕсли;
	
	Возврат "<a class=""" + Класс + """ href=""app:" + Команда + """>" + Содержимое + "</a>";
	
КонецФункции

&НаСервере
Функция СтилиКлавиатуры(ЦветСуммы)
	
	Возврат "*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}"
		+ "body{font-family:-apple-system,BlinkMacSystemFont,""Segoe UI"",Roboto,Arial,sans-serif;background:#FAFAFA;color:#111827;min-height:100vh;display:flex;align-items:flex-end}"
		+ "a{text-decoration:none;color:inherit;-webkit-user-select:none;user-select:none}"
		+ ".sheet{width:100%;background:#fff;border-radius:16px 16px 0 0;padding:12px 14px calc(14px + env(safe-area-inset-bottom,0px));box-shadow:0 -4px 20px rgba(17,24,39,0.06)}"
		+ ".top{display:flex;align-items:center;gap:8px;margin-bottom:8px}"
		+ ".title{flex:1;font-size:16px;font-weight:700;color:#111827;text-align:center;min-width:0}"
		+ ".icon-btn{width:34px;height:34px;border-radius:50%;background:#F3F4F6;display:flex;align-items:center;justify-content:center;color:#6B7280;flex:0 0 auto}"
		+ ".icon-btn.ghost{visibility:hidden}"
		+ ".done-top{flex:0 0 auto;min-width:34px;height:34px;padding:0 10px;border-radius:17px;background:#2563EB;color:#fff;font-size:13px;font-weight:700;display:flex;align-items:center;justify-content:center}"
		+ ".done-top:active{background:#1D4ED8}"
		+ ".amount{text-align:center;font-size:34px;font-weight:700;letter-spacing:-0.02em;line-height:1.15;padding:8px 8px 2px;word-break:break-all}"
		+ ".amount.placeholder{color:#9CA3AF!important;font-weight:600;font-size:28px}"
		+ ".hint{text-align:center;font-size:12px;font-weight:600;color:#6B7280;margin-bottom:12px}"
		+ ".pad{margin-bottom:10px}"
		+ ".row{display:flex;margin:0 0 8px}"
		+ ".key{flex:1;height:52px;margin-right:8px;border-radius:14px;background:#fff;border:1px solid #E5E7EB;display:flex;align-items:center;justify-content:center;font-size:22px;font-weight:600;color:#111827}"
		+ ".row .key:last-child{margin-right:0}"
		+ ".key.wide{flex:2.1}"
		+ ".key.danger{color:#DC2626}"
		+ ".key.danger-text{font-size:15px;font-weight:700;color:#DC2626}"
		+ ".key:active{background:#FAFAFA;border-color:#3B82F6}"
		+ ".done{display:flex;align-items:center;justify-content:center;height:52px;border-radius:14px;background:#2563EB;color:#fff;font-size:16px;font-weight:700}"
		+ ".done.disabled{background:#E5E7EB;color:#6B7280;pointer-events:none}";
	
КонецФункции

&НаСервере
Функция ЦветПоРежиму(Режим)
	
	Если Режим = "income" Или Режим = "dohod" Или Режим = "приход" Тогда
		
		Возврат "#16A34A";
		
	ИначеЕсли Режим = "expense" Или Режим = "rashod" Или Режим = "расход" Тогда
		
		Возврат "#DC2626";
		
	КонецЕсли;
	
	Возврат "#2563EB";
	
КонецФункции

&НаСервере
Функция ТекстВводаИзЧисла(Сумма)
	
	Если Не ЗначениеЗаполнено(Сумма) Или Сумма = 0 Тогда
		
		Возврат "";
		
	КонецЕсли;
	
	Текст = Формат(Сумма, "ЧДЦ=2; ЧРД=,; ЧН=0; ЧГ=0");
	
	Пока СтрЗаканчиваетсяНа(Текст, "0") И СтрНайти(Текст, ",") > 0 Цикл
		
		Текст = Лев(Текст, СтрДлина(Текст) - 1);
		
	КонецЦикла;
	
	Если СтрЗаканчиваетсяНа(Текст, ",") Тогда
		
		Текст = Лев(Текст, СтрДлина(Текст) - 1);
		
	КонецЕсли;
	
	Возврат Текст;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ЧислоИзТекстаВвода(Текст)
	
	Если ПустаяСтрока(Текст) Или Текст = "," Тогда
		
		Возврат 0;
		
	КонецЕсли;
	
	Нормализованный = СтрЗаменить(Текст, " ", "");
	Нормализованный = СтрЗаменить(Нормализованный, Символы.НПП, "");
	Нормализованный = СтрЗаменить(Нормализованный, ",", ".");
	
	Если СтрЗаканчиваетсяНа(Нормализованный, ".") Тогда
		
		Нормализованный = Лев(Нормализованный, СтрДлина(Нормализованный) - 1);
		
	КонецЕсли;
	
	Попытка
		
		Возврат Число(Нормализованный);
		
	Исключение
		
		Возврат 0;
		
	КонецПопытки;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ТолькоЦифрыТелефона(Знач Текст)
	
	Результат = "";
	Текст = Строка(Текст);
	
	Для Индекс = 1 По СтрДлина(Текст) Цикл
		
		Символ = Сред(Текст, Индекс, 1);
		
		Если СтрНайти("0123456789", Символ) > 0 Тогда
			
			Результат = Результат + Символ;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Если СтрДлина(Результат) > 11 Тогда
		
		Результат = Лев(Результат, 11);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ФорматТелефонаПоМаске(Знач Текст)
	
	Цифры = ТолькоЦифрыТелефона(Текст);
	
	Если ПустаяСтрока(Цифры) Тогда
		
		Возврат "";
		
	КонецЕсли;
	
	Маска = "9-999-999-99-99";
	Результат = "";
	ИндексЦифры = 1;
	
	Для Позиция = 1 По СтрДлина(Маска) Цикл
		
		СимволМаски = Сред(Маска, Позиция, 1);
		
		Если СимволМаски = "9" Тогда
			
			Если ИндексЦифры > СтрДлина(Цифры) Тогда
				
				Прервать;
				
			КонецЕсли;
			
			Результат = Результат + Сред(Цифры, ИндексЦифры, 1);
			ИндексЦифры = ИндексЦифры + 1;
			
		Иначе
			
			Если ИндексЦифры > СтрДлина(Цифры) Тогда
				
				Прервать;
				
			КонецЕсли;
			
			Результат = Результат + СимволМаски;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Функция ПредставлениеСуммыДляЭкрана(Текст, Символ)
	
	Если ПустаяСтрока(Текст) Тогда
		
		Отображение = "0";
		
	Иначе
		
		Части = СтрРазделить(Текст, ",", Истина);
		Целая = Части[0];
		
		Если ПустаяСтрока(Целая) Тогда
			
			Целая = "0";
			
		КонецЕсли;
		
		Отображение = ГруппироватьЦифры(Целая);
		
		Если Части.Количество() > 1 Тогда
			
			Отображение = Отображение + "," + Части[1];
			
		ИначеЕсли СтрЗаканчиваетсяНа(Текст, ",") Тогда
			
			Отображение = Отображение + ",";
			
		КонецЕсли;
		
	КонецЕсли;
	
	Отображение = СтрЗаменить(Отображение, " ", "&nbsp;");
	
	Если ЗначениеЗаполнено(Символ) Тогда
		
		Отображение = Отображение + "&nbsp;" + ЭкранироватьHTML(Символ);
		
	КонецЕсли;
	
	Возврат Отображение;
	
КонецФункции

&НаСервере
Функция ГруппироватьЦифры(Цифры)
	
	Результат = "";
	
	Пока СтрДлина(Цифры) > 3 Цикл
		
		Результат = "&nbsp;" + Прав(Цифры, 3) + Результат;
		Цифры = Лев(Цифры, СтрДлина(Цифры) - 3);
		
	КонецЦикла;
	
	Возврат Цифры + Результат;
	
КонецФункции

&НаСервере
Функция ЭкранироватьHTML(Знач Текст)
	
	Результат = Строка(Текст);
	Результат = СтрЗаменить(Результат, "&", "&amp;");
	Результат = СтрЗаменить(Результат, "<", "&lt;");
	Результат = СтрЗаменить(Результат, ">", "&gt;");
	Результат = СтрЗаменить(Результат, """", "&quot;");
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Функция ИзвлечьКомандуИзСсылки(Знач АдресСсылки)
	
	Если Не ЗначениеЗаполнено(АдресСсылки) Тогда
		
		Возврат "";
		
	КонецЕсли;
	
	АдресСсылки = СокрЛП(АдресСсылки);
	Позиция = СтрНайти(НРег(АдресСсылки), "app:");
	
	Если Позиция = 0 Тогда
		
		Возврат "";
		
	КонецЕсли;
	
	Возврат Сред(АдресСсылки, Позиция + 4);
	
КонецФункции

&НаСервере
Функция SVGСтрелкаНазад()
	
	Возврат "<svg width=""18"" height=""18"" viewBox=""0 0 24 24"" fill=""none"" stroke=""currentColor"" stroke-width=""2"" stroke-linecap=""round"" stroke-linejoin=""round""><path d=""M15 18l-6-6 6-6""/></svg>";
	
КонецФункции

