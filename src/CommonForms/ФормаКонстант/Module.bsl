////////////////////////////////////////////////////////////////////////////////
// Форма констант: валюта учёта, режим курсов, автообновление.
////////////////////////////////////////////////////////////////////////////////

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	НастроитьДоступностьАвтообновления();
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ОбщийМодульКлиент.ИзменитьРазмерШрифтаЭлементов(ЭтаФорма);
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	
	Если ЗавершениеРаботы Тогда
		
		Возврат;
		
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(НаборКонстант.ВалютаУчета) Тогда
		
		Отказ = Истина;
		
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Укажите валюту учёта перед продолжением работы.";
		Сообщение.Поле = "ВалютаУчета";
		Сообщение.Сообщить();
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	
	Если ЗначениеЗаполнено(НаборКонстант.ВалютаУчета) Тогда
		
		ОбщийМодульСервер_СистемныеНастройки.ПрошелПервыйЗапуск();
		
	КонецЕсли;
	
	ОбщийМодульСервер_КурсыВалют.ПрименитьНастройкиАвтообновленияКурсов();
	НастроитьДоступностьАвтообновления();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовФормы

&НаКлиенте
Процедура ИспользоватьПоследнийИзвестныйКурсПриИзменении(Элемент)
	
	Если НаборКонстант.ИспользоватьПоследнийИзвестныйКурс Тогда
		
		НаборКонстант.АвтообновлениеКурсовВалют = Ложь;
		
	КонецЕсли;
	
	НастроитьДоступностьАвтообновленияНаКлиенте();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ОбновитьКурсыСейчас(Команда)
	
	Результат = ОбновитьКурсыНаСервере();
	ПоказатьПредупреждение(, Результат);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Функция ОбновитьКурсыНаСервере()
	
	РезультатОбновления = ОбщийМодульСервер_КурсыВалют.ОбновитьКурсыВалют();
	Возврат РезультатОбновления.Текст;
	
КонецФункции

&НаСервере
Процедура НастроитьДоступностьАвтообновления()
	
	ДоступноАвтообновление = Не НаборКонстант.ИспользоватьПоследнийИзвестныйКурс;
	Элементы.АвтообновлениеКурсовВалют.Доступность = ДоступноАвтообновление;
	
	Если Не ДоступноАвтообновление Тогда
		
		НаборКонстант.АвтообновлениеКурсовВалют = Ложь;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура НастроитьДоступностьАвтообновленияНаКлиенте()
	
	ДоступноАвтообновление = Не НаборКонстант.ИспользоватьПоследнийИзвестныйКурс;
	Элементы.АвтообновлениеКурсовВалют.Доступность = ДоступноАвтообновление;
	
КонецПроцедуры

#КонецОбласти
