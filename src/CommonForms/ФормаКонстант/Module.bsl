////////////////////////////////////////////////////////////////////////////////
// Форма констант: начальная настройка (валюта учёта).
////////////////////////////////////////////////////////////////////////////////

#Область ОбработчикиСобытийФормы

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ОбщийМодульКлиент.ИзменитьРазмерШрифтаЭлементов(ЭтаФорма);
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	
	Если ЗавершениеРаботы Тогда
		
		Возврат;
		
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(НаборКонстант.ВалютаУчета) Тогда
		
		Отказ = Истина;
		
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Укажите валюту учёта перед продолжением работы.";
		Сообщение.Поле = "ВалютаУчета";
		Сообщение.Сообщить();
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	
	Если ЗначениеЗаполнено(НаборКонстант.ВалютаУчета) Тогда
		
		ОбщийМодульСервер_СистемныеНастройки.УстановитьНачальнаяНастройкаВыполнена(Истина);
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти
