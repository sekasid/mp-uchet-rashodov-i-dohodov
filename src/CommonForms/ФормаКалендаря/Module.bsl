////////////////////////////////////////////////////////////////////////////////
// Общая форма календаря.
// Параметр ТолькоДата = Истина — скрывает поле времени (выбор только даты).
// Параметр Дата — начальная дата в календаре (если не передана — текущая).
// Оповещение «ВыборДаты» отправляется только после явного выбора (день или «Выбрать»).
////////////////////////////////////////////////////////////////////////////////

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ТолькоДата = Ложь;
	ДатаПодтверждена = Ложь;
	
	Если Параметры.Свойство("ТолькоДата") Тогда
		
		ТолькоДата = Параметры.ТолькоДата;
		
	КонецЕсли;
	
	Элементы.Время.Видимость = Не ТолькоДата;
	
	Если Параметры.Свойство("Дата") И ЗначениеЗаполнено(Параметры.Дата) Тогда
		
		Период = НачалоДня(Параметры.Дата);
		
	ИначеЕсли Не ЗначениеЗаполнено(Период) Тогда
		
		Период = НачалоДня(ТекущаяДата());
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовФормы

&НаКлиенте
Процедура ПериодВыбор(Элемент, ВыбраннаяДата)
	
	Период = НачалоДня(ВыбраннаяДата);
	ДатаПодтверждена = Истина;
	Закрыть();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ЗакрытьФорму(Команда)
	
	ДатаПодтверждена = Истина;
	Закрыть();
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	
	Если Не ДатаПодтверждена Или Не ЗначениеЗаполнено(Период) Тогда
		
		Возврат;
		
	КонецЕсли;
	
	ПараметрыВыбора = Новый Структура;
	ПараметрыВыбора.Вставить("Период", НачалоДня(Период));
	ПараметрыВыбора.Вставить("Время", ?(ТолькоДата, '00010101', Время));
	ПараметрыВыбора.Вставить("ТолькоДата", ТолькоДата);
	Оповестить("ВыборДаты", ПараметрыВыбора);
	
КонецПроцедуры

#КонецОбласти
