////////////////////////////////////////////////////////////////////////////////
// Общая форма быстрого ввода операции (приход / расход).
////////////////////////////////////////////////////////////////////////////////

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Свойство("ВидОперации") Тогда
		
		ВидОперации = Параметры.ВидОперации;
		
	КонецЕсли;
	
	Валюта = ОбщийМодульСервер_СистемныеНастройки.ПолучитьВалютуРегламентированногоУчета();
	ДатаДокумента = ТекущаяДата();
	
	Если ВидОперации = Перечисления.ВидОперацииДокумента.Приход Тогда
		
		СформироватьФормуПрихода();
		ЭтотОбъект.Заголовок = "Приход";
		
	ИначеЕсли ВидОперации = Перечисления.ВидОперацииДокумента.Расход Тогда
		
		СформироватьФормуРасхода();
		ЭтотОбъект.Заголовок = "Расход";
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "ВыборДаты" Тогда
		
		Если ТипЗнч(Параметр) = Тип("Структура") Тогда
			
			Если ЗначениеЗаполнено(Параметр.Время) Тогда
				
				Часов = Час(Параметр.Время);
				Минут = Минута(Параметр.Время);
				Секунд = Секунда(Параметр.Время);
				ВсегоСекунд = Часов * 3600 + Минут * 60 + Секунд;
				
			Иначе
				
				ВсегоСекунд = 0;
				
			КонецЕсли;
			
			ДатаДокумента = Параметр.Период + ВсегоСекунд;
			
		КонецЕсли;
		
	ИначеЕсли ИмяСобытия = "ВводЦифр" Тогда
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Записать(Команда)
	
	Если Не ДанныеОперацииЗаполненыКорректно() Тогда
		
		Возврат;
		
	КонецЕсли;
	
	Категория = КатегорияПоВидуОперации();
	
	ОбщийМодульКлиент.СоздатьИПровестиОперацию(ДатаДокумента, ВидОперации, Категория, Счет, Валюта, Сумма);
	
	Закрыть(Истина);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовФормы

&НаКлиенте
Процедура ДатаНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	ОткрытьФорму("ОбщаяФорма.ФормаКалендаря", , ЭтотОбъект, , , , , РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
	
КонецПроцедуры

&НаКлиенте
Процедура СуммаНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	ОткрытьФорму("ОбщаяФорма.ФормаЦифры", , ЭтотОбъект, , , , , РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура СформироватьФормуПрихода()
	
	МассивРеквизитов = Новый Массив;
	МассивРеквизитов.Добавить("ДатаДокумента");
	МассивРеквизитов.Добавить("Счет");
	МассивРеквизитов.Добавить("КатегорияДоходов");
	МассивРеквизитов.Добавить("Валюта");
	МассивРеквизитов.Добавить("Сумма");
	ОбщийМодульСервер.ДобавитьРеквизитНаФорму(ЭтотОбъект, МассивРеквизитов);
	ОбщийМодульСервер.УстановитьДействиеРеквизитуНаФорме(ЭтотОбъект, "ДатаДокумента", "НачалоВыбора", "ДатаНачалоВыбора");
	
	УстановитьОтметкуНезаполненного("ДатаДокумента");
	УстановитьОтметкуНезаполненного("Счет");
	УстановитьОтметкуНезаполненного("КатегорияДоходов");
	УстановитьОтметкуНезаполненного("Валюта");
	УстановитьОтметкуНезаполненного("Сумма");
	
	ОбщийМодульСервер.ДобавитьКомандуНаФорму(ЭтотОбъект, "Записать", "ЗаписатьДокумент", "Записать документ");
	
КонецПроцедуры

&НаСервере
Процедура СформироватьФормуРасхода()
	
	МассивРеквизитов = Новый Массив;
	МассивРеквизитов.Добавить("ДатаДокумента");
	МассивРеквизитов.Добавить("Счет");
	МассивРеквизитов.Добавить("КатегорияРасходов");
	МассивРеквизитов.Добавить("Валюта");
	МассивРеквизитов.Добавить("Сумма");
	ОбщийМодульСервер.ДобавитьРеквизитНаФорму(ЭтотОбъект, МассивРеквизитов);
	ОбщийМодульСервер.УстановитьДействиеРеквизитуНаФорме(ЭтотОбъект, "ДатаДокумента", "НачалоВыбора", "ДатаНачалоВыбора");
	
	УстановитьОтметкуНезаполненного("ДатаДокумента");
	УстановитьОтметкуНезаполненного("Счет");
	УстановитьОтметкуНезаполненного("КатегорияРасходов");
	УстановитьОтметкуНезаполненного("Валюта");
	УстановитьОтметкуНезаполненного("Сумма");
	
	ОбщийМодульСервер.ДобавитьКомандуНаФорму(ЭтотОбъект, "Записать", "ЗаписатьДокумент", "Записать документ");
	
КонецПроцедуры

&НаСервере
Процедура УстановитьОтметкуНезаполненного(ИмяЭлемента)
	
	ЭлементФормы = Элементы.Найти(ИмяЭлемента);
	
	Если ЭлементФормы <> Неопределено Тогда
		
		ЭлементФормы.АвтоОтметкаНезаполненного = Истина;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Функция КатегорияПоВидуОперации()
	
	Если ВидОперации = ПредопределенноеЗначение("Перечисление.ВидОперацииДокумента.Приход") Тогда
		
		Возврат КатегорияДоходов;
		
	КонецЕсли;
	
	Возврат КатегорияРасходов;
	
КонецФункции

&НаКлиенте
Функция ДанныеОперацииЗаполненыКорректно()
	
	Отказ = Ложь;
	
	Если Не ЗначениеЗаполнено(ДатаДокумента) Тогда
		
		ПоказатьОшибкуЗаполнения("Не заполнена дата операции.", "ДатаДокумента");
		Отказ = Истина;
		
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Счет) Тогда
		
		ПоказатьОшибкуЗаполнения("Не заполнен счет.", "Счет");
		Отказ = Истина;
		
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Валюта) Тогда
		
		ПоказатьОшибкуЗаполнения("Не заполнена валюта.", "Валюта");
		Отказ = Истина;
		
	КонецЕсли;
	
	Если ВидОперации = ПредопределенноеЗначение("Перечисление.ВидОперацииДокумента.Приход") Тогда
		
		Если Не ЗначениеЗаполнено(КатегорияДоходов) Тогда
			
			ПоказатьОшибкуЗаполнения("Не заполнена категория доходов.", "КатегорияДоходов");
			Отказ = Истина;
			
		КонецЕсли;
		
	ИначеЕсли ВидОперации = ПредопределенноеЗначение("Перечисление.ВидОперацииДокумента.Расход") Тогда
		
		Если Не ЗначениеЗаполнено(КатегорияРасходов) Тогда
			
			ПоказатьОшибкуЗаполнения("Не заполнена категория расходов.", "КатегорияРасходов");
			Отказ = Истина;
			
		КонецЕсли;
		
	Иначе
		
		ПоказатьОшибкуЗаполнения("Не указан вид операции.", "");
		Отказ = Истина;
		
	КонецЕсли;
	
	Если Сумма <= 0 Тогда
		
		ПоказатьОшибкуЗаполнения("Сумма операции должна быть больше нуля.", "Сумма");
		Отказ = Истина;
		
	КонецЕсли;
	
	Возврат Не Отказ;
	
КонецФункции

&НаКлиенте
Процедура ПоказатьОшибкуЗаполнения(ТекстСообщения, ИмяПоля)
	
	Сообщение = Новый СообщениеПользователю;
	Сообщение.Текст = ТекстСообщения;
	
	Если ЗначениеЗаполнено(ИмяПоля) Тогда
		
		Сообщение.Поле = ИмяПоля;
		
	КонецЕсли;
	
	Сообщение.Сообщить();
	
КонецПроцедуры

#КонецОбласти
